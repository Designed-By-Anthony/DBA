{
  "name": "designed-by-anthony-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@firebase/util",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "protobufjs",
      "re2",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "build:turbo": "turbo run build --filter=./apps/web-viewer",
    "dev:web": "pnpm --filter agency-os dev",
    "dev:web:test": "pnpm --filter agency-os dev:test",
    "dev:lighthouse": "pnpm --filter lighthouse-audit dev",
    "dev:marketing": "pnpm --filter designed-by-anthony dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:push": "pnpm --filter @dba/database run db:push",
    "db:seed:master": "pnpm --filter @dba/database run db:seed:master",
    "db:apply-rls": "pnpm --filter @dba/database run db:apply-rls",
    "db:verify-rls": "pnpm --filter @dba/database run db:verify-rls",
    "test:e2e": "pnpm run test:e2e:marketing && pnpm run test:e2e:lighthouse && pnpm run test:e2e:web",
    "test:e2e:marketing": "pnpm --filter designed-by-anthony run test:release",
    "test:e2e:lighthouse": "pnpm --filter lighthouse-audit run test",
    "test:e2e:web": "pnpm --filter agency-os run test",
    "test:e2e:smoke:web": "pnpm --filter agency-os exec playwright test tests/smoke.spec.ts --project=chromium",
    "test:e2e:web:smoke": "pnpm --filter agency-os run test:e2e:smoke"
  }
}
