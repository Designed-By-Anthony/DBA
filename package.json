{
	"name": "designed-by-anthony-monorepo",
	"private": true,
	"packageManager": "pnpm@10.12.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@clerk/shared",
			"@sentry/cli",
			"@swc/core",
			"esbuild",
			"protobufjs",
			"re2",
			"sharp",
			"unrs-resolver"
		],
		"overrides": {
			"yaml@<2.8.3": "^2.8.3"
		}
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"build": "turbo run build",
		"lint": "turbo run lint",
		"dev": "turbo run dev",
		"dev:lighthouse": "pnpm --filter dba-lighthouse-audit dev",
		"dev:marketing": "pnpm --filter dbastudio-315 dev",
		"test:e2e": "npx cypress run",
		"test:cypress": "npx cypress run",
		"test:cypress:open": "npx cypress open"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^22.10.2",
		"cypress": "^15.14.0",
		"turbo": "^2.9.6",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@vercel/functions": "^3.4.3"
	}
}
