{
	"name": "dba-monorepo",
	"version": "0.0.1",
	"private": true,
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"postcss": "^8.5.12",
		"uuid": "^14.0.0",
		"yaml@<2.8.3": "^2.8.3"
	},
	"scripts": {
		"dev": "turbo run dev --parallel",
		"dev:web": "turbo run dev --filter=@dba/web",
		"dev:api": "turbo run dev --filter=@dba/api",
		"build": "turbo run build",
		"build:web": "turbo run build --filter=@dba/web",
		"build:api": "turbo run build --filter=@dba/api",
		"deploy:web": "turbo run deploy --filter=@dba/web",
		"deploy:api": "turbo run deploy --filter=@dba/api",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check . --write --unsafe",
		"test:e2e": "cypress run",
		"test:cypress": "cypress run",
		"test:cypress:open": "cypress open",
		"test:playwright": "playwright test",
		"test:playwright:render": "playwright test playwright/pages-render.spec.ts",
		"test:playwright:zap": "cross-env PLAYWRIGHT_ZAP=1 playwright test",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@playwright/test": "^1.52.0",
		"cross-env": "^10.1.0",
		"cypress": "^15.14.2",
		"drizzle-kit": "^0.31.10",
		"turbo": "^2.9.6"
	}
}
