{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["middleware.ts", "tsconfig.json", "vercel.json"],
  "globalEnv": [
    "ADMIN_UPSTREAM_URL",
    "ACCOUNTS_UPSTREAM_URL",
    "LIGHTHOUSE_UPSTREAM_URL",
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_GIT_COMMIT_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DATABASE_SSL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SIGNING_SECRET",
        "NEXT_PUBLIC_SENTRY_DSN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "GOOGLE_PAGESPEED_API_KEY",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "RESEND_API_KEY",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_FROM_NUMBER",
        "COMMS_EMAIL_DISABLED",
        "COMMS_SMS_DISABLED",
        "TURNSTILE_SECRET_KEY",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_CLIENT_EMAIL",
        "FIREBASE_PRIVATE_KEY",
        "FIRESTORE_DATABASE_ID",
        "NEXT_PUBLIC_FIREBASE_API_KEY",
        "NEXT_PUBLIC_FIREBASE_APP_ID",
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
        "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "NEXT_PUBLIC_FCM_VAPID_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_AGENCY_PRO_PRICE_ID",
        "LEAD_WEBHOOK_SECRET",
        "LEAD_WEBHOOK_CORS_ORIGINS",
        "LEAD_WEBHOOK_DEFAULT_AGENCY_ID",
        "INGEST_SECRET",
        "LEAD_INGEST_REQUIRE_SECRET",
        "PUBLIC_LEAD_INGEST_DISABLED",
        "PUBLIC_INGEST_URL",
        "PUBLIC_TENANT_ID",
        "AGENCY_OS_LEAD_INGEST_URL",
        "AGENCY_OS_WEBHOOK_URL",
        "AGENCY_OS_WEBHOOK_SECRET",
        "INDEXNOW_KEY",
        "INDEXNOW_ENDPOINT",
        "INDEXNOW_FALLBACK_ENDPOINTS",
        "PUBLIC_API_URL",
        "PUBLIC_CRM_LEAD_URL",
        "PUBLIC_SENTRY_DSN",
        "REPORT_PUBLIC_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
