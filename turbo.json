{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"middleware.ts",
		"tsconfig.json",
		"apps/*/vercel.json"
	],
	"globalEnv": [
		"LIGHTHOUSE_UPSTREAM_URL",
		"NODE_ENV",
		"VERCEL",
		"VERCEL_ENV",
		"VERCEL_URL",
		"VERCEL_GIT_COMMIT_SHA"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**",
				".vercel/output/**"
			],
			"env": [
				"DATABASE_URL",
				"DATABASE_URL_UNPOOLED",
				"DATABASE_SSL",
				"NEXT_PUBLIC_APP_URL",
				"NEXTAUTH_SECRET",
				"NEXTAUTH_URL",
				"NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
				"NEXT_PUBLIC_admin_CLERK_PUBLISHABLE_KEY",
				"admin_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
				"NEXT_PUBLIC_CLERK_DOMAIN",
				"NEXT_PUBLIC_CLERK_PROXY_URL",
				"NEXT_PUBLIC_CLERK_JS_URL",
				"NEXT_PUBLIC_CLERK_UI_URL",
				"CLERK_FAPI_UPSTREAM",
				"CLERK_SECRET_KEY",
				"admin_CLERK_SECRET_KEY",
				"CLERK_WEBHOOK_SIGNING_SECRET",
				"ADMIN_PASSPHRASE",
				"ADMIN_ALLOWED_ORG_IDS",
				"ADMIN_ALLOWED_USER_IDS",
				"NEXT_PUBLIC_SENTRY_DSN",
				"NEXT_PUBLIC_VERCEL_WEB_ANALYTICS",
				"NEXT_PUBLIC_SENTRY_REPLAY",
				"SENTRY_AUTH_TOKEN",
				"SENTRY_DSN",
				"SENTRY_ORG",
				"SENTRY_PROJECT",
				"SENTRY_PUBLIC_KEY",
				"SENTRY_OTLP_TRACES_URL",
				"SENTRY_VERCEL_LOG_DRAIN_URL",
				"GOOGLE_PAGESPEED_API_KEY",
				"GOOGLE_PLACES_API_KEY",
				"GEMINI_API_KEY",
				"GEMINI_MODEL",
				"MOZ_API_CREDENTIALS",
				"RESEND_API_KEY",
				"TWILIO_ACCOUNT_SID",
				"TWILIO_AUTH_TOKEN",
				"TWILIO_FROM_NUMBER",
				"COMMS_EMAIL_DISABLED",
				"COMMS_SMS_DISABLED",
				"TURNSTILE_SECRET_KEY",
				"NEXT_PUBLIC_TURNSTILE_SITE_KEY",
				"GOOGLE_SERVICE_ACCOUNT_EMAIL",
				"GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY",
				"STRIPE_SECRET_KEY",
