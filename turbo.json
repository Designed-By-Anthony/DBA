				"STREAM_CHAT_SECRET",
				"STREAM_CHAT_INBOX_USER_ID",
				"STREAM_CHAT_INBOX_NAME",
				"BROWSERBASE_API_KEY",
				"BROWSERBASE_PROJECT_ID",
				"GEMINI_API_KEY",
				"NEON_AUTH_BASE_URL",
				"VITE_NEON_AUTH_URL",
				"R2_ACCOUNT_ID",
				"R2_ACCESS_KEY_ID",
				"R2_SECRET_ACCESS_KEY",
				"R2_BUCKET_NAME",
				"PRINTNODE_API_KEY",
				"GEMINI_API_KEY"
			]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"cache": false
		}
	}
}
