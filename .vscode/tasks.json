{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "bun: build (monorepo)",
			"type": "shell",
			"command": "bun run build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "bun: web dev",
			"type": "shell",
			"command": "bun run dev:web",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		}
	]
}
