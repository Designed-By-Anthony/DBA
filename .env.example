# ==============================================================================
# Designed by Anthony — Turborepo root .env.example
# ==============================================================================
#
# Exhaustive list of every environment variable any app in this repo reads at
# build time or runtime. Cross-checked against:
#   • `turbo.json` → `tasks.build.env`  (the build allowlist)
#   • every `process.env.*` / `import.meta.env.*` reference in `apps/**`
#   • `packages/env/src/{marketing,web-viewer,lighthouse}.ts` (Zod schemas)
#
# Copy to `.env` for local dev (git-ignored), or paste into Vercel →
# Settings → Environment Variables for the single-project Turborepo deploy.
#
# Labels:
#   REQUIRED  — production deploy will fail or break core functionality without it
#   OPTIONAL  — feature-flagged or has a working default
# ==============================================================================


# ------------------------------------------------------------------------------
# Host-based routing gateway  (root middleware.ts)
# ------------------------------------------------------------------------------
# Only used when the three apps are split across three Vercel projects.
# With a single-project Turborepo build, leave these UNSET.
#
# ADMIN_UPSTREAM_URL           OPTIONAL  https://<web-viewer>.vercel.app
# ACCOUNTS_UPSTREAM_URL        OPTIONAL  https://<web-viewer>.vercel.app
# LIGHTHOUSE_UPSTREAM_URL      OPTIONAL  https://<lighthouse>.vercel.app


# ==============================================================================
# apps/marketing  —  designedbyanthony.com  (Astro)
# ==============================================================================

# --- Lead + audit integration (public = inlined into the static site) ---
# PUBLIC_CRM_LEAD_URL            REQUIRED   full URL of Agency OS POST /api/lead  (e.g. https://admin.designedbyanthony.com/api/lead)
# PUBLIC_API_URL                 REQUIRED   Lighthouse audit base URL           (e.g. https://lighthouse.designedbyanthony.com)
# PUBLIC_TURNSTILE_SITE_KEY      REQUIRED   Cloudflare Turnstile site key       (1x00000000000000000000AA = always-pass test key)

# --- Sentry (marketing) ---
# PUBLIC_SENTRY_DSN              OPTIONAL   browser DSN, also drives CSP report-uri via `npm run sync:firebase-csp`
# SENTRY_DSN                     OPTIONAL   server/edge DSN (usually same as PUBLIC_SENTRY_DSN)
# SENTRY_AUTH_TOKEN              OPTIONAL   sourcemap uploads (build skips them if unset)
# SENTRY_ORG                     OPTIONAL   defaults to `designed-by-anthony`
# SENTRY_PROJECT                 OPTIONAL   defaults to `javascript-astro`
# SENTRY_CSP_ENVIRONMENT         OPTIONAL   tag for CSP reports
# PUBLIC_SENTRY_ENVIRONMENT      OPTIONAL   tag for CSP reports

# --- IndexNow (build-time URL submission) ---
# INDEXNOW_KEY                   OPTIONAL   overrides default a503ff689a18407993ac047df017d9a8
# INDEXNOW_ENDPOINT              OPTIONAL   primary endpoint
# INDEXNOW_FALLBACK_ENDPOINTS    OPTIONAL   comma-separated fallbacks (empty = disabled)


# ==============================================================================
# apps/web-viewer  —  Agency OS CRM  (Next.js)
#                     admin.designedbyanthony.com + accounts.designedbyanthony.com
# ==============================================================================

# --- Clerk auth (REQUIRED in production) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# If NEXT_PUBLIC_CLERK_DOMAIN is set, DNS must resolve `clerk.<domain>` OR set
# NEXT_PUBLIC_CLERK_PROXY_URL=https://<instance>.clerk.accounts.dev (Clerk dashboard → Frontend API),
# or CLERK_FAPI_UPSTREAM to the same URL (server-only; enables /clerk-fapi proxy in web-viewer).
# CLERK_WEBHOOK_SIGNING_SECRET   OPTIONAL   needed only if you consume organization.* webhooks  (whsec_...)

# --- Cloud SQL / Postgres 18 (REQUIRED in production) ---
# Public IP  +  TLS          :  postgresql://USER:PASS@34.172.29.180:5432/DB?sslmode=require
# Cloud SQL Auth Proxy (best) :  postgresql://USER:PASS@127.0.0.1:5432/DB
DATABASE_URL=
# DATABASE_SSL                   OPTIONAL   legacy opt-in; no longer needed when DATABASE_URL carries `?sslmode=...`

# --- App URL (emails, Stripe return URLs, Clerk redirects, push notifications) ---
# NEXT_PUBLIC_APP_URL            REQUIRED   https://admin.designedbyanthony.com
# NEXTAUTH_URL                   OPTIONAL   legacy override; falls back to NEXT_PUBLIC_APP_URL
# NEXTAUTH_SECRET                OPTIONAL   signs email-tracking tokens (falls back to a placeholder)

# --- Lead intake + server-to-server webhook ---
# LEAD_WEBHOOK_DEFAULT_AGENCY_ID REQUIRED   Clerk org id for anonymous leads + Calendly new-booking tenant (e.g. org_3CWuIWj5aFCaZXr8dUEpwtGSiCW)
# LEAD_WEBHOOK_SECRET            REQUIRED   shared secret for POST /api/webhooks/lead (must match lighthouse AGENCY_OS_WEBHOOK_SECRET)
# LEAD_WEBHOOK_CORS_ORIGINS      OPTIONAL   comma-separated browser origins allowed to POST /api/lead
# LEAD_SEND_SUBMITTER_CONFIRMATION  OPTIONAL  "true" to auto-reply to form submitter
# PUBLIC_LEAD_INGEST_DISABLED    OPTIONAL   "true" to disable browser POST /api/lead (webhook only)

# --- Transactional email (Resend) ---
# RESEND_API_KEY                 REQUIRED   if unset, mailer runs in test-fire mode
# EMAIL_TEST_MODE                OPTIONAL   "true" forces test-fire regardless of RESEND_API_KEY

# --- Turnstile (server-side verification) ---
# TURNSTILE_SECRET_KEY           OPTIONAL   server-side secret matching the marketing PUBLIC_TURNSTILE_SITE_KEY

# --- Stripe (Billing module — planSuite=full) ---
# STRIPE_SECRET_KEY              REQUIRED (if billing enabled)
# STRIPE_WEBHOOK_SECRET          REQUIRED (if billing enabled)
# STRIPE_AGENCY_PRO_PRICE_ID     REQUIRED (if billing enabled)   price_...

# --- Web Push / PWA notifications ---
# NEXT_PUBLIC_FCM_VAPID_KEY      OPTIONAL   VAPID public key (browser-facing)
# VAPID_PUBLIC_KEY               OPTIONAL   alternate name for the public key
# VAPID_PRIVATE_KEY              OPTIONAL   VAPID private key (server-side)
# VAPID_CONTACT_EMAIL            OPTIONAL   defaults to mailto:anthony@designedbyanthony.com

# --- Google Workspace integrations (contracts, Drive, Docs) ---
# GOOGLE_APPLICATION_CREDENTIALS OPTIONAL   path to a service-account JSON file
# GOOGLE_CLIENT_ID               OPTIONAL   OAuth refresh-token flow
# GOOGLE_CLIENT_SECRET           OPTIONAL   OAuth refresh-token flow
# GOOGLE_REFRESH_TOKEN           OPTIONAL   OAuth refresh-token flow
# GOOGLE_DOCS_MSA_TEMPLATE_ID    OPTIONAL   source doc for contract generator
# GOOGLE_DRIVE_CONTRACTS_FOLDER_ID OPTIONAL folder for generated contracts
# GOOGLE_DRIVE_CLIENTS_FOLDER_ID OPTIONAL   folder for client records
# FIREBASE_CLIENT_EMAIL          OPTIONAL   used as fallback service-account email
# FIREBASE_PRIVATE_KEY           OPTIONAL   used as fallback service-account key  (escape newlines as \\n)

# --- Cron / scheduled tasks (Vercel Cron) ---
# CRON_SECRET                    REQUIRED (if crons run)   shared Bearer token for POST /api/cron/*

# --- Sentry (web-viewer) ---
# NEXT_PUBLIC_SENTRY_DSN         OPTIONAL
# SENTRY_DSN                     OPTIONAL
# SENTRY_AUTH_TOKEN              OPTIONAL
# SENTRY_ORG                     OPTIONAL
# SENTRY_PROJECT                 OPTIONAL
# SENTRY_ENABLE_DEV              OPTIONAL   "true" to enable Sentry in dev builds


# ==============================================================================
# apps/lighthouse  —  audit engine  (Next.js, lighthouse.designedbyanthony.com)
# ==============================================================================

# --- Core audit APIs (REQUIRED for audits to run) ---
# GOOGLE_PAGESPEED_API_KEY       REQUIRED   PageSpeed Insights API key
# GEMINI_API_KEY                 REQUIRED   (or) GOOGLE_API_KEY — Gemini API key
# GEMINI_MODEL                   OPTIONAL   defaults to gemini-2.5-pro
# GOOGLE_API_KEY                 OPTIONAL   alternate to GEMINI_API_KEY
# GOOGLE_CLOUD_PROJECT           OPTIONAL   defaults to lighthouse-492701 (Vertex fallback)
# GOOGLE_CLOUD_LOCATION          OPTIONAL   defaults to us-east4

# --- Turnstile (shared with web-viewer; values MUST match) ---
# TURNSTILE_SECRET_KEY           OPTIONAL
# NEXT_PUBLIC_TURNSTILE_SITE_KEY OPTIONAL

# --- CORS allowlist (comma-separated) ---
# ALLOWED_ORIGINS                OPTIONAL   defaults permit marketing + admin

# --- Forward leads to Agency OS ---
# AGENCY_OS_WEBHOOK_URL          REQUIRED   https://admin.designedbyanthony.com/api/webhooks/lead
# AGENCY_OS_WEBHOOK_SECRET       REQUIRED   MUST match web-viewer LEAD_WEBHOOK_SECRET
# AGENCY_OS_LEAD_INGEST_URL      OPTIONAL   override for POST /api/contact CRM target
# REPORT_PUBLIC_BASE_URL         OPTIONAL   where /report/:id is served  (defaults https://designedbyanthony.com)

# --- Optional: Google Workspace (Sheets archive + Drive delivery) ---
# GMAIL_SERVICE_ACCOUNT_KEY      OPTIONAL   full service-account JSON as a single line
# SHEETS_ID                      OPTIONAL   lead archive spreadsheet ID
# DRIVE_PROJECTS_FOLDER_ID       OPTIONAL   Drive folder for delivered reports

# --- Optional: enrichment APIs (audit degrades gracefully) ---
# MOZ_API_CREDENTIALS            OPTIONAL   base64 accessId:secretKey OR x-moz-token
# MOZ_API_TOKEN                  OPTIONAL   alias of MOZ_API_CREDENTIALS
# MOZ_LOCAL_API_KEY              OPTIONAL   legacy fallback (Cloud Functions)
# GOOGLE_PLACES_API_KEY          OPTIONAL   business + competitor lookup

# --- Optional: live-chat bridge ---
# GOOGLE_CHAT_WEBHOOK_URL        OPTIONAL   Google Chat webhook for incoming messages

# --- Sentry (lighthouse) ---
# NEXT_PUBLIC_SENTRY_DSN         OPTIONAL
# SENTRY_DSN                     OPTIONAL
# SENTRY_AUTH_TOKEN              OPTIONAL
# SENTRY_ORG                     OPTIONAL   defaults to designed-by-anthony
# SENTRY_PROJECT                 OPTIONAL   defaults to javascript-nextjs


# ==============================================================================
# Shared build-time toggles (injected automatically by Vercel — do NOT set)
# ==============================================================================
# NODE_ENV                  — auto (development / test / production)
# VERCEL                    — auto ("1" on Vercel)
# VERCEL_ENV                — auto (development / preview / production)
# VERCEL_URL                — auto (deployment URL)
# VERCEL_GIT_COMMIT_SHA     — auto (commit SHA; used for service-worker cache bust)
# NEXT_RUNTIME              — auto (nodejs / edge)
# CI                        — auto (set by CI runners + Vercel)
# SKIP_ENV_VALIDATION       — escape hatch: "1" bypasses all @dba/env checks (do NOT use in prod)


# ==============================================================================
# Test-only (do NOT set in Vercel production)
# ==============================================================================
# NEXT_PUBLIC_IS_TEST       — "true" forces test mode (mailer, Stripe, Turnstile)
# PLAYWRIGHT_TEST_BASE_URL  — Playwright sets automatically
# PLAYWRIGHT_SKIP_WEBSERVER — "1" reuses an already-running dev server
# PLAYWRIGHT_USE_FIREBASE_EMULATOR — "1" routes smoke tests through firebase emulator
# BASE_URL                  — Playwright test target (defaults to production)
# E2E_PORT                  — lighthouse Playwright port  (default 3002)
# E2E_NO_FIRESTORE_EMULATOR — "1" skips Firestore emulator step
# SKIP_WEBSERVER            — web-viewer Playwright flag
# SPOTLIGHT                 — "1" enables @spotlightjs/astro in astro dev
# PW_AUDIT                  — "1" increases Playwright trace/video retention
