# ==============================================================================
# Designed by Anthony — root Next.js app `.env.example`
# ==============================================================================
#
# Environment variables read by this **single** Next.js app at build time or
# runtime. Cross-check against:
#   • `process.env.*` usage under `src/`
#   • Zod schemas in `src/lib/env/marketing.ts`, `src/lib/env/lighthouse.ts`,
#     `src/lib/env/shared.ts`
#
# Copy to `.env` or `.env.local` for local dev (git-ignored). For production,
# set variables in Firebase App Hosting (Google Cloud console) or with
# `firebase apphosting:secrets` / linked GitHub backend env — not committed here.
#
# Labels:
#   REQUIRED  — production deploy will fail or break core functionality without it
#   OPTIONAL  — feature-flagged or has a working default
# ==============================================================================

# ------------------------------------------------------------------------------
# Deploy: Firebase App Hosting
# ------------------------------------------------------------------------------
# Production is intended to run on **Firebase App Hosting** (Blaze). Wire the
# GitHub repository for automatic rollouts. Set secrets in Google Cloud /
# Firebase console (App Hosting → backend → Environment / Secrets) or via
# `firebase apphosting:secrets`. Variables consumed in the browser as
# `process.env.NEXT_PUBLIC_*` must be available at **build** time for that host.
# Source of truth: **GitHub** — connect that repo in Firebase App Hosting.


# ------------------------------------------------------------------------------
# Lighthouse audit  (lives on the apex at /lighthouse — no subdomain)
# ------------------------------------------------------------------------------
# GOOGLE_PAGESPEED_API_KEY     REQUIRED  enables Core Web Vitals + Lighthouse score lookup
# GEMINI_API_KEY               REQUIRED  enables AI-prioritized audit summary
# GEMINI_MODEL                 OPTIONAL  defaults to `gemini-2.5-pro`


# ==============================================================================
# Marketing + public site — designedbyanthony.com (same Next.js app)
# ==============================================================================

# --- Lead + audit integration ---
# PUBLIC_CRM_LEAD_URL            OPTIONAL   legacy browser POST URL if you still wire a VertaFlow ingest from the client
# LEAD_WEBHOOK_URL               REQUIRED   server `POST /api/contact` forwards JSON here (Convex → Slack). Example:
#                                         https://YOUR_DEPLOY.convex.site/webhook/lead
# NEXT_PUBLIC_LEAD_WEBHOOK_URL   OPTIONAL   browser default for `[data-audit-form]` when the form has no `action` (same URL pattern as LEAD_WEBHOOK_URL if you want parity)
# PUBLIC_API_URL                 OPTIONAL   audit API base when forms call another origin; same deploy can omit (defaults to current origin)
#
# --- reCAPTCHA Enterprise (marketing contact / lead-email; preferred) ---
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY OPTIONAL   browser + assessment `siteKey` (same value as Google console key)
# NEXT_PUBLIC_RECAPTCHA_ACTION   OPTIONAL   `grecaptcha.enterprise.execute` action (default `contact_submit`); must match server below
# RECAPTCHA_ENTERPRISE_API_KEY   OPTIONAL   Google Cloud API key with reCAPTCHA Enterprise API enabled (server-only; never commit)
# GOOGLE_CLOUD_PROJECT           OPTIONAL   same GCP project as the key (often already set for Lighthouse/Gemini)
# RECAPTCHA_GOOGLE_CLOUD_PROJECT OPTIONAL   override if different from GOOGLE_CLOUD_PROJECT
# RECAPTCHA_EXPECTED_ACTION      OPTIONAL   server assessment `expectedAction` (defaults to NEXT_PUBLIC_RECAPTCHA_ACTION or `contact_submit`)
# RECAPTCHA_MIN_SCORE            OPTIONAL   reject when `riskAnalysis.score` is below this (0–1); default 0.5 when score is returned
# RECAPTCHA_SITE_KEY             OPTIONAL   server-only site key (only if you refuse NEXT_PUBLIC_* — normally use NEXT_PUBLIC_RECAPTCHA_SITE_KEY)
#
# --- Cloudflare Turnstile (legacy / Lighthouse strict audit) ---
# PUBLIC_TURNSTILE_SITE_KEY      OPTIONAL   marketing form widget only when Enterprise is not configured
# TURNSTILE_SECRET_KEY           OPTIONAL   pairs with Turnstile or legacy marketing when Enterprise is off
#
# --- Chat: Crisp (sole canonical chat surface; root layout) ---
# NEXT_PUBLIC_CRISP_WEBSITE_ID  OPTIONAL  Crisp website UUID. Unset = baked-in production website id in CrispBootstrap.

# --- Sentry (marketing) ---
# PUBLIC_SENTRY_DSN              OPTIONAL   browser DSN, also drives CSP report-uri via `npm run sync:static-headers` (marketing)
# SENTRY_DSN                     OPTIONAL   server/edge DSN (usually same as PUBLIC_SENTRY_DSN)
# SENTRY_AUTH_TOKEN              OPTIONAL   sourcemap uploads (build skips them if unset)
# SENTRY_ORG                     OPTIONAL   defaults to `designed-by-anthony`
# SENTRY_PROJECT                 OPTIONAL   defaults to `javascript-nextjs`
# SENTRY_CSP_ENVIRONMENT         OPTIONAL   tag for CSP reports
# PUBLIC_SENTRY_ENVIRONMENT      OPTIONAL   tag for CSP reports

# --- IndexNow (build-time URL submission) ---
# INDEXNOW_KEY                   OPTIONAL   overrides default a503ff689a18407993ac047df017d9a8
# INDEXNOW_ENDPOINT              OPTIONAL   primary endpoint
# INDEXNOW_FALLBACK_ENDPOINTS    OPTIONAL   comma-separated fallbacks (empty = disabled)




# ==============================================================================
# Lighthouse audit APIs (PageSpeed, Gemini, etc.; `lighthouse.*` + `/lighthouse`)
# ==============================================================================

# --- Core audit APIs (REQUIRED for audits to run) ---
# GOOGLE_PAGESPEED_API_KEY       REQUIRED   PageSpeed Insights API key
# GEMINI_API_KEY                 REQUIRED   (or) GOOGLE_API_KEY — Gemini API key
# GEMINI_MODEL                   OPTIONAL   defaults to gemini-2.5-pro
# GOOGLE_API_KEY                 OPTIONAL   alternate to GEMINI_API_KEY
# GOOGLE_CLOUD_PROJECT           OPTIONAL   defaults to lighthouse-492701 (Vertex fallback)
# GOOGLE_CLOUD_LOCATION          OPTIONAL   defaults to us-east4

# --- Turnstile (site-wide; server secret + public site key must pair) ---
# TURNSTILE_SECRET_KEY           OPTIONAL
# NEXT_PUBLIC_TURNSTILE_SITE_KEY OPTIONAL
# LIGHTHOUSE_STRICT_TURNSTILE    OPTIONAL   set to 1 to require Turnstile on POST /api/audit (needs TURNSTILE_SECRET_KEY + client token). Default: audits run without Turnstile for stable /lighthouse UX.
#                                In Cloudflare → Turnstile → your widget → Hostnames: add apex, www, localhost, Firebase App Hosting previews (*.hosted.app), and any other deploy hostnames or challenges return 400.

# --- reCAPTCHA Enterprise (`POST /api/audit`) ---
# NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY OPTIONAL defaults to the DBA public site key
# NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_ACTION   OPTIONAL defaults to submit
# RECAPTCHA_ENTERPRISE_API_KEY              OPTIONAL server-only Google API key. When set, `/api/audit` verifies tokens with Google.
# RECAPTCHA_ENTERPRISE_PROJECT_ID           OPTIONAL defaults to dba-website-prod
# RECAPTCHA_ENTERPRISE_SITE_KEY             OPTIONAL server-side override; defaults to NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY
# RECAPTCHA_ENTERPRISE_EXPECTED_ACTION      OPTIONAL defaults to NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_ACTION
# RECAPTCHA_ENTERPRISE_MIN_SCORE            OPTIONAL defaults to 0.5

# --- CORS allowlist (comma-separated) ---
# ALLOWED_ORIGINS                OPTIONAL   defaults permit marketing + admin

# --- Audit webhooks (optional) ---
# AUDIT_LEAD_WEBHOOK_URL         OPTIONAL   minimal audit lead JSON after success; MUST pair with AUDIT_LEAD_WEBHOOK_SECRET (Convex / Slack, etc.). Unset = no dispatch.
# AUDIT_LEAD_WEBHOOK_SECRET      OPTIONAL   shared secret header `x-lead-secret` for AUDIT_LEAD_WEBHOOK_URL
# AUDIT_LOGGING_WEBHOOK_URL      OPTIONAL   POST JSON after each successful audit (Convex / Sheets / Slack pipeline). Example: https://YOUR_DEPLOY.convex.site/webhook/audit — see `src/lighthouse/lib/auditLoggingWebhook.ts` for payload shape. Fire-and-forget; failures are logged only.
# REPORT_PUBLIC_BASE_URL         OPTIONAL   where /report/:id is served  (defaults https://designedbyanthony.com)

# --- Optional: Google Workspace (Sheets archive + Drive delivery) ---
# GMAIL_SERVICE_ACCOUNT_KEY      OPTIONAL   full service-account JSON as a single line
# SHEETS_ID                      OPTIONAL   lead archive spreadsheet ID
# DRIVE_PROJECTS_FOLDER_ID       OPTIONAL   Drive folder for delivered reports

# --- Optional: Resend (transactional email; audit receipt + /api/lead-email + /api/audit/email-summary) ---
# RESEND_API_KEY                 OPTIONAL   when set, audit completion receipt prefers Resend over Gmail
# RESEND_FROM_EMAIL              OPTIONAL   verified sender in Resend (default outreach@designedbyanthony.com)
# LEAD_EMAIL_TO                  OPTIONAL   internal inbox for marketing lead-email bridge (default anthony@)

# --- Optional: enrichment APIs (audit degrades gracefully) ---
# MOZ_API_CREDENTIALS            OPTIONAL   base64 accessId:secretKey OR x-moz-token
# MOZ_API_TOKEN                  OPTIONAL   alias of MOZ_API_CREDENTIALS
# MOZ_LOCAL_API_KEY              OPTIONAL   legacy fallback (Cloud Functions)
# GOOGLE_PLACES_API_KEY          OPTIONAL   business + competitor lookup

# --- Optional: live-chat bridge ---
# GOOGLE_CHAT_WEBHOOK_URL        OPTIONAL   Google Chat webhook for incoming messages

# --- Sentry (lighthouse) ---
# NEXT_PUBLIC_SENTRY_DSN         OPTIONAL
# SENTRY_DSN                     OPTIONAL
# SENTRY_AUTH_TOKEN              OPTIONAL
# SENTRY_ORG                     OPTIONAL   defaults to designed-by-anthony
# SENTRY_PROJECT                 OPTIONAL   defaults to javascript-nextjs


# ==============================================================================
# Shared build-time / host toggles (usually do NOT set manually)
# ==============================================================================
# NODE_ENV                  — auto (development / test / production)
# CI                        — auto (set by CI runners and some cloud builds)
# SKIP_ENV_VALIDATION       — escape hatch: "1" bypasses env schema checks (do NOT use in prod)
#
# Firebase App Hosting / Cloud Run may expose additional runtime env vars; this
# app does not depend on Vercel-specific names. If you still run previews on
# other hosts, optional legacy vars may appear:
# VERCEL / VERCEL_ENV / VERCEL_URL / VERCEL_GIT_COMMIT_SHA — only when that host sets them
# NEXT_RUNTIME              — auto on some platforms (nodejs / edge)


# ==============================================================================
# Test-only (do NOT set in production / App Hosting)
# ==============================================================================
# NEXT_PUBLIC_IS_TEST       — "true" forces test mode (mailer, Stripe, Turnstile)
# PLAYWRIGHT_TEST_BASE_URL  — Playwright sets automatically
# PLAYWRIGHT_SKIP_WEBSERVER — "1" reuses an already-running dev server
# PLAYWRIGHT_USE_STATIC_PARITY_SERVER — "1" serves built output with static-headers.json for parity tests
# BASE_URL                  — Playwright test target (defaults to production)
# E2E_PORT                  — lighthouse Playwright port  (default 3002)
# SKIP_WEBSERVER            — Playwright: reuse an already-running server
# SPOTLIGHT                 — "1" enables Spotlight in local development
# PW_AUDIT                  — "1" increases Playwright trace/video retention

# Stagehand (Browser Automation)
GEMINI_API_KEY=
BROWSERBASE_API_KEY=
