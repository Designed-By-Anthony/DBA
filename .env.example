# ==============================================================================
# ANTHONY. — Turborepo Cloudflare `.env.example`
# ==============================================================================
#
# Environment variables read by the Next.js frontend (`apps/web`) and Elysia
# API Worker (`apps/api`) at build time or runtime. Cross-check against:
#   • `process.env.*` usage under `apps/web/src`, `apps/api/src`, and
#     `packages/shared/src`
#   • Zod schemas in `apps/web/src/lib/env/*`
#
# Copy to `.env` or `.env.local` for local dev (git-ignored). For production,
# set variables via the Cloudflare dashboard (Workers & Pages → Settings →
# Variables & Secrets) or `wrangler secret put <KEY>` — not committed here.
#
# Labels:
#   REQUIRED  — production deploy will fail or break core functionality without it
#   OPTIONAL  — feature-flagged or has a working default
# ==============================================================================

# ------------------------------------------------------------------------------
# Deploy: Turborepo + Bun monorepo (apps/web → Cloudflare Pages, apps/api → Worker)
# ------------------------------------------------------------------------------
# Structure:
#   apps/web  — Next.js 16 frontend on Cloudflare Pages (advanced mode bundle)
#   apps/api  — ElysiaJS Cloudflare Worker            (api.designedbyanthony.com)
#
# Dev:     bun run dev:web          (Next.js on :3000)
#          bun run dev:api          (Wrangler on :8787)
# Build:   bun run build            (turbo: both apps)
# Deploy:  bun run deploy:web       (wrangler pages deploy from apps/web)
#          bun run deploy:api       (wrangler deploy from apps/api)
#
# Secrets/vars: Cloudflare dashboard → Workers & Pages → <project|worker> → Settings → Variables & Secrets.
# Variables prefixed NEXT_PUBLIC_* must be available at **build** time.

# --- API base URL (optional production override for frontend → API Worker calls) ---
# NEXT_PUBLIC_API_BASE_URL   OPTIONAL         Base URL of the Elysia API Worker.
#                                              Examples: https://api.designedbyanthony.com
#                                                        https://dba-api.<account>.workers.dev
#                                              Production defaults to https://api.designedbyanthony.com
#                                              In dev, Next.js rewrites /api/* to http://localhost:8787


# ==============================================================================
# Marketing + public site — designedbyanthony.com (same Next.js app)
# ==============================================================================

# --- Lead / CRM integration ---
# LEAD_WEBHOOK_URL               REQUIRED   Convex HTTP action or Slack webhook for all leads.
#                                            Example: https://YOUR_DEPLOY.convex.site/webhook/lead
# LEAD_WEBHOOK_SECRET            OPTIONAL   Shared secret sent as `x-lead-secret` header.
# NEXT_PUBLIC_LEAD_WEBHOOK_URL   OPTIONAL   Browser default for `[data-audit-form]` when the
#                                            form has no `action` (same URL as LEAD_WEBHOOK_URL).
# PUBLIC_API_URL                 OPTIONAL   Audit API base for forms calling another origin.

# --- reCAPTCHA Enterprise (ALL forms — lighthouse + contact) ---
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY                   OPTIONAL   Browser siteKey (marketing contact forms)
# NEXT_PUBLIC_RECAPTCHA_ACTION                     OPTIONAL   grecaptcha.enterprise.execute action (default: contact_submit)
# RECAPTCHA_ENTERPRISE_API_KEY                     OPTIONAL   Google Cloud API key (server-only)
# GOOGLE_CLOUD_PROJECT                             OPTIONAL   GCP project (often shared with Lighthouse/Gemini)
# RECAPTCHA_GOOGLE_CLOUD_PROJECT                   OPTIONAL   Override if different from GOOGLE_CLOUD_PROJECT
# RECAPTCHA_EXPECTED_ACTION                        OPTIONAL   Server expectedAction (defaults to NEXT_PUBLIC_RECAPTCHA_ACTION)
# RECAPTCHA_MIN_SCORE                              OPTIONAL   Reject below this score (0–1); default 0.5
#
# NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY        OPTIONAL   Lighthouse audit form siteKey
# NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_ACTION          OPTIONAL   Lighthouse audit action (default: submit)
# RECAPTCHA_ENTERPRISE_PROJECT_ID                  OPTIONAL   GCP project for Enterprise (default: dba-website-prod)
# RECAPTCHA_ENTERPRISE_API_KEY                     OPTIONAL   Server-only Google API key (same key works for both)
# RECAPTCHA_ENTERPRISE_EXPECTED_ACTION             OPTIONAL   Server expectedAction for audit
# RECAPTCHA_ENTERPRISE_MIN_SCORE                   OPTIONAL   Min score for audit (default 0.5)

# --- Chat: Crisp (sole canonical chat surface; root layout) ---
# NEXT_PUBLIC_CRISP_WEBSITE_ID  OPTIONAL  Crisp website UUID. Unset = baked-in production id in CrispBootstrap.

# --- IndexNow (build-time URL submission) ---
# INDEXNOW_KEY                   OPTIONAL   overrides default a503ff689a18407993ac047df017d9a8
# INDEXNOW_ENDPOINT              OPTIONAL   primary endpoint
# INDEXNOW_FALLBACK_ENDPOINTS    OPTIONAL   comma-separated fallbacks (empty = disabled)


# ==============================================================================
# Lighthouse audit APIs (PageSpeed, Gemini, etc.; `/lighthouse`)
# ==============================================================================

# --- Core audit APIs (REQUIRED for audits to run) ---
# GOOGLE_PAGESPEED_API_KEY       REQUIRED   PageSpeed Insights API key
# GEMINI_API_KEY                 REQUIRED   (or) GOOGLE_API_KEY — Gemini API key
# GEMINI_MODEL                   OPTIONAL   defaults to gemini-2.5-pro
# GOOGLE_API_KEY                 OPTIONAL   alternate to GEMINI_API_KEY
# GOOGLE_CLOUD_PROJECT           OPTIONAL   defaults to lighthouse-492701 (Vertex fallback)
# GOOGLE_CLOUD_LOCATION          OPTIONAL   defaults to us-east4

# --- CORS allowlist (comma-separated) ---
# ALLOWED_ORIGINS                OPTIONAL   defaults permit marketing + admin

# --- Audit webhooks ---
# AUDIT_LOGGING_WEBHOOK_URL      OPTIONAL   POST JSON after each successful audit (fire-and-forget).
#                                            Example: https://YOUR_DEPLOY.convex.site/webhook/audit
# REPORT_PUBLIC_BASE_URL         OPTIONAL   Where /report/:id is served (defaults https://designedbyanthony.com)

# --- Optional: Google Workspace (Gmail for audit receipt emails) ---
# GMAIL_SERVICE_ACCOUNT_KEY      OPTIONAL   Full service-account JSON as a single line

# --- Optional: Resend (transactional email; audit receipt + /api/lead-email) ---
# RESEND_API_KEY                 OPTIONAL   When set, audit completion receipt prefers Resend over Gmail
# RESEND_FROM_EMAIL              OPTIONAL   Verified sender in Resend (default outreach@designedbyanthony.com)
# LEAD_EMAIL_TO                  OPTIONAL   Internal inbox for lead-email bridge (default anthony@)

# --- Optional: enrichment APIs (audit degrades gracefully) ---
# MOZ_API_CREDENTIALS            OPTIONAL   base64 accessId:secretKey OR x-moz-token
# MOZ_API_TOKEN                  OPTIONAL   alias of MOZ_API_CREDENTIALS
# GOOGLE_PLACES_API_KEY          OPTIONAL   Business + competitor lookup
# GOOGLE_CHAT_WEBHOOK_URL        OPTIONAL   Google Chat webhook for incoming messages


# ==============================================================================
# Shared build-time / host toggles (usually do NOT set manually)
# ==============================================================================
# NODE_ENV                  — auto (development / test / production)
# CI                        — auto (set by CI runners and some cloud builds)
# SKIP_ENV_VALIDATION       — escape hatch: "1" bypasses env schema checks (do NOT use in prod)


# ==============================================================================
# Test-only (do NOT set in production / Cloudflare Workers)
# ==============================================================================
# NEXT_PUBLIC_IS_TEST       — "true" forces test mode (mailer, etc.)
# PLAYWRIGHT_TEST_BASE_URL  — Playwright sets automatically
# PLAYWRIGHT_SKIP_WEBSERVER — "1" reuses an already-running dev server
# PLAYWRIGHT_USE_STATIC_PARITY_SERVER — "1" serves built output with static-headers.json for parity tests
# BASE_URL                  — Playwright test target (defaults to production)
# E2E_PORT                  — lighthouse Playwright port (default 3002)
# SKIP_WEBSERVER            — Playwright: reuse an already-running server
# PW_AUDIT                  — "1" increases Playwright trace/video retention
# EMAIL_TEST_MODE           — "true" captures sent emails in-memory instead of dispatching

# Stagehand (Browser Automation)
GEMINI_API_KEY=
BROWSERBASE_API_KEY=
