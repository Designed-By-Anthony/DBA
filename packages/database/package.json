{
  "name": "@dba/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema.ts"
  },
  "scripts": {
    "db:push": "drizzle-kit push --config drizzle.config.cjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.cjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.cjs",
    "db:seed:master": "node ./scripts/seed-master-tenant.mjs",
    "db:apply-rls": "node ./scripts/apply-rls.mjs",
    "db:verify-rls": "node ./scripts/verify-rls.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.9.3"
  }
}
