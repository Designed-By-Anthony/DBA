# App URL (emails, admin links)
NEXT_PUBLIC_APP_URL=https://admin.designedbyanthony.com

# Vercel Web Analytics + Speed Insights on custom domains (e.g. admin.*). Set on Vercel after enabling Web Analytics.
# NEXT_PUBLIC_VERCEL_WEB_ANALYTICS=1

# Optional: Calendly inline embed on /admin/calendar (append ?embed=true if omitted at runtime)
# NEXT_PUBLIC_CALENDLY_EMBED_URL=https://calendly.com/your-org/your-event

# Neon Postgres (see root AGENTS.md > Infrastructure Context).
# Copy the connection string from Neon (Dashboard → Connection details).
# Pooled URL for the app; direct (non-pooler) URL for drizzle-kit when required.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_SSL=true

# Google Workspace (Docs/Drive) — OAuth preferred; inline service account optional fallback
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Clerk (see Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Vercel may prefill: NEXT_PUBLIC_admin_CLERK_PUBLISHABLE_KEY, admin_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY,
# or admin_CLERK_SECRET_KEY — @dba/env copies those onto the canonical names above.
# NEXT_PUBLIC_admin_CLERK_PUBLISHABLE_KEY=
# admin_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# admin_CLERK_SECRET_KEY=
# Optional: Clerk custom domain / satellite — if `NEXT_PUBLIC_CLERK_DOMAIN` is set but
# there is no DNS record for `clerk.<your-domain>`, the browser cannot load clerk-js
# (ERR_NAME_NOT_RESOLVED). Fix: either add the CNAME in Clerk’s DNS instructions, or
# point script loads at your Frontend API host:
#   NEXT_PUBLIC_CLERK_PROXY_URL=https://YOUR_INSTANCE.clerk.accounts.dev
# Or set the same URL once as server-only (no NEXT_PUBLIC_ duplicate):
#   CLERK_FAPI_UPSTREAM=https://YOUR_INSTANCE.clerk.accounts.dev
# (enables same-origin /clerk-fapi → Clerk FAPI rewrite + Clerk proxyUrl)
# NEXT_PUBLIC_CLERK_DOMAIN=designedbyanthony.com
# NEXT_PUBLIC_CLERK_PROXY_URL=
# Webhook signing secret for POST /api/webhooks/clerk (Clerk Dashboard → Webhooks)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Lead intake — must match your Clerk Organization ID (Agency OS CRM tenant)
# Calendly webhooks also use this for new bookings when the email is not yet in CRM.
LEAD_WEBHOOK_DEFAULT_AGENCY_ID=org_3CWuIWj5aFCaZXr8dUEpwtGSiCW

# Optional: single-tenant only — if unset, use the first row in Postgres `tenants`.
# Do NOT enable for multi-tenant SaaS.
# LEAD_WEBHOOK_SQL_SINGLE_TENANT_FALLBACK=true

# Secret for server-to-server POST /api/webhooks/lead (marketing backend, Lighthouse server-side, Zapier)
LEAD_WEBHOOK_SECRET=

# Webhook signing key returned by Calendly when you create the webhook_subscription.
# If unset, POST /api/webhooks/calendly returns 503 (fails closed). Never falls back
# to accepting unsigned requests.
# CALENDLY_WEBHOOK_SIGNING_KEY=
#
# Multi-tenant Calendly: use a different webhook URL per agency, e.g.
#   https://your-domain.com/api/webhooks/calendly?tenant=org_xxx
# where org_xxx is that salon/plumber’s Clerk org id (must exist in Postgres `tenants`).
# Single-tenant: omit ?tenant= and rely on LEAD_WEBHOOK_DEFAULT_AGENCY_ID above.

# Shared secret for POST /api/webhooks/agentic. If unset the route returns 503.
# Send as `Authorization: Bearer <secret>` or `x-webhook-secret: <secret>`.
# AGENTIC_WEBHOOK_SECRET=

# Shared secret for POST /api/webhooks/idx. If unset the route returns 503.
# Send as `Authorization: Bearer <secret>` or `x-webhook-secret: <secret>`.
# IDX_WEBHOOK_SECRET=

# Optional: comma-separated origins for browser POSTs to /api/webhooks/lead and /api/lead
# LEAD_WEBHOOK_CORS_ORIGINS=https://designedbyanthony.com,https://www.designedbyanthony.com

# Resend (transactional email)
RESEND_API_KEY=
# Inbound webhooks (Resend Dashboard → Webhooks → signing secret for Svix verification)
RESEND_WEBHOOK_SECRET=
# Optional: after a verified `email.received`, call GET /emails/receiving/{id} (adds latency; needs RESEND_API_KEY)
# RESEND_INBOUND_FETCH_BODY=true
# Domain onboarding test mode returns deterministic DNS records without calling Resend.
# RESEND_DOMAIN_TEST_MODE=true
# Internal admin alerts for tenant/domain activity.
DISCORD_WEBHOOK_URL=
# Discord test mode records notifications in-memory for Playwright/API checks.
# DISCORD_TEST_MODE=true

# High-entropy secret used to HMAC-sign click-tracking and unsubscribe links
# that appear in outbound emails. If unset, the email-utils helpers throw at
# call time — previously they fell back to a literal 'agency-os-secret',
# which made every link forgeable by anyone reading the source.
# Rotate when you rotate other session secrets (NEXTAUTH_SECRET etc).
# EMAIL_LINK_SIGNING_SECRET=

# Optional: auto-reply to form submitter from execute-lead-intake
# LEAD_SEND_SUBMITTER_CONFIRMATION=true

# Optional: disable public browser endpoint POST /api/lead (keep webhook secret flow only)
# PUBLIC_LEAD_INGEST_DISABLED=true

# Sentry — set DSN in Vercel env only; never commit real DSN strings.
# Browser: NEXT_PUBLIC_SENTRY_DSN=   Server/edge: SENTRY_DSN= (optional; falls back to NEXT_PUBLIC_*)
# Session Replay captures page DOM (may include PHI) — off unless NEXT_PUBLIC_SENTRY_REPLAY=1
# NEXT_PUBLIC_SENTRY_REPLAY=1
# SENTRY_ENABLE_DEV=true

# E2E test mode — SERVER-ONLY (do NOT prefix with NEXT_PUBLIC_).
# Setting this to "true" in the Vercel production environment is a no-op; the helper
# in src/lib/test-mode.ts refuses to evaluate true when VERCEL_ENV=production.
# Used by:
#   - POST /api/portal/magic-link    : echo the one-time link back in the response body
#   - POST /api/webhooks/stripe       : skip Stripe signature verification
#   - admin server actions            : return mocked Stripe/Google-Workspace results
# IS_TEST=true

# Cloudflare Turnstile — required for POST /api/lead in production.
# If unset in prod, the route returns 503 to prevent silent downgrade
# to honeypot-only (attackers that skip _hp slip through).
# Preview/dev can opt out explicitly with PUBLIC_LEAD_INGEST_ALLOW_NO_TURNSTILE=true.
# TURNSTILE_SECRET_KEY=
# PUBLIC_LEAD_INGEST_ALLOW_NO_TURNSTILE=true
