# App URL (emails, admin links)
NEXT_PUBLIC_APP_URL=https://viewer.designedbyanthony.com

# Google Cloud SQL (PostgreSQL) — copy to .env.local; never commit secrets
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# DATABASE_SSL=true
# Local dev: prefer Cloud SQL Auth Proxy (localhost) and point DATABASE_URL at 127.0.0.1
# Production on GCP: often Unix socket or private IP; SSL may be required (?sslmode=require)

# Clerk (see Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret for POST /api/webhooks/clerk (Clerk Dashboard → Webhooks)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Lead intake — must match your Clerk Organization ID (Agency OS CRM tenant)
LEAD_WEBHOOK_DEFAULT_AGENCY_ID=org_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret for server-to-server POST /api/webhooks/lead (marketing backend, Lighthouse server-side, Zapier)
LEAD_WEBHOOK_SECRET=

# Optional: comma-separated origins for browser POSTs to /api/webhooks/lead and /api/lead
# LEAD_WEBHOOK_CORS_ORIGINS=https://designedbyanthony.com,https://www.designedbyanthony.com

# Resend (transactional email)
RESEND_API_KEY=

# Optional: auto-reply to form submitter from execute-lead-intake
# LEAD_SEND_SUBMITTER_CONFIRMATION=true

# Optional: disable public browser endpoint POST /api/lead (keep webhook secret flow only)
# PUBLIC_LEAD_INGEST_DISABLED=true
