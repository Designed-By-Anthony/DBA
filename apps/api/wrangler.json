{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "dba-api",
	"main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
	"routes": [
		{
			"pattern": "api.designedbyanthony.com",
			"custom_domain": true
		}
	],
  "kv_namespaces": [
    {
      "binding": "AUDIT_REPORTS_KV",
      "id": "48827a794a8b4ccc8b0dc3dbca8c80ec"
    }
  ],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "dba-ledger",
			"database_id": "961ce211-2843-4ed7-a609-9ab224f7eb8a"
		}
	]
}
