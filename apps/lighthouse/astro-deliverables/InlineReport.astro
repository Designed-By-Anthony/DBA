---
// src/components/InlineReport.astro
//
// Receipt-style Lighthouse report component.
// Used in two places:
//   1. The form page — after a successful submit, rendered inline from the API response
//   2. src/pages/report/[id].astro — SSR-fetched from /api/report/[id]
//
// Props match the shape returned by the Next.js API (both the audit POST
// response's `results` object and the report GET endpoint).

interface PrioritizedAction {
	priority: number;
	action: string;
	impact: "high" | "medium" | "low";
	effort: "high" | "medium" | "low";
}

interface AiInsight {
	executiveSummary?: string;
	conversionScore?: number;
	strengths?: string[];
	weaknesses?: string[];
	prioritizedActions?: PrioritizedAction[];
	copywritingAnalysis?: string;
}

interface Props {
	reportId: string;
	lead: {
		name?: string;
		company?: string;
		url: string;
	};
	scores: {
		trustScore?: number;
		performance: number;
		accessibility: number;
		bestPractices: number;
		seo: number;
		conversion?: number;
	};
	metrics: {
		fcp: string;
		lcp: string;
		tbt: string;
		cls: string;
	};
	diagnostics?: {
		failedAuditCount: number;
		criticalIssue: string;
	};
	aiInsight: AiInsight | string;
	htmlSignals?: {
		schemaTypes?: string[];
		missingRecommendedSchema?: string[];
		readabilityScore?: number | null;
		readingLevel?: string | null;
		ttfbMs?: number | null;
		mixedContentCount?: number;
		imgsWithLazyLoad?: number;
		imgsWithDimensions?: number;
		imgCount?: number;
		wordCount?: number;
	};
	backlinks?: {
		found?: boolean;
		domainAuthority?: number | null;
		spamScore?: number | null;
		linkingRootDomains?: number | null;
		externalBacklinks?: number | null;
	};
	sitewide?: {
		sitemap?: { exists?: boolean; urlCount?: number };
		robotsTxt?: { exists?: boolean; allowsCrawlers?: boolean };
		redirectChain?: { httpRedirectsToHttps?: boolean };
	};
	indexCoverage?: {
		estimatedIndexedPages?: number | null;
	};
	createdAt?: string | null;
	showEmailButton?: boolean;
}

const {
	reportId,
	lead,
	scores,
	metrics,
	diagnostics,
	aiInsight,
	htmlSignals,
	backlinks,
	sitewide,
	indexCoverage,
	createdAt,
	showEmailButton = true,
} = Astro.props;

const ai: AiInsight =
	typeof aiInsight === "string"
		? { executiveSummary: aiInsight }
		: aiInsight || {};

function impactColor(impact: string): string {
	if (impact === "high") return "#ef4444";
	if (impact === "medium") return "#f59e0b";
	return "#22c55e";
}

function effortLabel(effort: string): string {
	if (effort === "low") return "Quick win";
	if (effort === "medium") return "Moderate";
	return "Major project";
}

// Public env var — set PUBLIC_API_BASE in your Astro .env
// e.g. PUBLIC_API_BASE=https://lighthouse-audit--lighthouse-492701.us-east4.hosted.app
const API_BASE = import.meta.env.PUBLIC_API_BASE || "";

const calendarUrl =
	"https://calendar.app.google/c1CaLZJQkbTAs9abA?utm_source=report_page&utm_medium=web&utm_campaign=audit_report";

// Score coloring thresholds match Lighthouse's own conventions
function scoreColor(score: number): string {
	if (score >= 90) return "#0cce6b"; // green
	if (score >= 50) return "#ffa400"; // amber
	return "#ff4e42"; // red
}

function formatDate(iso: string | null | undefined): string {
	if (!iso)
		return new Date().toLocaleString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
			hour: "numeric",
			minute: "2-digit",
		});
	return new Date(iso).toLocaleString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
		hour: "numeric",
		minute: "2-digit",
	});
}

const displayUrl = lead.url.replace(/^https?:\/\//, "").replace(/\/$/, "");
const companyDisplay = lead.company || displayUrl;
---

<article class="report">
  <!-- Receipt header -->
  <header class="report__header">
    <div class="report__brand">
      <div class="report__brand-name">Designed by Anthony</div>
      <div class="report__brand-sub">Lighthouse Site Report</div>
    </div>
    <div class="report__meta">
      <div class="report__id">{reportId}</div>
      <div class="report__date">{formatDate(createdAt)}</div>
    </div>
  </header>

  <div class="report__divider"></div>

  <!-- Subject line: what was audited -->
  <section class="report__subject">
    <h1 class="report__title">{companyDisplay}</h1>
    <a href={lead.url} target="_blank" rel="noopener" class="report__url">{displayUrl}</a>
  </section>

  <!-- Score cards -->
  <section class="report__scores" aria-label="Lighthouse scores">
    <div class="score-card">
      <div class="score-card__ring" style={`--score-color: ${scoreColor(scores.performance)}`}>
        <span class="score-card__value">{scores.performance}</span>
      </div>
      <div class="score-card__label">Performance</div>
    </div>
    <div class="score-card">
      <div class="score-card__ring" style={`--score-color: ${scoreColor(scores.accessibility)}`}>
        <span class="score-card__value">{scores.accessibility}</span>
      </div>
      <div class="score-card__label">Accessibility</div>
    </div>
    <div class="score-card">
      <div class="score-card__ring" style={`--score-color: ${scoreColor(scores.bestPractices)}`}>
        <span class="score-card__value">{scores.bestPractices}</span>
      </div>
      <div class="score-card__label">Best Practices</div>
    </div>
    <div class="score-card">
      <div class="score-card__ring" style={`--score-color: ${scoreColor(scores.seo)}`}>
        <span class="score-card__value">{scores.seo}</span>
      </div>
      <div class="score-card__label">SEO</div>
    </div>
  </section>

  <!-- Executive Summary -->
  {ai.executiveSummary && (
    <section class="report__section">
      <h2 class="report__h2">Executive Summary</h2>
      <div class="report__insight" set:html={ai.executiveSummary}></div>
    </section>
  )}

  <!-- Strengths & Weaknesses -->
  {(ai.strengths?.length || ai.weaknesses?.length) && (
    <section class="report__section">
      <h2 class="report__h2">Key Findings</h2>
      <div class="findings">
        {ai.strengths && ai.strengths.length > 0 && (
          <div class="findings__col">
            <h3 class="findings__heading findings__heading--good">What's working</h3>
            <ul class="findings__list">
              {ai.strengths.map((s) => (
                <li class="findings__item findings__item--good">{s}</li>
              ))}
            </ul>
          </div>
        )}
        {ai.weaknesses && ai.weaknesses.length > 0 && (
          <div class="findings__col">
            <h3 class="findings__heading findings__heading--bad">What needs attention</h3>
            <ul class="findings__list">
              {ai.weaknesses.map((w) => (
                <li class="findings__item findings__item--bad">{w}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Prioritized Actions -->
  {ai.prioritizedActions && ai.prioritizedActions.length > 0 && (
    <section class="report__section">
      <h2 class="report__h2">Recommended Actions</h2>
      <ol class="actions-list">
        {ai.prioritizedActions.map((a) => (
          <li class="action-card">
            <div class="action-card__number">{a.priority}</div>
            <div class="action-card__body">
              <p class="action-card__text">{a.action}</p>
              <div class="action-card__tags">
                <span class="action-tag" style={`--tag-color: ${impactColor(a.impact)}`}>
                  {a.impact} impact
                </span>
                <span class="action-tag action-tag--effort">
                  {effortLabel(a.effort)}
                </span>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- Core Web Vitals -->
  <section class="report__section">
    <h2 class="report__h2">Core Web Vitals</h2>
    <dl class="metrics">
      <div class="metric"><dt>Largest Contentful Paint</dt><dd>{metrics.lcp}</dd></div>
      <div class="metric"><dt>First Contentful Paint</dt><dd>{metrics.fcp}</dd></div>
      <div class="metric"><dt>Total Blocking Time</dt><dd>{metrics.tbt}</dd></div>
      <div class="metric"><dt>Cumulative Layout Shift</dt><dd>{metrics.cls}</dd></div>
      {htmlSignals?.ttfbMs != null && (
        <div class="metric"><dt>Server Response (TTFB)</dt><dd>{htmlSignals.ttfbMs}ms</dd></div>
      )}
    </dl>
  </section>

  <!-- Backlink & Authority Profile -->
  {backlinks?.found && (
    <section class="report__section">
      <h2 class="report__h2">Authority &amp; Backlinks</h2>
      <dl class="metrics">
        {backlinks.domainAuthority != null && (
          <div class="metric"><dt>Domain Authority</dt><dd>{backlinks.domainAuthority}<span class="metric__unit">/100</span></dd></div>
        )}
        {backlinks.spamScore != null && (
          <div class={`metric ${backlinks.spamScore > 30 ? 'metric--warn' : ''}`}><dt>Spam Score</dt><dd>{backlinks.spamScore}<span class="metric__unit">/100</span></dd></div>
        )}
        {backlinks.linkingRootDomains != null && (
          <div class="metric"><dt>Linking Domains</dt><dd>{backlinks.linkingRootDomains}</dd></div>
        )}
        {backlinks.externalBacklinks != null && (
          <div class="metric"><dt>Total Backlinks</dt><dd>{backlinks.externalBacklinks}</dd></div>
        )}
      </dl>
    </section>
  )}

  <!-- Site Health Checklist (only show if we have sitewide or htmlSignals data) -->
  {(sitewide?.robotsTxt || sitewide?.sitemap || sitewide?.redirectChain || htmlSignals?.schemaTypes?.length || htmlSignals?.readabilityScore != null || indexCoverage?.estimatedIndexedPages != null) && (
  <section class="report__section">
    <h2 class="report__h2">Site Health</h2>
    <ul class="checklist">
      {sitewide?.robotsTxt && (
        <li class={`checklist__item ${sitewide.robotsTxt.exists && sitewide.robotsTxt.allowsCrawlers ? 'checklist__item--pass' : 'checklist__item--fail'}`}>
          robots.txt {sitewide.robotsTxt.exists ? (sitewide.robotsTxt.allowsCrawlers ? 'present & allows crawlers' : 'present but blocking crawlers') : 'missing'}
        </li>
      )}
      {sitewide?.sitemap && (
        <li class={`checklist__item ${sitewide.sitemap.exists ? 'checklist__item--pass' : 'checklist__item--fail'}`}>
          Sitemap {sitewide.sitemap.exists ? `found (${sitewide.sitemap.urlCount} pages)` : 'missing'}
        </li>
      )}
      {sitewide?.redirectChain && (
        <li class={`checklist__item ${sitewide.redirectChain.httpRedirectsToHttps ? 'checklist__item--pass' : 'checklist__item--fail'}`}>
          HTTP → HTTPS redirect {sitewide.redirectChain.httpRedirectsToHttps ? 'working' : 'not detected'}
        </li>
      )}
      {htmlSignals?.mixedContentCount != null && (
        <li class={`checklist__item ${htmlSignals.mixedContentCount === 0 ? 'checklist__item--pass' : 'checklist__item--fail'}`}>
          Mixed content: {htmlSignals.mixedContentCount === 0 ? 'clean' : `${htmlSignals.mixedContentCount} insecure resources`}
        </li>
      )}
      {htmlSignals?.schemaTypes && htmlSignals.schemaTypes.length > 0 && (
        <li class="checklist__item checklist__item--pass">
          Schema markup: {htmlSignals.schemaTypes.join(', ')}
        </li>
      )}
      {htmlSignals?.missingRecommendedSchema && htmlSignals.missingRecommendedSchema.length > 0 && (
        <li class="checklist__item checklist__item--fail">
          Missing recommended: {htmlSignals.missingRecommendedSchema.join(', ')}
        </li>
      )}
      {htmlSignals?.readabilityScore != null && (
        <li class={`checklist__item ${htmlSignals.readabilityScore >= 60 ? 'checklist__item--pass' : 'checklist__item--warn'}`}>
          Readability: {htmlSignals.readabilityScore}/100 ({htmlSignals.readingLevel})
        </li>
      )}
      {indexCoverage?.estimatedIndexedPages != null && (
        <li class="checklist__item checklist__item--info">
          ~{indexCoverage.estimatedIndexedPages} pages estimated in search index
        </li>
      )}
    </ul>
  </section>
  )}

  <!-- Copywriting Analysis -->
  {ai.copywritingAnalysis && (
    <section class="report__section">
      <h2 class="report__h2">Copywriting Analysis</h2>
      <div class="report__insight" set:html={ai.copywritingAnalysis}></div>
    </section>
  )}

  <!-- Failed audits callout -->
  {diagnostics && diagnostics.failedAuditCount > 0 && (
    <section class="callout">
      <div class="callout__title">{diagnostics.failedAuditCount} technical issues flagged</div>
      <p class="callout__body">
        The scan flagged <strong>{diagnostics.failedAuditCount}</strong> distinct errors dragging your scores down
        {diagnostics.criticalIssue && (
          <span> — including failing the test for <em>{diagnostics.criticalIssue}</em></span>
        )}.
        The full breakdown and my recommendations are easier to walk through on a quick call than in writing.
      </p>
    </section>
  )}

  <!-- Primary CTA -->
  <section class="cta-primary no-print">
    <h2 class="cta-primary__title">Want me to walk you through it?</h2>
    <p class="cta-primary__body">
      I keep a few 15-minute slots open each week to go through these reports one-on-one with business owners. No sales pitch — just me, your numbers, and what to fix first.
    </p>
    <a href={calendarUrl} class="btn btn--primary" target="_blank" rel="noopener">
      Grab 15 minutes with Anthony &rarr;
    </a>
  </section>

  <!-- Secondary actions -->
  <section class="actions no-print">
    <button type="button" class="btn btn--ghost" id="print-btn">
      🖨 Print report
    </button>
    {showEmailButton && (
      <button type="button" class="btn btn--ghost" id="email-btn" data-report-id={reportId}>
        ✉ Email me a copy
      </button>
    )}
    <div class="actions__hint">
      Tip: use <strong>Print → Save as PDF</strong> in your browser to save a copy for your records.
    </div>
    <div id="email-status" class="actions__status" aria-live="polite"></div>
  </section>

  <!-- Fine print -->
  <footer class="report__footer">
    <div>Report ID: <code>{reportId}</code></div>
    <div>Run via Google Lighthouse · Designed by Anthony</div>
  </footer>
</article>

<script define:vars={{ apiBase: API_BASE }}>
  // Print button
  const printBtn = document.getElementById('print-btn');
  if (printBtn) {
    printBtn.addEventListener('click', () => window.print());
  }

  // Email-me-a-copy button
  const emailBtn = document.getElementById('email-btn');
  const emailStatus = document.getElementById('email-status');
  if (emailBtn && emailStatus) {
    emailBtn.addEventListener('click', async () => {
      const reportId = emailBtn.getAttribute('data-report-id');
      if (!reportId) return;

      emailBtn.setAttribute('disabled', 'true');
      emailStatus.textContent = 'Sending…';
      emailStatus.className = 'actions__status actions__status--pending';

      try {
        const res = await fetch(`${apiBase}/api/report/${reportId}/email`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const data = await res.json();

        if (res.ok && data.success) {
          emailStatus.textContent = '✓ Sent — check your inbox.';
          emailStatus.className = 'actions__status actions__status--success';
          // Keep disabled so they can't spam it
        } else {
          emailStatus.textContent = data.error || 'Something went wrong. Try again in a minute.';
          emailStatus.className = 'actions__status actions__status--error';
          emailBtn.removeAttribute('disabled');
        }
      } catch (err) {
        emailStatus.textContent = 'Network error. Try again in a minute.';
        emailStatus.className = 'actions__status actions__status--error';
        emailBtn.removeAttribute('disabled');
      }
    });
  }
</script>

<style>
  .report {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #111;
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 24px;
    line-height: 1.6;
    font-size: 16px;
  }

  /* --- Header --- */
  .report__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .report__brand-name {
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #111;
  }
  .report__brand-sub {
    font-size: 12px;
    color: #6b7280;
    letter-spacing: 0.3px;
  }
  .report__meta {
    text-align: right;
    font-size: 12px;
  }
  .report__id {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-weight: 600;
    color: #111;
    background: #f3f4f6;
    padding: 4px 10px;
    border-radius: 4px;
    display: inline-block;
  }
  .report__date {
    color: #6b7280;
    margin-top: 4px;
  }
  .report__divider {
    height: 1px;
    background: #e5e7eb;
    margin: 20px 0 24px;
  }

  /* --- Subject --- */
  .report__subject {
    margin-bottom: 32px;
  }
  .report__title {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 4px;
    line-height: 1.2;
  }
  .report__url {
    color: #6b7280;
    font-size: 14px;
    text-decoration: none;
  }
  .report__url:hover {
    color: #111;
    text-decoration: underline;
  }

  /* --- Score cards --- */
  .report__scores {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  @media (max-width: 600px) {
    .report__scores {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .score-card {
    text-align: center;
  }
  .score-card__ring {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 4px solid var(--score-color);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 8px;
    background: color-mix(in srgb, var(--score-color) 8%, white);
  }
  .score-card__value {
    font-size: 28px;
    font-weight: 700;
    color: var(--score-color);
  }
  .score-card__label {
    font-size: 12px;
    font-weight: 600;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  /* --- Sections --- */
  .report__section {
    margin-bottom: 32px;
  }
  .report__h2 {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #6b7280;
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e5e7eb;
  }
  .report__insight :global(p) {
    margin: 0 0 14px;
  }
  .report__insight :global(p:last-child) {
    margin-bottom: 0;
  }

  /* --- Metrics --- */
  .metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin: 0;
  }
  @media (max-width: 500px) {
    .metrics { grid-template-columns: 1fr; }
  }
  .metric {
    background: #f9fafb;
    padding: 12px 16px;
    border-radius: 6px;
  }
  .metric dt {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: #6b7280;
    font-weight: 600;
  }
  .metric dd {
    margin: 2px 0 0;
    font-size: 18px;
    font-weight: 600;
    color: #111;
  }

  /* --- Key Findings (Strengths / Weaknesses) --- */
  .findings {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media (max-width: 600px) {
    .findings { grid-template-columns: 1fr; }
  }
  .findings__heading {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin: 0 0 10px;
    padding-bottom: 8px;
    border-bottom: 2px solid;
  }
  .findings__heading--good { color: #059669; border-color: #059669; }
  .findings__heading--bad { color: #dc2626; border-color: #dc2626; }
  .findings__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .findings__item {
    font-size: 14px;
    line-height: 1.5;
    padding: 10px 12px 10px 36px;
    border-radius: 6px;
    position: relative;
  }
  .findings__item::before {
    position: absolute;
    left: 12px;
    top: 10px;
    font-size: 14px;
    line-height: 1;
  }
  .findings__item--good {
    background: #f0fdf4;
    color: #166534;
  }
  .findings__item--good::before { content: '✓'; color: #059669; font-weight: 700; }
  .findings__item--bad {
    background: #fef2f2;
    color: #991b1b;
  }
  .findings__item--bad::before { content: '!'; color: #dc2626; font-weight: 700; }

  /* --- Prioritized Actions --- */
  .actions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    counter-reset: none;
  }
  .action-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: #f9fafb;
    border-radius: 8px;
    padding: 16px;
    border: 1px solid #e5e7eb;
    transition: border-color 0.15s ease;
  }
  .action-card:hover { border-color: #d1d5db; }
  .action-card__number {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #111;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .action-card__body {
    flex: 1;
    min-width: 0;
  }
  .action-card__text {
    margin: 0 0 8px;
    font-size: 14px;
    line-height: 1.5;
    color: #111;
  }
  .action-card__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .action-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    padding: 3px 8px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color, #6b7280) 12%, white);
    color: var(--tag-color, #6b7280);
    border: 1px solid color-mix(in srgb, var(--tag-color, #6b7280) 25%, transparent);
  }
  .action-tag--effort {
    --tag-color: #6b7280;
  }

  /* --- Site Health Checklist --- */
  .checklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .checklist__item {
    font-size: 14px;
    padding: 8px 12px 8px 34px;
    border-radius: 6px;
    position: relative;
    line-height: 1.5;
  }
  .checklist__item::before {
    position: absolute;
    left: 10px;
    top: 8px;
