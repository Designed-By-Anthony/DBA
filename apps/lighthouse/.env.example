# Runtime services
GOOGLE_PAGESPEED_API_KEY=
GEMINI_API_KEY=
FORMSPREE_ENDPOINT=
TURNSTILE_SECRET_KEY=

# Optional Gmail + CRM integrations
GMAIL_SERVICE_ACCOUNT_KEY=
SHEETS_ID=
DRIVE_PROJECTS_FOLDER_ID=

# SEO audit enrichment (all optional — audit works without them)
# Moz Links API — base64-encoded accessId:secretKey OR x-moz-token value
MOZ_API_CREDENTIALS=

# Google Places (business + competitor lookup)
GOOGLE_PLACES_API_KEY=

# Optional overrides
GOOGLE_CLOUD_PROJECT=lighthouse-492701
GOOGLE_CLOUD_LOCATION=us-east4
GEMINI_MODEL=gemini-2.5-pro
ALLOWED_ORIGINS=

# CRM (Web Viewer) — POST /api/webhooks/lead; secret must match Web Viewer LEAD_WEBHOOK_SECRET
AGENCY_OS_WEBHOOK_URL=
AGENCY_OS_WEBHOOK_SECRET=
# Where /report/:id is hosted (Designed by Anthony); matches Sheets report links
REPORT_PUBLIC_BASE_URL=https://designedbyanthony.com

# Sentry (error monitoring, tracing, session replay, logs)
# Client (browser) — public
NEXT_PUBLIC_SENTRY_DSN=
# Server / Edge — often same DSN as NEXT_PUBLIC_SENTRY_DSN; set explicitly if you split projects
SENTRY_DSN=
# Build-time: source maps + releases (keep in CI secrets or .env.sentry-build-plugin — gitignored)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
