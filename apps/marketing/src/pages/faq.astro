---
import SourceList from "../components/SourceList.astro";
import { evidenceLinks } from "../data/evidence";
import Layout from "../layouts/Layout.astro";
import {
	FOUNDING_PARTNER_SEO_LABEL,
	MONTHLY_LOCAL_SEO_PRICE,
	PUBLIC_PRICING_NOTE,
	PUBLIC_PRICING_PILL,
	STANDARD_WEBSITE_STARTING_PRICE,
} from "../lib/offers";
import { buildFaqPageSchema } from "../lib/seo";

const platformSources = [
	{
		...evidenceLinks.astroWhy,
		note: "Astro is built for content-driven sites and emphasizes shipping less client-side JavaScript.",
	},
	{
		...evidenceLinks.astroPrerender,
		note: "Astro prerenders pages by default when they do not need server logic.",
	},
	{
		...evidenceLinks.wordpressUpdates,
		note: "WordPress projects typically involve ongoing update management.",
	},
];

const mobileSources = [
	{
		...evidenceLinks.googleMobileFirst,
		note: "Google predominantly uses the mobile version of the content for indexing and ranking.",
	},
];

const seoSources = [
	{
		...evidenceLinks.googlePageExperience,
		note: "Google says good Core Web Vitals and mobile usability matter to page experience.",
	},
	{
		...evidenceLinks.googleLocalBusiness,
		note: "Proper LocalBusiness schema helps Google understand a business more clearly.",
	},
];

const faqEntries = [
	{
		question: "Who is the best fit for Designed by Anthony?",
		answer:
			"Service businesses that want a website that looks professional, shows up on Google, and gets more calls. If a quick template is not cutting it and you want something built around your business, this is a strong fit.",
	},
	{
		question: "What is the starting price?",
		answer: `${PUBLIC_PRICING_NOTE} Final pricing still depends on how many pages you need, what features are involved, and whether the job is a new build, a rescue, or an SEO engagement.`,
	},
	{
		question: "What is the payment structure?",
		answer:
			"50% down to start the project. 50% at launch after you have approved the final site. No surprise charges.",
	},
	{
		question: "Do you offer payment plans?",
		answer:
			"Yes. In-house payment plans are available on every project. No credit checks, no third-party financing, and no hidden fees. We work out a schedule that fits your budget before any work begins so there are no surprises.",
	},
	{
		question: "Who writes the website content?",
		answer:
			"You give Anthony the topics and ideas. Anthony writes the copy. You are not stuck trying to write your own website.",
	},
	{
		question: "How many revisions do I get?",
		answer:
			"The work keeps getting refined until the site is right. Most projects wrap in one or two rounds of feedback, but corners do not get cut.",
	},
	{
		question: "Can I see the site before it goes live?",
		answer:
			"Yes. You get a full preview of the site before anything launches. Nothing goes live until you say it is ready.",
	},
	{
		question: "What happens in the free website audit?",
		answer:
			"You can run our in-house Lighthouse scanner right on the site — no signup, no waiting. Enter any URL and get instant performance, accessibility, best practices, and SEO scores. If you want a deeper analysis, Anthony reviews the results and follows up with a practical action plan within 24 hours.",
	},
	{
		question: "What is the free Lighthouse audit tool?",
		answer:
			"It is a live, instant audit tool built in-house by our engineering team. It runs a full Google Lighthouse pass against any URL you enter and returns four category scores — performance, accessibility, best practices, and SEO — in under 60 seconds. The same engineering quality behind the tool is the same engineering behind every site we build.",
	},
	{
		question: "How is this different from Google PageSpeed Insights?",
		answer:
			"Our tool runs the same core Lighthouse engine, but it is built specifically for service businesses evaluating their website. You get your scores instantly on screen plus the option for Anthony to review the results and provide a contextual recommendation based on what he sees — not just a raw data dump.",
	},
	{
		question: "Do I need to give my email to run an audit?",
		answer:
			"The tool asks for your name, company, and email so Anthony can follow up with a deeper analysis if you want one. Your scores are delivered instantly on screen regardless.",
	},
	{
		question: "How quickly do you reply?",
		answer:
			"Audit requests and serious inquiries are answered within one business day. No drawn-out sales process.",
	},
	{
		question: "How long does a project usually take?",
		answer:
			"Most websites for service businesses are done in a few weeks once we know the scope and have your input. Bigger projects take longer. We lay out the timeline clearly before any work starts.",
	},
	{
		question: "What does managed hosting cost?",
		answer: `$40 per year for hosting on its own. Or it is included free in the ${MONTHLY_LOCAL_SEO_PRICE} per month SEO maintenance package. We recommend the package because it puts your site on global CDN servers that make it load faster for visitors everywhere.`,
	},
	{
		question: "What about ongoing costs after the site is built?",
		answer: `The only ongoing cost is hosting at $40 per year. If you want SEO maintenance, that is ${MONTHLY_LOCAL_SEO_PRICE} per month and includes hosting. No hidden fees.`,
	},
	{
		question: "What if I already have a website?",
		answer:
			"That is common. I review whether the current site needs better content, stronger local SEO, a speed fix, or a full rebuild. The free audit is designed to answer that first.",
	},
	{
		question: "Do you offer logo design or branding?",
		answer:
			"Yes. If your business needs a logo, color palette, or basic brand identity as part of a website project, we handle that in-house. The goal is a cohesive look across your site, business cards, and online profiles so everything feels like the same business. If you already have branding you like, we build around it.",
	},
	{
		question: "How much does a website cost compared to a big agency?",
		answer: `Large agencies typically charge $5,000 to $15,000 or more for a small business website, and that often does not include hosting or ongoing SEO. Freelance marketplaces can go lower, but the quality and communication vary wildly. Here, standard custom website builds start at ${STANDARD_WEBSITE_STARTING_PRICE}, and the relaunch founding partner program includes a limited number of complimentary builds for qualified businesses paired with the monthly ${FOUNDING_PARTNER_SEO_LABEL}. You get a custom-built site with SEO structure, fast performance, and direct communication with the person doing the work — at a fraction of the agency price.`,
	},
	{
		question: "Why do you use a different technology instead of WordPress?",
		answer:
			"The technology behind Designed by Anthony lets me build faster, lighter websites that score higher on Google and need less maintenance. No plugin maze to update, no constant security patching, and a cleaner codebase that loads faster because there is less slowing it down.",
		sources: platformSources,
	},
	{
		question: "Why does mobile performance matter so much?",
		answer:
			"Most people searching for a contractor or service business are on their phone. If your site is slow or hard to use on mobile, they leave and call someone else. Google also ranks slow mobile sites lower.",
		sources: mobileSources,
	},
	{
		question: "Is SEO included in a new build?",
		answer: `Yes. Every site we build is set up to show up on Google from day one. If you want ongoing SEO work to keep climbing the rankings, that is available as a ${MONTHLY_LOCAL_SEO_PRICE} per month package.`,
		sources: seoSources,
	},
	{
		question: "What kind of results are these sites built to improve?",
		answer: `The consistent goals are the same: faster load times, stronger Google positioning, and a site that looks professional enough for visitors to actually pick up the phone. The finished example builds show the quality level, and the free audit shows what is holding your specific site back—plus whether a founding partner spot still makes sense for your business.`,
	},
	{
		question: "Why should I trust a solo operator instead of a bigger agency?",
		answer:
			"Because you talk to the person doing the work. At a bigger agency, your project gets assigned to whoever is available, filtered through an account manager, and built with the same templates they use for every client. Here, Anthony writes the code, writes the copy, handles the SEO setup, and answers your questions directly. The tradeoff is scale — I take fewer projects at a time. The benefit is that nothing gets lost in translation and the standard stays the same from first call to final launch.",
	},
	{
		question: "What if I already tried a web designer and it did not work out?",
		answer:
			"That happens more often than people admit. The usual story is a template site that looked okay at first but never brought in calls, or a project that dragged on for months and still did not feel right. The free audit is designed to show you what actually needs to change before any money changes hands. You see the report, you see the recommendation, and you decide whether to move forward.",
	},
];

const faqSchema = buildFaqPageSchema(
	faqEntries.map(({ question, answer }) => ({
		question,
		answer,
	})),
);

const faqFooterCta = {
	eyebrow: "Still Have a Question?",
	title:
		"If you want a direct answer about your own site, start with the audit.",
	description:
		"Run our free Lighthouse scanner to see your scores instantly. If you want a deeper read, Anthony will follow up with a practical next step.",
	primaryHref: "/free-seo-audit",
	primaryLabel: "Run the Free Audit",
	secondaryHref:
		"https://calendly.com/anthony-designedbyanthony/web-design-consult",
	secondaryLabel: "Book a 15-minute intro call",
	note: "Instant results. No catch and no mailing list.",
};
---

<Layout
  title="Web Design & Development FAQ: Pricing & Process | Designed by Anthony"
  description="Web design and development FAQ covering pricing, process, hosting, local SEO, and how our company works with small service businesses."
  schema={faqSchema}
  footerCta={faqFooterCta}
>
  <section class="page-hero centered">
    <div class="page-hero-inner faq-hero">
      <p class="page-eyebrow">FAQ</p>
      <h1>Answers to the questions most businesses ask before getting started.</h1>
      <p>
        Pricing, process, what you get, and what to expect. If your question is not here, use the <a href="/contact">contact page</a> and I will point you in the right direction.
      </p>
      <div class="hero-meta-row">
        <span class="mini-pill">{PUBLIC_PRICING_PILL}</span>
        <span class="mini-pill">Reply within one business day</span>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="section-container faq-container" id="faq-accordion" data-faq-accordion>
      {faqEntries.map((entry) => (
        <div class="faq-item surface-card reveal-up">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-icon"></span>
            <span class="faq-title">{entry.question}</span>
          </button>
          <div class="faq-panel">
            <div class="faq-panel-inner">
              <div class="faq-content">
                <p>{entry.answer}</p>
                {entry.sources && <SourceList title="Sources" items={entry.sources} compact={true} />}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .faq-hero {
    max-width: 860px;
  }

  .faq-container {
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    overflow: hidden;
  }

  .faq-trigger {
    width: 100%;
    padding: 1.7rem 1.8rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }

  .faq-trigger:focus-visible {
    outline: 2px solid rgba(96, 165, 250, 0.4);
    outline-offset: -2px;
  }

  .faq-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background-color: var(--accent-blue);
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  .faq-icon::before {
    top: 9px;
    left: 0;
    width: 20px;
    height: 3px;
    border-radius: 2px;
  }

  .faq-icon::after {
    top: 0;
    left: 9px;
    width: 3px;
    height: 20px;
    border-radius: 2px;
  }

  .faq-trigger[aria-expanded='true'] .faq-icon::after {
    opacity: 0;
    transform: scaleY(0);
  }

  .faq-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-white);
    line-height: 1.45;
  }

  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  .faq-panel.is-open {
    grid-template-rows: 1fr;
  }

  .faq-panel-inner {
    overflow: hidden;
  }

  .faq-content {
    padding: 0 1.8rem 1.6rem 3.8rem;
  }

  .faq-content p {
    color: var(--text-gray);
  }

  @media (max-width: 768px) {
    .faq-trigger {
      padding: 1.3rem 1.2rem;
    }

    .faq-content {
      padding: 0 1.2rem 1.2rem;
    }
  }
</style>
