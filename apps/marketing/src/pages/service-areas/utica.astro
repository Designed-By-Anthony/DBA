---
import ServiceAreaPage from "../../components/ServiceAreaPage.astro";
import { buildServiceAreaSchema } from "../../lib/seo";

const pageTitle = "Utica Web Design, Hosting & SEO | Designed by Anthony";
const pageDescription =
	"Responsive web design, managed hosting, and local SEO for Utica service businesses that need better visibility, stronger trust, and more calls.";

const areaSchema = buildServiceAreaSchema({
	name: "Web Design and Hosting Services in Utica, New York",
	description: pageDescription,
	path: "/service-areas/utica",
	areaServed: "Utica, New York",
	serviceType: "Web design, managed hosting, website rescue, and local SEO",
	cityName: "Utica",
	regionName: "New York",
	regionAbbr: "NY",
	geo: { latitude: 43.1009, longitude: -75.2327 },
});

const blocks = [
	{
		level: "h2" as const,
		title: "Why Utica businesses need stronger digital positioning",
		paragraphs: [
			"Utica is a broader and busier search market than many surrounding towns. Businesses competing for website design in Utica are up against healthcare, legal, trades, restaurants, and professional services all chasing the same steady stream of mobile users looking for the fastest trustworthy option.",
			"That means your website cannot just exist. It has to clarify your offer quickly, feel current on mobile, and make it obvious why someone should contact you instead of the next listing in search results.",
		],
	},
	{
		level: "h3" as const,
		title: "A city page should match how people actually search",
		paragraphs: [
			"Utica customers do not always search with perfect brand awareness. They search by service, urgency, neighborhood familiarity, and trust. Your page architecture has to meet that behavior with focused service pages, better metadata, and location-aware copy that sounds specific instead of generic.",
		],
	},
	{
		level: "h4" as const,
		title: "Trust signals matter in a more competitive SERP",
		paragraphs: [
			"In Utica, strong reviews, clearer proof, structured data, and faster load times can make the difference between getting the click and being skipped entirely. Your website has to support those signals, not dilute them.",
		],
	},
	{
		level: "h5" as const,
		title: "Clarity usually wins before brand familiarity does",
		paragraphs: [
			"A better-structured Utica page helps the right visitor understand the offer quickly, which matters a lot when they are comparing several local options in one search session.",
		],
	},
	{
		level: "h2" as const,
		title: "Website rescues for established Utica companies",
		paragraphs: [
			"Many long-running businesses in Utica are sitting on websites that were built in another era of the internet. They may still pull in some traffic, but they often feel cluttered, outdated, or difficult to use on phones, which quietly drags down conversions.",
			"A rescue project modernizes the experience without throwing away the recognition and search equity the business has already earned. That is especially important in a city where legacy reputation and local familiarity still carry real weight.",
		],
	},
	{
		level: "h3" as const,
		title: "Keeping your rankings intact during a rebuild",
		paragraphs: [
			"The rebuild process should preserve URLs where it makes sense, redirect the pages that need to change, and keep local relevance intact. That protects the value of your existing site while giving you a better foundation for future growth.",
		],
	},
	{
		level: "h2" as const,
		title: "Local SEO and hosting for Utica service businesses",
		paragraphs: [
			"Utica businesses often benefit from a layered local strategy: one strong Utica page, targeted service pages, and supporting pages for nearby high-priority towns when the business truly serves them. Combined with real search engine optimization on each page, this structure creates clearer relevance than broad regional copy ever will.",
			"On the web hosting side, the priority is simple. The site needs to stay fast, secure, and stable whether a lead finds you from an organic search, a map listing, or a social referral. Reliable Utica web hosting keeps the website from becoming the weak point in your sales process.",
		],
	},
	{
		level: "h3" as const,
		title: "Website rescue work for older Utica sites",
		paragraphs: [
			"A lot of Utica businesses do not need a brand-new digital strategy. They need a cleaner site, better mobile performance, stronger service framing, and hosting they do not have to babysit. That is where rescue work usually makes more sense than another patch layered on top of an already weak build.",
			"The goal is straightforward: keep what still helps, remove what creates friction, and rebuild the parts that make the business look older, slower, or harder to trust than it really is.",
		],
	},
	{
		level: "h3" as const,
		title: "When separate pages for Utica and nearby towns help",
		paragraphs: [
			"If the business actively competes in Utica, New Hartford, and Rome, separate pages usually improve both relevance and conversion because each market has its own expectations, search behavior, and level of competition.",
		],
	},
];

const relatedMarkets = [
	{
		title: "Rome NY Website Designer",
		href: "/service-areas/rome",
		description:
			"A tighter local page for businesses that need dedicated coverage in Rome and the surrounding Mohawk Valley market.",
		tag: "Rome",
	},
	{
		title: "Web Design in New Hartford, NY",
		href: "/service-areas/new-hartford",
		description:
			"A good companion page when the business also competes in New Hartford, Whitesboro, or Yorkville.",
		tag: "New Hartford",
	},
	{
		title: "Syracuse Web Design Company",
		href: "/service-areas/syracuse",
		description:
			"The next move for businesses expanding from Utica into a larger Central New York search market.",
		tag: "Syracuse",
	},
];
---

<ServiceAreaPage
  title={pageTitle}
  description={pageDescription}
  breadcrumbLabel="Utica"
  schema={areaSchema}
  eyebrow="Utica, New York"
  heroTitlePrefix="Web Design and Hosting for"
  heroHighlight="Utica"
  heroDescription="Responsive website design, managed web hosting, and local search engine optimization for Utica businesses that need to look credible faster and turn more visits into calls."
  heroPills={['Utica website design', 'Web hosting and local SEO', 'Focused city and nearby-town coverage']}
  blocks={blocks}
  ctaLabel="Get a Free Utica Website Audit"
  relatedMarkets={relatedMarkets}
/>
