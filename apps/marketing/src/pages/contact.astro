---
import AuditForm from "../components/AuditForm.astro";
import PortableEmbedShowcase from "../components/PortableEmbedShowcase.astro";
import Layout from "../layouts/Layout.astro";
import {
	FOUNDING_PARTNER_SEO_LABEL,
	MONTHLY_LOCAL_SEO_PRICE,
} from "../lib/offers";
import {
	businessProfile,
	ORGANIZATION_ID,
	type SchemaValue,
	toAbsoluteUrl,
} from "../lib/seo";

const contactSchema: SchemaValue = {
	"@context": "https://schema.org",
	"@type": "ContactPage",
	"@id": `${toAbsoluteUrl("/contact")}#contact`,
	url: toAbsoluteUrl("/contact"),
	name: "Contact Anthony Jones About Web Design and SEO | Designed by Anthony",
	description:
		"Get in touch with Designed by Anthony for custom web design, local SEO, managed hosting, or website rescue projects.",
	mainEntity: {
		"@id": ORGANIZATION_ID,
	},
	contactPoint: [
		{
			"@type": "ContactPoint",
			contactType: "sales",
			email: businessProfile.email,
			telephone: businessProfile.telephone,
			areaServed: "US",
			availableLanguage: ["en-US"],
		},
	],
};
---

<Layout
  title="Contact — Web Design & SEO | Designed by Anthony"
  description="Get in touch with Designed by Anthony for custom web design, local SEO, managed hosting, or website rescue projects. Direct communication with the founder."
  pageType="ContactPage"
  schema={contactSchema}
  hidePreFooterCTA={true}
>
  <section class="page-hero centered">
    <div class="page-hero-inner contact-hero">
      <p class="page-eyebrow">Get in touch</p>
      <h1>Tell me what you are trying to fix.</h1>
      <p>
        New build, rescue, local SEO, hosting — whatever it is, drop the details below. I read every message and reply within one business day.
      </p>
      <div class="hero-meta-row">
        <span class="mini-pill">Reply within 24 hours</span>
        <span class="mini-pill">Custom Web Design</span>
        <span class="mini-pill">Founder-led guidance</span>
      </div>
      <div class="audit-nudge">
        <span>Looking for an instant site check?</span>
        <a href="/free-seo-audit">Run our free Lighthouse audit →</a>
      </div>
    </div>
  </section>

  <section class="section-shell contact-shell">
    <div class="section-container contact-grid">
      <aside class="surface-card contact-sidebar reveal-up">
        <div class="card-tag">What you get</div>
        <h2>You talk to the person building the site.</h2>
        <p>
          No account managers, no handoff queue. I write the code, own the timeline, and answer the phone when something matters.
        </p>

        <ul class="trust-list contact-trust-list">
          <li>Sites tuned to load fast and score strong on Lighthouse — because slow pages cost you calls.</li>
          <li>Our audit tool is in-house, so the same care goes into your build as into the scanner.</li>
          <li>SEO structure baked into every new build, not sold as a surprise add-on.</li>
        </ul>

        <div class="contact-direct">
          <span class="contact-label">How I respond</span>
          <p>You will hear back within 24 hours with a clear next step — not an automated sequence.</p>
        </div>

        <div class="contact-direct">
          <span class="contact-label">What to include</span>
          <p>Share your website URL (if you have one) and what you are looking to accomplish so I can give you the most useful feedback.</p>
        </div>

        <div class="contact-direct">
          <span class="contact-label">Best fit</span>
          <p>Service businesses that want a website that actually brings in calls instead of just sitting there.</p>
        </div>

        <div class="contact-direct contact-risk-reversal">
          <span class="contact-label">No commitment. No catch.</span>
          <ul class="trust-list contact-trust-list">
            <li>No deposit required to start the conversation.</li>
            <li>You will not be added to a mailing list.</li>
            <li>If I am not the right fit, I will tell you that too.</li>
          </ul>
        </div>

        <div class="contact-direct contact-founder-nudge">
          <span class="contact-label">Founding partner spots</span>
          <p>Ten businesses get a complimentary custom build at launch when they enroll in the {MONTHLY_LOCAL_SEO_PRICE}/mo {FOUNDING_PARTNER_SEO_LABEL}. If you are interested, mention it in your message or <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" data-calendar-link class="inline-link">book a quick call directly</a>.</p>
        </div>
      </aside>

      <div class="surface-card contact-form-card reveal-up">
        <div class="contact-form-copy">
          <div class="card-tag">Start a Conversation</div>
          <h2>Tell me about the project.</h2>
          <p>
            Share what you are looking to build, fix, or improve. I will reply within 24 hours with the clearest next step.
          </p>
        </div>

        <AuditForm
          ctaSource="contact-page"
          pageContext="contact_page_general"
          pageTitle="Contact Anthony Jones About Web Design and SEO | Designed by Anthony"
          offerType="contact_page"
          subjectLine="New Project Inquiry - Designed by Anthony"
          submitLabel="Send Message"
          metaMessage="No spam. Direct reply within 24 hours from Anthony."
          websiteLabel="Website URL (if you have one)"
          websitePlaceholder="yourwebsite.com"
          websiteRequired={false}
          issueLabel="What are you looking to accomplish?"
          issuePlaceholder="New website, site rescue, local SEO, managed hosting, or something else..."
          issueRequired={false}
          successMode="redirect"
          successTag="Message Sent"
          successTitle="Got it — I will be in touch."
          successMessage="Anthony will review your message and reply within 24 hours with a practical next step."
          successPoints={[
            'Your message was delivered successfully.',
            'Anthony will review and respond personally.',
            'You will hear back within one business day.',
          ]}
        />
      </div>
    </div>
  </section>

  <PortableEmbedShowcase />

  <section class="section-shell calendly-shell">
    <div class="section-container">
      <div class="section-header centered">
        <p class="section-eyebrow">Prefer to Book Directly?</p>
        <h2>Pick a time that works for you — no form needed.</h2>
        <p>If you already know you want to talk, skip the form and grab a time on the calendar. This is a free 15-minute intro call with Anthony.</p>
      </div>
      <div class="calendly-cta-card surface-card reveal-up">
        <div class="calendly-cta-inner">
          <svg class="calendly-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <h3>Schedule a 15-minute intro call</h3>
          <p>Free 15-minute intro call. Anthony reviews your situation and tells you the clearest next step — whether that's a small fix or a full rebuild.</p>
          <button
            type="button"
            class="btn btn-primary-book"
            id="calendlyOpenBtn"
            data-calendar-link
            data-calendly-href="https://calendly.com/anthony-designedbyanthony/web-design-consult?utm_source=contact_page&utm_medium=site&utm_campaign=direct_intro_call"
          >
            Open Calendar
          </button>
        </div>
      </div>
    </div>
  </section>

  <div
    class="layout-calendly-modal"
    id="calendlyModal"
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="calendlyModalTitle"
  >
    <div class="layout-calendly-modal__content splash-shell splash-shell--calendly">
      <h2 id="calendlyModalTitle" class="sr-only">
        Schedule a web design consultation
      </h2>
      <button type="button" class="layout-calendly-modal__close splash-close" id="calendlyCloseBtn" aria-label="Close calendar">
        &times;
      </button>
      <div class="layout-calendly-modal__body" id="calendlyModalBody">
        <div class="calendly-embed-loading" data-calendly-loading>
          <div class="calendly-embed-loading__spinner" aria-hidden="true" />
          <p class="calendly-embed-loading__text">Loading calendar…</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contact-hero {
    max-width: 860px;
  }

  .audit-nudge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.25rem;
    font-size: 0.92rem;
  }

  .audit-nudge span {
    color: var(--text-gray);
  }

  .audit-nudge a {
    color: #93c5fd;
    font-weight: 700;
    transition: color 0.2s ease;
  }

  .audit-nudge a:hover {
    color: var(--text-white);
  }

  .contact-shell {
    padding-top: 4rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.86fr) minmax(0, 1.14fr);
    gap: 1.5rem;
    align-items: start;
  }

  .contact-sidebar,
  .contact-form-card {
    padding: 2rem;
  }

  .contact-sidebar h2,
  .contact-form-card h2 {
    font-size: clamp(1.8rem, 3vw, 2.35rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin: 1rem 0 0.9rem;
  }

  .contact-sidebar > p,
  .contact-form-copy p {
    color: var(--text-gray);
    font-size: 1rem;
    line-height: 1.75;
  }

  .contact-trust-list {
    margin-top: 1.5rem;
  }

  .contact-direct {
    display: grid;
    gap: 0.35rem;
    padding-top: 1.2rem;
    margin-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .contact-label {
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #93c5fd;
  }

  .contact-direct a {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-white);
  }

  .contact-direct p {
    color: var(--text-gray);
    line-height: 1.72;
  }

  .contact-direct .inline-link {
    color: #93c5fd;
    font-weight: 600;
    font-size: inherit;
  }

  .contact-direct .inline-link:hover {
    color: var(--text-white);
  }

  .contact-risk-reversal .trust-list {
    margin-top: 0.5rem;
  }

  .contact-form-copy {
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Calendly CTA Card */
  .calendly-shell {
    padding-top: 0;
    padding-bottom: 5rem;
  }

  .calendly-cta-card {
    max-width: 560px;
    margin: 0 auto;
    padding: 2.5rem;
    text-align: center;
  }

  .calendly-cta-inner {
    position: relative;
    z-index: 1;
  }

  .calendly-icon {
    width: 48px;
    height: 48px;
    color: var(--accent-blue);
    margin-bottom: 1.25rem;
  }

  .calendly-cta-card h3 {
    font-size: 1.35rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .calendly-cta-card p {
    color: var(--text-gray);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

</style>
