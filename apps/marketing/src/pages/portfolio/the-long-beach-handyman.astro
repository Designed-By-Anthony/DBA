---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { showcaseItems } from '../../data/showcase';
import { releases } from '../../data/releases';
import { buildBlogPostingSchema } from '../../lib/seo';

const project = showcaseItems.find((item) => item.caseStudySlug === 'the-long-beach-handyman')!;
const release = releases.find((item) => item.url === '/portfolio/the-long-beach-handyman')!;

const caseStudySchema = buildBlogPostingSchema({
  headline: release.title,
  description: release.excerpt,
  path: '/portfolio/the-long-beach-handyman',
  image: project.image!,
  datePublished: release.publishedTime,
  articleSection: 'Case Study',
  keywords: [
    'handyman website',
    'client build',
    'custom web design',
    'Long Beach CA',
    'Storyblok CMS',
    'lead generation website',
    'local SEO',
    'contractor website',
  ],
});

const footerCta = {
  eyebrow: 'Want a Site Like This?',
  title: 'See where your current site stands first.',
  description:
    'Run the free audit for an instant baseline, then book a short call if you want a direct recommendation.',
  primaryHref: '/free-seo-audit',
  primaryLabel: 'Run the Free Audit',
  secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
  secondaryLabel: 'Book a 15-minute intro call',
};
---

<Layout
  title={`${release.title} | Designed by Anthony`}
  description={release.excerpt}
  breadcrumbLabel="The Long Beach Handyman"
  image={project.image}
  schema={caseStudySchema}
  footerCta={footerCta}
>
  <section class="page-hero">
    <div class="page-hero-inner case-hero">
      <div class="case-hero-copy">
        <div class="case-hero-meta">
          <span class="card-tag">{project.statusLabel}</span>
          <span class="case-industry">{project.industry}</span>
          <span class="case-live-badge">● Live</span>
        </div>
        <h1>The Long Beach Handyman</h1>
        <p class="lead-copy">
          {project.description}
        </p>
        <div class="hero-actions">
          <a href={project.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Visit the Live Site<span class="sr-only">(opens in new window)</span>
          </a>
          <a href="/free-seo-audit" class="btn btn-outline">Run the Free Audit</a>
        </div>
      </div>
      {project.displayImage && (
        <div class="case-hero-image">
          <Image
            src={project.displayImage}
            alt={project.imageAlt!}
            class="case-image"
            widths={[640, 960, 1280, 1600]}
            sizes="(max-width: 900px) 100vw, 55vw"
            format="webp"
            quality={80}
            loading="eager"
          />
        </div>
      )}
    </div>
  </section>

  <section class="section-shell">
    <div class="section-container case-grid">
      <div class="surface-card case-block reveal-up">
        <p class="section-eyebrow">The Challenge</p>
        <h2>What the business needed</h2>
        <p>{project.problem}</p>
      </div>
      <div class="surface-card case-block reveal-up">
        <p class="section-eyebrow">The Build</p>
        <h2>How we solved it</h2>
        <p>{project.solution}</p>
      </div>
    </div>
  </section>

  {project.features && project.features.length > 0 && (
    <section class="section-shell case-features-shell">
      <div class="section-container">
        <div class="section-header centered">
          <p class="section-eyebrow">What We Built</p>
          <h2>The technical features behind the project</h2>
          <p>
            Every feature was chosen because it solves a real business problem — not because it looks good on a spec sheet.
          </p>
        </div>
        <div class="case-features-grid">
          {project.features.map((feature, i) => (
            <div class="surface-card case-feature-card reveal-up">
              <span class="case-feature-number">{String(i + 1).padStart(2, '0')}</span>
              <h3>{feature.label}</h3>
              <p>{feature.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-shell">
    <div class="section-container">
      <div class="proof-band case-results reveal-up">
        <div class="section-header centered">
          <p class="section-eyebrow">Results at Launch</p>
          <h2>What was delivered and what is still being validated</h2>
        </div>
        <div class="proof-grid">
          <div class="proof-item">
            <span class="proof-value">$250</span>
            <span class="proof-label">Client-paid build project (initial launch budget)</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">98+</span>
            <span class="proof-label">Lighthouse scores at launch benchmark</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">0</span>
            <span class="proof-label">Confirmed customers from paid ads so far</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">Live</span>
            <span class="proof-label">Site deployed with analytics tracking active</span>
          </div>
        </div>
        <p class="case-results-note">
          This is an early client case study. The technical baseline is strong, but lead generation performance is still in testing.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell case-visit-shell">
    <div class="section-container">
      <div class="cta-band case-visit-band reveal-up">
        <div class="case-visit-copy">
          <p class="section-eyebrow">See It Live</p>
          <h2>Visit the finished site</h2>
          <p>
            The Long Beach Handyman is live in production. See the finished build and how the site experience holds up on real devices.
          </p>
          <div class="hero-actions">
            <a href={project.href} target="_blank" rel="noopener noreferrer" class="btn btn-white">
              Open thelongbeachhandyman.com<span class="sr-only">(opens in new window)</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .case-hero {
    max-width: 1180px;
  }

  .case-hero-copy {
    max-width: 680px;
  }

  .case-hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.2rem;
  }

  .case-industry {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .case-live-badge {
    color: #22c55e;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .case-hero h1 {
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.02;
    margin-bottom: 1.15rem;
  }

  .case-hero-image {
    margin-top: 3rem;
    border-radius: 1.2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.5);
  }

  .case-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Challenge / Solution grid */
  .case-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .case-block {
    padding: 2.2rem;
  }

  .case-block h2 {
    font-size: 1.6rem;
    letter-spacing: -0.04em;
    margin: 0.8rem 0 1rem;
  }

  .case-block p {
    color: var(--text-gray);
    line-height: 1.75;
  }

  /* Features grid */
  .case-features-shell {
    padding-top: 0;
  }

  .case-features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .case-feature-card {
    padding: 1.8rem;
  }

  .case-feature-number {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--accent-blue);
    margin-bottom: 0.8rem;
  }

  .case-feature-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.7rem;
  }

  .case-feature-card p {
    color: var(--text-gray);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* Results band */
  .case-results {
    text-align: center;
  }

  .case-results .proof-grid {
    margin-top: 2rem;
  }

  .case-results-note {
    margin: 1rem auto 0;
    max-width: 62ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Visit CTA */
  .case-visit-shell {
    padding-top: 0;
  }

  .case-visit-band {
    text-align: center;
    padding: 3rem;
  }

  .case-visit-copy {
    max-width: 660px;
    margin: 0 auto;
  }

  .case-visit-copy .hero-actions {
    justify-content: center;
  }

  @media (max-width: 900px) {
    .case-grid,
    .case-features-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .case-visit-band {
      padding: 2rem 1.4rem;
    }
  }
</style>
