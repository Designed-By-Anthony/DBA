---
import InlineReport from "../../components/InlineReport.astro";
import Layout from "../../layouts/Layout.astro";

const pageTitle = "Website Audit Report and SEO Findings | Designed by Anthony";
const pageDescription =
	"View your website audit report with Lighthouse SEO, performance, accessibility, and conversion findings.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  noindex={true}
  minimalChrome={true}
>
  <div class="report-page-container">
    <div class="report-header no-print">
      <a href="/" class="back-link">&larr; Back to Designed by Anthony</a>
    </div>

    <!-- Loading State -->
    <div id="report-loading" class="report-loading isolate">
      <div class="lh-spinner"></div>
      <p>Locating report...</p>
    </div>

    <!-- Error State -->
    <div id="report-error" class="report-error isolate" hidden>
      <h2>Report Not Found</h2>
      <p>We couldn't find a report with that ID, or it may have been securely removed.</p>
      <a href="/free-seo-audit" class="btn btn-primary" style="margin-top: 1rem;">Run a New Audit</a>
    </div>

    <!-- The Report will unhide itself when dataset is filled -->
    <InlineReport />
    
  </div>
</Layout>

<script>
  type InlineReportInstance = HTMLElement & {
    setReportData: (data: Record<string, unknown>) => void;
  };

  (async function () {
    // Extract report ID from clean pathname (/report/DBA-XXXXXXXX)
    // Falls back to ?id= query param for backward compatibility
    const pathSegments = window.location.pathname.split('/').filter(Boolean);
    const pathId = pathSegments.length >= 2 && pathSegments[0] === 'report' ? pathSegments[1] : null;
    const queryId = new URLSearchParams(window.location.search).get('id');
    const reportId = pathId || queryId;

    const loadingEl = document.getElementById('report-loading');
    const errorEl = document.getElementById('report-error');
    const inlineReport = document.querySelector('inline-report') as InlineReportInstance | null;

    if (!reportId || !/^DBA-[A-Za-z0-9]{8}$/.test(reportId)) {
      document.title = 'Audit Report Not Found | Designed by Anthony';
      if (loadingEl) loadingEl.hidden = true;
      if (errorEl) errorEl.hidden = false;
      return;
    }

    // If the user arrived via ?id= param, push them to the clean URL without reload
    if (!pathId && queryId) {
      window.history.replaceState(null, '', `/report/${queryId}`);
    }

    try {
      const apiUrl = 'https://lighthouse-audit--lighthouse-492701.us-east4.hosted.app'; // Fallback in case env variable is missing
      const envUrl = typeof import.meta !== 'undefined' && import.meta.env ? import.meta.env.PUBLIC_API_URL : null;
      const baseUrl = envUrl || apiUrl;
      const res = await fetch(`${baseUrl}/api/report/${encodeURIComponent(reportId)}`);
      
      if (!res.ok) {
        throw new Error('Not found');
      }

      const data = await res.json();
      
      if (loadingEl) loadingEl.hidden = true;
      
      if (inlineReport) {
        inlineReport.setReportData({
          reportId: data.id,
          url: data.lead?.url || '',
          company: data.lead?.company || '',
          scores: data.scores,
          trustScore: data.scores?.trustScore,
          conversion: data.scores?.conversion,
          metrics: data.metrics,
          diagnostics: data.diagnostics,
          aiInsight: data.aiInsight,
          htmlSignals: data.htmlSignals,
          places: data.places,
          competitors: data.competitors,
          createdAt: data.createdAt,
        });

        // Dynamic OG meta for link previews
        const company = data.lead?.company || data.lead?.url || 'Website Audit Report';
        const trustScore = data.scores?.trustScore;
        document.title = `${company} Website Audit Report and SEO Findings | Designed by Anthony`;
        const ogTitle = document.querySelector('meta[property="og:title"]');
        if (ogTitle) ogTitle.setAttribute('content', `${company} — Trust Score: ${trustScore ?? 'N/A'}/100`);
        const ogDesc = document.querySelector('meta[property="og:description"]');
        if (ogDesc) ogDesc.setAttribute('content', `Digital Presence Audit by Designed by Anthony. Performance: ${data.scores?.performance ?? 'N/A'}, SEO: ${data.scores?.seo ?? 'N/A'}.`);
      }

    } catch (err) {
      console.error(err);
      document.title = 'Audit Report Not Found | Designed by Anthony';
      if (loadingEl) loadingEl.hidden = true;
      if (errorEl) errorEl.hidden = false;
    }
  })();
</script>

<style>
  .report-page-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem var(--container-gutter) 6rem;
  }

  .report-header {
    margin-bottom: 2rem;
  }

  .back-link {
    color: var(--text-gray);
    text-decoration: none;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text-white);
  }

  .report-loading, .report-error {
    text-align: center;
    padding: 4rem 1rem;
    background: var(--surface-1, #0d1320);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .lh-spinner {
    width: 3rem;
    height: 3rem;
    border: 3px solid rgba(59, 130, 246, 0.15);
    border-top-color: var(--accent-blue);
    border-radius: 50%;
    margin: 0 auto 1.5rem;
    animation: lh-spin 1s linear infinite;
  }

  @keyframes lh-spin {
    to { transform: rotate(360deg); }
  }

  .report-error h2 {
    color: #fca5a5;
    margin-top: 0;
  }

  .report-error p {
    color: var(--text-gray);
  }

  @media print {
    .report-page-container {
      padding: 0;
    }
  }
</style>
