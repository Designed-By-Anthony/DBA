---
import GbpRoiCalculator from "../../components/GbpRoiCalculator.astro";
import ServiceDetailPage from "../../components/ServiceDetailPage.astro";
import { evidenceLinks } from "../../data/evidence";
import { MONTHLY_LOCAL_SEO_PRICE } from "../../lib/offers";
import { buildServiceSchema } from "../../lib/seo";

const localSeoSources = [
	{
		...evidenceLinks.googleLocalBusiness,
		note: "Google documents how LocalBusiness structured data can communicate business details in a machine-readable way.",
	},
	{
		...evidenceLinks.googleBusinessProfileLocalRanking,
		note: "Google says local ranking depends on relevance, distance, and prominence, and that complete profile info and reviews help.",
	},
	{
		...evidenceLinks.googleBusinessProfileInfoSources,
		note: "Google explains that business information can come from the official site, users, and third-party sources.",
	},
	{
		...evidenceLinks.googleBusinessProfileReviews,
		note: "Google notes that review replies are public and help show that a business values feedback.",
	},
	{
		...evidenceLinks.googleBusinessProfileServices,
		note: "Google lets businesses manage services directly on the profile, which helps clarify what the business actually offers.",
	},
	{
		...evidenceLinks.googleMobileFirst,
		note: "Google uses the mobile version of a page for indexing.",
	},
	{
		...evidenceLinks.googlePageExperience,
		note: "Google recommends strong page experience and good Core Web Vitals.",
	},
];

/* Self-hosted Unsplash mirror — see /public/images/reference/ */
const serviceImage =
	"/images/reference/nisonco-pr-and-seo-yIRdUr6hIvQ-unsplash-5cd0e3bc-7b7b-4e95-abf3-152d21d0600f.png";
const serviceSchema = buildServiceSchema({
	name: "Local SEO and Search Visibility",
	description:
		"Technical local SEO and Google Business Profile work for service businesses — Designed by Anthony is a Merchynt agency partner.",
	path: "/services/local-seo",
	image: serviceImage,
	serviceType: "Local SEO",
});

const detailBlocks = [
	{
		title: "Helping Google understand your business",
		paragraphs: [
			"We add behind-the-scenes structure that tells Google exactly what your business does, what services you offer, and where you are located. This makes it easier for the right people to find you.",
		],
		supporting: [
			{
				level: "h4" as const,
				title: "Clear structure beats vague marketing copy",
				paragraphs: [
					"Search visibility improves when the site clearly explains your services, service areas, and supporting details instead of trying to say everything on one page.",
				],
			},
			{
				level: "h5" as const,
				title: "Schema fills in the details machines need",
				paragraphs: [
					"Structured data helps search engines connect your business entity, service pages, and location coverage without guessing.",
				],
			},
		],
	},
	{
		title: "Making your Google listing work harder",
		paragraphs: [
			"Your Google Business Profile needs to match your website. We make sure your business name, address, phone number, services, and categories line up so Google shows you to the right searchers.",
		],
		supporting: [
			{
				level: "h4" as const,
				title: "Consistency protects trust and rankings",
				paragraphs: [
					"If your site says one thing and your Google profile says another, the market notices and search engines do too. Alignment makes the business feel more established.",
				],
			},
			{
				level: "h5" as const,
				title: "The site and profile should reinforce each other",
				paragraphs: [
					"The best local SEO setups use the website to deepen credibility and the profile to win visibility, not treat them like separate marketing channels.",
				],
			},
		],
	},
	{
		title: "Merchynt agency partner — Google Business Profile in focus",
		paragraphs: [
			"We are an agency partner with Merchynt, which gives us access to tooling and workflows built for Google Business Profile growth, reviews, and local visibility. We pair that with hands-on strategy so your categories, services, and posts match what your website already claims.",
			"Your profile is a live channel: posts, photos, services, hours, and reviews all signal whether the business looks active and trustworthy. We treat GBP as ongoing work, not a one-time form fill.",
		],
		supporting: [
			{
				level: "h4" as const,
				title: "The listing and the site should tell one story",
				paragraphs: [
					"When Search and Maps surface your business, the next click is often your website. We keep messaging, offers, and service names aligned so customers do not get mixed signals between the profile and the site.",
				],
			},
		],
	},
	{
		title: "Pages built around what you do and where you do it",
		paragraphs: [
			"We build dedicated pages for each service you offer and each area you serve. That way, when someone searches for a plumber in Rome or a roofer in Utica, your page has a clearer chance to show up.",
		],
		supporting: [
			{
				level: "h4" as const,
				title: "Separate intent deserves separate pages",
				paragraphs: [
					"A broad catch-all page usually underperforms because it does not feel specific enough for the user or the search engine. Focused pages create better relevance.",
				],
			},
			{
				level: "h5" as const,
				title: "Internal linking turns pages into a system",
				paragraphs: [
					"When service pages and location pages are planned together, they strengthen each other instead of competing for the same vague keywords.",
				],
			},
		],
	},
	{
		title: "Why the work has to continue monthly",
		paragraphs: [
			"Local SEO is not a switch you flip once. Hours change, services expand, reviews come in, competitors publish new pages, and Google keeps comparing how complete and useful each business looks.",
			"That is why the monthly work matters. It keeps the Google Business Profile current, keeps the website supporting the profile, and keeps the business adding signals that feel active and trustworthy instead of stale.",
		],
		supporting: [
			{
				level: "h4" as const,
				title: "Directories are part of the foundation, not the whole strategy",
				paragraphs: [
					"Citation consistency still matters, but it is not the whole monthly package. We treat citation cleanup as setup work first, then light maintenance inside the retainer so the core business info stays aligned.",
				],
			},
			{
				level: "h5" as const,
				title: "Monthly SEO should create visible business assets",
				paragraphs: [
					"A healthy retainer should produce updates you can point to: profile improvements, review support, service pages, location pages, or offer pages that make the business stronger over time.",
				],
			},
		],
	},
];

const faqEntries = [
	{
		question: "What does local SEO actually change for a service business?",
		answer:
			"Local SEO helps Google understand what you do, where you work, and which pages should rank for each service or market. That usually means stronger visibility for nearby searches, cleaner service-area coverage, and a better chance of getting in front of buyers before they call a competitor.",
	},
	{
		question: "Is local SEO just setting up a Google Business Profile?",
		answer:
			"No. Your Google Business Profile matters, but it works best when the website supports it with strong service pages, location pages, internal links, and structured data. The profile brings attention, but the website is what proves relevance and trust once someone clicks. As a Merchynt agency partner, we also keep profile work aligned with modern local SEO practice — not outdated directory tricks.",
	},
	{
		question: "What does local SEO cost after the site is built?",
		answer: `Ongoing SEO maintenance is ${MONTHLY_LOCAL_SEO_PRICE} per month and includes hosting. That covers ongoing Google Business Profile work, review support, on-site local SEO updates, and one meaningful growth asset each month so the business keeps moving instead of treating SEO like a one-time setup.`,
	},
	{
		question:
			"Are directories and citations included in the monthly SEO package?",
		answer:
			"Core citation cleanup is best handled during setup or as a standalone one-time project when listings are messy. After that, light citation maintenance can sit inside the monthly package so the business information stays consistent without turning directory work into the entire SEO strategy.",
	},
];

const relatedAreas = [
	{
		title: "Web Design in Rome, NY",
		href: "/service-areas/rome",
		description:
			"See how a local page is structured for tighter service-area targeting in Oneida County.",
		tag: "Rome",
	},
	{
		title: "Web Design in Syracuse, NY",
		href: "/service-areas/syracuse",
		description:
			"Review how broader competition changes page structure, service framing, and local intent coverage.",
		tag: "Syracuse",
	},
	{
		title: "Web Design in Miami, FL",
		href: "/service-areas/miami",
		description:
			"See how local SEO strategy changes in a faster, multilingual market where mobile performance matters immediately.",
		tag: "Miami",
	},
];

const relatedArticles = [
	{
		title: "The Hidden Code That Gets Local Businesses Ranked",
		href: "/blog/local-business-schema",
		description:
			"See how schema helps connect business details, services, and service areas.",
		tag: "Schema",
	},
	{
		title: "Is Local SEO Dead? What Actually Works in 2025",
		href: "/blog/local-seo-death",
		description:
			"Learn which old local tactics stopped working and what stronger site structure looks like now.",
		tag: "SEO",
	},
	{
		title: "How to Fix Thin Content Without Nuking Your Rankings",
		href: "/blog/fix-thin-content",
		description:
			"Understand how to build topical depth without leaving weak location and service pages all over the site.",
		tag: "Content",
	},
	{
		title: "Why Monthly SEO Matters for Local Service Businesses",
		href: "/blog/why-monthly-seo-matters",
		description:
			"A clearer look at why local SEO needs monthly follow-through instead of a one-time setup only.",
		tag: "SEO",
	},
];

const pricingSection = {
	title: "How we structure local SEO work",
	intro:
		"The strongest local SEO setups usually separate one-time cleanup from ongoing monthly work so the business owner can see what is foundation and what is maintenance.",
	cards: [
		{
			label: "Local SEO Foundation",
			amount: "One-time",
			badge: "Best first step",
			description:
				"Used when the site, profile, and tracking need cleanup before a monthly retainer makes sense.",
			features: [
				"Google Business Profile cleanup and alignment",
				"Core citation and directory consistency work",
				"Tracking setup and review-link setup",
				"On-site local SEO fixes and service-area planning",
			],
		},
		{
			label: "Monthly SEO",
			amount: MONTHLY_LOCAL_SEO_PRICE,
			period: "/month",
			description:
				"Ongoing local SEO maintenance for businesses that want the website and profile to keep moving after launch.",
			features: [
				"Hosting included",
				"Google Business Profile updates and maintenance",
				"Review support and profile trust work",
				"One meaningful growth asset each month",
			],
			recommended: true,
		},
		{
			label: "Citation Cleanup",
			amount: "Standalone",
			description:
				"A one-time option when directories and business info need cleanup without a full monthly engagement.",
			features: [
				"Best for messy or inconsistent listings",
				"Good pre-work before monthly SEO begins",
				"Focused on consistency, not full growth strategy",
				"Can also be folded into a broader setup phase",
			],
		},
	],
};
---

<ServiceDetailPage
  title="Local SEO & Google Map Pack | Designed by Anthony"
  description="Local SEO and Map Pack for service businesses: GBP optimization, citations, schema, and on-page work. Merchynt partner."
  breadcrumbLabel="Local SEO"
  schema={serviceSchema}
  serviceNumber="05"
  heroTitle="Show Up When People Search for What You Do"
  heroDescription="We help service businesses get found on Google — including a stronger Google Business Profile in Search and Maps — by the people nearby who are already looking for what you offer."
  pricingNote={`SEO maintenance is ${MONTHLY_LOCAL_SEO_PRICE} per month and includes hosting.`}
  heroPills={['Google Business Profile + site in sync', 'Merchynt agency partner', 'Built for Maps and local Search']}
  image={serviceImage}
  imageAlt="Letter tiles spelling SEO on a wooden surface"
  imageWidth={1024}
  imageHeight={682}
  sectionTitle="How we get your business found on Google"
  sectionIntro="Local SEO works best when the website, the business profile, and the service-area strategy all support the same message."
  detailBlocks={detailBlocks}
  pricingSection={pricingSection}
  faqEntries={faqEntries}
  relatedAreas={relatedAreas}
  relatedArticles={relatedArticles}
  sourcesTitle="Why We Emphasize Structure"
  sourcesIntro="Here is the documentation behind the approach we use for local search."
  sourcesItems={localSeoSources}
  ctaTitle="Ready to start showing up when people search for what you do?"
  ctaDescription="Start with a free audit and I will show you exactly where you stand on Google and what needs to change first."
>
  <section class="gbp-mid section-shell" slot="mid-content">
    <div class="section-container">
      <div class="section-header centered service-detail-header">
        <p class="section-eyebrow">Google Business Profile</p>
        <h2>Model the upside, then tighten the listing</h2>
        <p>
          Use the calculator to stress-test what even a modest lift in daily customers could mean — then we align your Google Business Profile and website so they reinforce the same story in Search and Maps.
        </p>
      </div>
      <div class="gbp-mid-grid">
        <div class="surface-card gbp-mid-card reveal-up">
          <GbpRoiCalculator />
        </div>
        <aside class="gbp-mid-aside reveal-up">
          <div class="surface-card gbp-partner-card">
            <p class="card-tag">Partner program</p>
            <h3 class="gbp-partner-title">Merchynt agency partner</h3>
            <p class="gbp-partner-copy">
              Designed by Anthony is an agency partner with{' '}
              <a
                href="https://www.merchynt.com/agencies"
                class="gbp-partner-link"
                target="_blank"
                rel="noopener noreferrer"
                >Merchynt</a
              >
              — local SEO and Google Business Profile tooling built for agencies. We combine that stack with your website so Search, Maps, and your site tell one story. For the full
              managed program (reviews, citations, heatmaps, and more), see{' '}
              <a href="/services/google-business-profile" class="gbp-partner-link">Google Business Profile &amp; local marketing</a>.
            </p>
          </div>
          <figure class="gbp-mid-figure">
            <img
              src="/images/reference/stephen-phillips-hostreviews-co-uk-shr_Xn8S8QU-unsplash-8877f04d-e413-4d11-8d63-8d684794508d.png"
              alt="Google Search Console performance chart showing clicks and impressions over time"
              width={1024}
              height={624}
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              Strong local SEO shows up in tools like Search Console — more qualified visibility, not just a prettier homepage.
            </figcaption>
          </figure>
        </aside>
      </div>

      <div class="gbp-proof-block">
        <h3 class="gbp-proof-heading">Profiles, reviews, and local rank coverage</h3>
        <p class="gbp-proof-lede">
          Your listing should read as complete and active on the phone — the same place most “near me” searches happen — and your visibility story should eventually show up in reporting, not just anecdotes.
        </p>
        <div class="gbp-proof-grid">
          <figure class="gbp-proof-figure">
            <img
              src="/images/reference/gbp-ec0fbdb6-e973-4437-81a8-8b85d4552e83.png"
              alt="Illustration of a Google Business Profile on a smartphone with reviews and call-to-action buttons"
              width={1024}
              height={934}
              loading="lazy"
              decoding="async"
            />
            <figcaption>Strong GBPs combine photos, services, reviews, and clear actions so Search and Maps users know what to do next.</figcaption>
          </figure>
          <figure class="gbp-proof-figure">
            <img
              src="/images/reference/before_and_after-d11af747-4341-4ade-9c29-24e938cb8222.png"
              alt="Local search ranking grid comparing weaker rankings with improved Map Pack visibility across a region"
              width={1024}
              height={934}
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              Grid-style rank tracking shows whether you are winning the local pack in the neighborhoods that matter — not just vanity keywords on one block.
            </figcaption>
          </figure>
        </div>
      </div>

    </div>
  </section>
</ServiceDetailPage>

<style>
  .gbp-mid {
    padding-top: 0;
    padding-bottom: 0;
  }

  .gbp-mid .section-header h2 {
    font-size: clamp(1.65rem, 2.8vw, 2.15rem);
  }

  .gbp-mid-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 1.5rem;
    align-items: start;
  }

  .gbp-mid-card {
    padding: 1.75rem 1.85rem;
  }

  .gbp-mid-aside {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .gbp-partner-card {
    padding: 1.5rem 1.6rem;
  }

  .gbp-partner-title {
    margin: 0.5rem 0 0.65rem;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-cream);
    font-family: var(--font-display, 'Outfit Variable', system-ui, sans-serif);
  }

  .gbp-partner-copy {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-gray);
  }

  .gbp-partner-link {
    color: var(--accent-blue);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(91, 156, 248, 0.35);
  }

  .gbp-partner-link:hover {
    border-bottom-color: rgba(147, 197, 253, 0.65);
  }

  .gbp-mid-figure {
    margin: 0;
    padding: 0;
  }

  .gbp-mid-figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    border: 1px solid rgba(255, 252, 245, 0.08);
    box-shadow: var(--shadow-card);
  }

  .gbp-mid-figure figcaption {
    margin-top: 0.65rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  @media (max-width: 960px) {
    .gbp-mid-grid {
      grid-template-columns: 1fr;
    }
  }

  .gbp-proof-block {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 252, 245, 0.08);
  }

  .gbp-proof-heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.2rem, 2.2vw, 1.45rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    text-align: center;
    color: var(--text-cream);
    font-family: var(--font-display, 'Outfit Variable', system-ui, sans-serif);
  }

  .gbp-proof-lede {
    margin: 0 auto 1.5rem;
    max-width: 46rem;
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-gray);
  }

  .gbp-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .gbp-proof-figure {
    margin: 0;
  }

  .gbp-proof-figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    border: 1px solid rgba(255, 252, 245, 0.08);
    box-shadow: var(--shadow-card);
  }

  .gbp-proof-figure figcaption {
    margin-top: 0.65rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .gbp-proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
