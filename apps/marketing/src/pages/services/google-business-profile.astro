---
import Layout from '../../layouts/Layout.astro';
import { GBP_FULL_PROGRAM_MONTHLY_PRICE, MONTHLY_LOCAL_SEO_PRICE } from '../../lib/offers';
import {
  businessProfile,
  buildFaqPageSchema,
  buildLighthouseSoftwareApplicationSchema,
  buildServiceSchema,
  toAbsoluteUrl,
  type SchemaValue,
} from '../../lib/seo';

const heroImage = '/images/gbp-deck/1-d6f4eaf4-bb9d-40b3-8966-a06134fa1d7c.png';
/** Short loop (MP4) — ranking movement; poster keeps LCP fast before decode. */
const rankingImprovementVideo = '/images/gbp-deck/ranking-improvement.mp4';
const studioReelVideo = '/media/designed-by-anthony-showreel.mp4';
const heroW = 1024;
const heroH = 576;

const serviceSchema = buildServiceSchema({
  name: 'Google Business Profile & Local Marketing',
  description:
    'Complete local marketing for Google Business Profile, reviews, citations, AI visibility, and website alignment — Designed by Anthony, Merchynt agency partner.',
  path: '/services/google-business-profile',
  image: heroImage,
  serviceType: 'Google Business Profile',
});

const pageSchema: SchemaValue = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${toAbsoluteUrl('/services/google-business-profile')}#webpage`,
  url: toAbsoluteUrl('/services/google-business-profile'),
  name: 'Managed GBP & Local Marketing | Designed by Anthony',
  description:
    'Managed Google Business Profile with reviews, citations, reporting, and website alignment. Merchynt agency partner.',
  isPartOf: {
    '@id': `${toAbsoluteUrl('/')}#website`,
  },
};

const gbpFaqEntries = [
  {
    question: 'What is included in managed Google Business Profile work?',
    answer:
      'Ongoing profile optimization, review requesting and responses, posting where it helps, citation alignment, visibility reporting, and recommendations that keep your website and profile aligned.',
  },
  {
    question: 'How long does it take to see local ranking movement?',
    answer:
      'Most markets need steady execution; meaningful movement often shows within roughly ninety days, though competitive cities can take longer.',
  },
  {
    question: 'What does the Merchynt agency partnership mean for my business?',
    answer:
      'We run the same class of structured local program Merchynt uses with agency partners — adapted to your service area, offers, and review cadence.',
  },
  {
    question: 'Is this only for Google Search and Maps?',
    answer:
      'Google is the anchor, but the work considers your broader local footprint so business details stay consistent where customers find you.',
  },
];

const schemas = [
  pageSchema,
  serviceSchema,
  buildFaqPageSchema(gbpFaqEntries),
  buildLighthouseSoftwareApplicationSchema(),
];
---

<Layout
  title="Managed GBP & Local Marketing | Designed by Anthony"
  description="Managed Google Business Profile: reviews, citations, heatmaps, reporting, and site alignment. Merchynt agency partner."
  breadcrumbLabel="Google Business Profile"
  schema={schemas}
  footerCta={{
    eyebrow: 'Talk through your market',
    title: 'See whether this program fits',
    description:
      'Share your service area, your profile today, and what a strong month looks like. We will map a realistic plan before anything is locked in.',
    primaryHref: '/free-seo-audit',
    primaryLabel: 'Run the Free Audit',
    secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
    secondaryLabel: 'Book a 15-minute intro call',
  }}
>
  <section class="page-hero gbp-hero">
    <div class="page-hero-inner gbp-hero-grid">
      <div class="gbp-hero-copy">
        <p class="page-eyebrow">Google Business Profile · Merchynt agency partner</p>
        <h1>Local marketing that treats your profile like a channel — not a form you filled once</h1>
        <p>
          Most owners do not need more dashboards. They need calls and booked jobs. This program keeps your{' '}
          <strong>Google Business Profile</strong>, reviews, citations, and website working together — using the same kind of playbook we run as a{' '}
          <a href="https://www.merchynt.com/agencies" class="gbp-a" target="_blank" rel="noopener noreferrer">Merchynt</a> agency partner.
        </p>
        <div class="hero-meta-row">
          <span class="mini-pill">Ongoing management</span>
          <span class="mini-pill">Heatmaps &amp; reporting</span>
          <span class="mini-pill">Site + profile aligned</span>
        </div>
        <div class="hero-actions gbp-hero-actions">
          <a href="#gbp-studio-reel" class="btn btn-primary-book">Watch reel with sound</a>
          <a href="/contact" class="btn btn-outline">Talk strategy</a>
        </div>
      </div>
      <figure class="gbp-hero-fig reveal-up">
        <div class="gbp-hero-video-wrap">
          {/*
            No native poster: it flashes when the first decoded video frame differs from the PNG.
            Cover with an overlay image until playback actually starts.
          */}
          <video
            class="gbp-hero-video"
            width={heroW}
            height={heroH}
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-label="Local search ranking positions improving over time"
          >
            <source src={rankingImprovementVideo} type="video/mp4" />
          </video>
          <img
            class="gbp-hero-poster-overlay"
            src={heroImage}
            alt=""
            width={heroW}
            height={heroH}
            decoding="async"
            fetchpriority="high"
            aria-hidden="true"
          />
        </div>
      </figure>
    </div>
  </section>

  <section id="gbp-studio-reel" class="section-shell section-shell--editorial gbp-video-shell">
    <div class="section-container gbp-video-wrap reveal-up">
      <div class="section-header centered gbp-video-header">
        <p class="section-eyebrow section-eyebrow--pulse">Studio Reel</p>
        <h2>Watch the full Designed by Anthony reel with audio</h2>
        <p>The sound design and pacing are part of the story, so this one is presented as a standalone video.</p>
      </div>
      <div class="surface-card gbp-video-card">
        <video
          class="gbp-feature-video"
          controls
          playsinline
          preload="metadata"
          poster="/images/og-site-premium.png"
          aria-label="Designed by Anthony brand reel with audio"
        >
          <source src={studioReelVideo} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
        <p class="gbp-video-note">Best experienced with sound for the full brand feel.</p>
        <div class="hero-actions gbp-video-actions">
          <a
            href="https://calendly.com/anthony-designedbyanthony/web-design-consult?utm_source=gbp_reel&utm_medium=site&utm_campaign=video_strategy_call"
            class="btn btn-primary-book"
            data-calendar-link
          >
            Book a 15-minute intro call
          </a>
          <a href="/contact" class="btn btn-outline">Send project details</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="section-container gbp-narrow">
      <h2 class="gbp-h2">Why this exists</h2>
      <p class="gbp-lede">
        Local search is crowded: tools, AI noise, and half-finished profiles. The winning move is usually <strong>consistency</strong> — accurate business data everywhere it
        matters, a profile that gets updated, and a website that backs up what the listing promises. That is what this service is built to run.
      </p>
      <p class="gbp-lede">
        If you only need foundational monthly help on your site and profile (not the full stack below), see{' '}
        <a class="gbp-a" href="/services/local-seo">Local SEO</a> — including the {MONTHLY_LOCAL_SEO_PRICE}/month maintenance path with hosting.
      </p>
    </div>
  </section>

  <section class="section-shell gbp-band">
    <div class="section-container">
      <div class="section-header centered gbp-header">
        <p class="section-eyebrow">What you get</p>
        <h2>One program, one accountable owner</h2>
        <p>Everything below is coordinated so you are not juggling five vendors who disagree about your NAP or your categories.</p>
      </div>
      <div class="gbp-grid">
        <div class="surface-card gbp-card">
          <h3>Google Business Profile</h3>
          <p>Categories, services, attributes, posts, and media on a real cadence — not a one-time audit.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Reviews</h3>
          <p>Request flows, responses, and escalation when something needs attention from Google.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Citations</h3>
          <p>Directory coverage and sync so your core business data stays consistent where Google and AI systems look.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Website alignment</h3>
          <p>Schema, on-page recommendations, and content direction so your site supports the profile — not contradicts it.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Social rhythm</h3>
          <p>Posting where it makes sense for your market so the business looks active, not abandoned.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Video &amp; YouTube</h3>
          <p>Optimization and distribution help when video is part of your trust story.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>AI &amp; discovery</h3>
          <p>Entity clarity and structured data so assistants and AI surfaces have something reliable to read.</p>
        </div>
        <div class="surface-card gbp-card">
          <h3>Reporting</h3>
          <p>Before/after style maps and visibility reporting so you can see movement — not just hope.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="section-container gbp-split">
      <div>
        <h2 class="gbp-h2">How we work</h2>
        <ul class="gbp-work-list">
          <li>
            <span class="gbp-work-label">Fast onboarding</span>
            <span class="gbp-work-desc">Short access checklist and preferences; then execution starts.</span>
          </li>
          <li>
            <span class="gbp-work-label">Specific to your business</span>
            <span class="gbp-work-desc">Copy and offers written for you, not generic AI sludge.</span>
          </li>
          <li>
            <span class="gbp-work-label">Data-informed</span>
            <span class="gbp-work-desc">Strategies shaped by what works across large-scale GBP programs, not guesswork.</span>
          </li>
          <li>
            <span class="gbp-work-label">Multi-surface</span>
            <span class="gbp-work-desc">Google is the anchor, but we think about your whole local footprint.</span>
          </li>
          <li>
            <span class="gbp-work-label">Iterating</span>
            <span class="gbp-work-desc">When Google shifts, the work shifts. No frozen checklist from years ago.</span>
          </li>
        </ul>
      </div>
      <div class="surface-card gbp-price">
        <p class="card-tag">Investment</p>
        <p class="gbp-price-line">
          <span class="gbp-price-amt">{GBP_FULL_PROGRAM_MONTHLY_PRICE}</span><span class="gbp-price-unit">/month per location</span>
        </p>
        <p class="gbp-price-note">Scope is confirmed in writing before billing. Timeline to traction varies by market.</p>
        <ul class="trust-list gbp-price-list">
          <li>Full Google Business Profile management</li>
          <li>Review requesting and responses</li>
          <li>Social posting (where applicable)</li>
          <li>Video support &amp; YouTube optimization</li>
          <li>AI discovery guidance</li>
          <li>Website optimization recommendations</li>
          <li>50+ directory citations &amp; sync</li>
          <li>Heatmap-style tracking &amp; visibility reports</li>
        </ul>
        <p class="gbp-guarantee">
          <strong>Commitment:</strong> If ranking signals are not moving in the right direction after a reasonable window, we keep working the plan with you — the point is progress
          you can see, not a report for the drawer.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell gbp-steps-shell">
    <div class="section-container">
      <div class="section-header centered gbp-header">
        <p class="section-eyebrow">Getting started</p>
        <h2>Simple sequence</h2>
      </div>
      <div class="gbp-steps">
        <div class="surface-card gbp-step">
          <span class="gbp-step-n">1</span>
          <h3>Intake</h3>
          <p>Access, brand voice, priorities — usually a short session, not a homework marathon.</p>
        </div>
        <div class="surface-card gbp-step">
          <span class="gbp-step-n">2</span>
          <h3>Launch</h3>
          <p>Work begins on the profile and supporting surfaces without a long runway.</p>
        </div>
        <div class="surface-card gbp-step">
          <span class="gbp-step-n">3</span>
          <h3>Measure</h3>
          <p>Most markets need time; meaningful movement often shows within roughly 90 days of steady execution.</p>
        </div>
      </div>
      <p class="gbp-contact">
        Questions? <a class="gbp-a" href={`mailto:${businessProfile.email}`}>{businessProfile.email}</a> ·{' '}
        <a class="gbp-a" href={businessProfile.telephoneHref}>{businessProfile.telephone.replace('+1-', '')}</a>
      </p>
      <div class="hero-actions gbp-final-actions">
        <a href="/contact" class="btn btn-primary">Start a conversation</a>
        <a href="/portfolio" class="btn btn-outline">See example builds</a>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--editorial gbp-faq-shell">
    <div class="section-container">
      <div class="section-header centered gbp-faq-header">
        <p class="section-eyebrow">FAQ</p>
        <h2>Questions owners ask before starting</h2>
      </div>
      <div class="gbp-faq-list" data-faq-accordion>
        {gbpFaqEntries.map((entry) => (
          <div class="faq-item surface-card reveal-up">
            <button type="button" class="faq-trigger" aria-expanded="false">
              <span class="faq-icon" aria-hidden="true" />
              <span class="faq-title">{entry.question}</span>
            </button>
            <div class="faq-panel">
              <div class="faq-panel-inner">
                <div class="faq-content">
                  <p>{entry.answer}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function () {
    function initGbpHeroPoster() {
      var wrap = document.querySelector('.gbp-hero-video-wrap');
      if (!wrap || wrap.dataset.posterBound === '1') return;
      var video = wrap.querySelector('video');
      var overlay = wrap.querySelector('.gbp-hero-poster-overlay');
      if (!video || !overlay) return;
      wrap.dataset.posterBound = '1';
      function dismiss() {
        overlay.classList.add('is-dismissed');
        overlay.setAttribute('aria-hidden', 'true');
      }
      video.addEventListener('playing', dismiss, { once: true });
    }
    initGbpHeroPoster();
    document.addEventListener('astro:page-load', initGbpHeroPoster);
  })();
</script>

<style>
  .gbp-hero {
    padding-top: clamp(5rem, 10vw, 6.5rem);
    padding-bottom: 2rem;
  }

  .gbp-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 2rem;
    align-items: center;
  }

  .gbp-hero-copy h1 {
    font-size: clamp(1.85rem, 3.8vw, 2.55rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .gbp-hero-copy > p {
    color: var(--text-gray);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 38rem;
  }

  .gbp-hero-actions {
    margin-top: 1.2rem;
  }

  .gbp-a {
    color: var(--accent-blue);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(91, 156, 248, 0.35);
  }

  .gbp-a:hover {
    border-bottom-color: rgba(147, 197, 253, 0.65);
  }

  .gbp-hero-fig {
    margin: 0;
  }

  .gbp-hero-video-wrap {
    position: relative;
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 252, 245, 0.08);
    box-shadow: var(--shadow-card);
    background: rgba(15, 18, 24, 0.9);
  }

  .gbp-hero-video-wrap .gbp-hero-video {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: top;
  }

  .gbp-hero-poster-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .gbp-hero-poster-overlay.is-dismissed {
    opacity: 0;
  }

  .gbp-narrow {
    max-width: 720px;
    margin: 0 auto;
  }

  .gbp-video-shell {
    padding-top: clamp(3rem, 5vw, 4rem);
    padding-bottom: clamp(3rem, 5vw, 4rem);
  }

  .gbp-video-wrap {
    max-width: 980px;
    margin: 0 auto;
  }

  .gbp-video-header {
    max-width: 760px;
    margin-bottom: 1.35rem;
  }

  .gbp-video-card {
    padding: clamp(0.8rem, 1.8vw, 1rem);
  }

  .gbp-feature-video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.95rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: #020617;
  }

  .gbp-video-note {
    margin: 0.8rem 0 0;
    color: var(--text-gray);
    font-size: 0.88rem;
    letter-spacing: 0.01em;
  }

  .gbp-video-actions {
    margin-top: 1rem;
    justify-content: flex-start;
    gap: 0.65rem;
  }

  @media (max-width: 640px) {
    .gbp-video-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .gbp-video-actions .btn {
      width: 100%;
    }
  }

  .gbp-h2 {
    font-size: clamp(1.45rem, 2.5vw, 1.85rem);
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .gbp-lede {
    color: var(--text-gray);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .gbp-band {
    background: rgba(0, 0, 0, 0.18);
    border-block: 1px solid rgba(255, 252, 245, 0.06);
    padding-top: clamp(2.75rem, 5vw, 3.75rem);
    padding-bottom: clamp(2.75rem, 5vw, 3.75rem);
  }

  .gbp-header {
    max-width: 640px;
    margin: 0 auto 2rem;
  }

  .gbp-header p {
    color: var(--text-gray);
    line-height: 1.65;
  }

  .gbp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .gbp-card {
    padding: 1.35rem 1.45rem;
  }

  .gbp-card h3 {
    font-size: 1.08rem;
    margin: 0 0 0.5rem;
    color: var(--text-cream);
  }

  .gbp-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-gray);
    line-height: 1.5;
  }

  .gbp-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .gbp-work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.05rem;
  }

  .gbp-work-list li {
    display: grid;
    grid-template-columns: auto minmax(10.5rem, 13.25rem) minmax(0, 1fr);
    column-gap: 0.85rem;
    align-items: start;
  }

  .gbp-work-list li::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 25%, #fef9c3, var(--accent-blue));
    box-shadow: 0 0 0 1px rgba(201, 168, 108, 0.35);
    margin-top: 0.42rem;
    flex-shrink: 0;
  }

  .gbp-work-label {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-cream);
    line-height: 1.4;
  }

  .gbp-work-desc {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-gray);
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .gbp-work-list li {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.4rem;
    }

    .gbp-work-list li::before {
      grid-row: 1 / span 2;
      align-self: start;
      margin-top: 0.38rem;
    }

    .gbp-work-label {
      grid-column: 2;
    }

    .gbp-work-desc {
      grid-column: 2;
    }
  }

  .gbp-price {
    padding: 1.75rem 1.85rem;
  }

  .gbp-price-line {
    margin: 0.5rem 0 0.75rem;
  }

  .gbp-price-amt {
    font-size: clamp(2rem, 3vw, 2.45rem);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .gbp-price-unit {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-gray);
    margin-left: 0.25rem;
  }

  .gbp-price-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
    line-height: 1.45;
  }

  .gbp-price-list {
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .gbp-guarantee {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--text-soft);
    padding: 0.95rem 1rem;
    border-radius: 0.65rem;
    border: 1px solid rgba(147, 197, 253, 0.22);
    background: rgba(91, 156, 248, 0.06);
    margin: 0;
  }

  .gbp-steps-shell {
    padding-bottom: clamp(4rem, 8vw, 5.5rem);
  }

  .gbp-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .gbp-step {
    padding: 1.4rem 1.35rem;
  }

  .gbp-step-n {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(91, 156, 248, 0.15);
    color: var(--accent-blue);
    font-weight: 800;
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }

  .gbp-step h3 {
    font-size: 1.08rem;
    margin: 0 0 0.4rem;
  }

  .gbp-step p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-gray);
    line-height: 1.5;
  }

  .gbp-contact {
    text-align: center;
    color: var(--text-gray);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .gbp-final-actions {
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 960px) {
    .gbp-hero-grid,
    .gbp-split {
      grid-template-columns: 1fr;
    }

    .gbp-steps {
      grid-template-columns: 1fr;
    }
  }

  .gbp-faq-shell {
    padding-bottom: clamp(4rem, 8vw, 5.5rem);
  }

  .gbp-faq-header {
    margin-bottom: 1.5rem;
  }

  .gbp-faq-list {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gbp-faq-list .faq-item {
    overflow: hidden;
  }

  .gbp-faq-list .faq-trigger {
