---
import ServiceDetailPage from '../../components/ServiceDetailPage.astro';
import { buildServiceSchema } from '../../lib/seo';

const serviceImage =
  '/images/reference/daniel-korpai-vHVfpi3h5xk-unsplash-8e6f39c4-bb5b-4d68-aa5f-ed1a13a38149.png';
const serviceSchema = buildServiceSchema({
  name: 'Google Workspace Setup',
  description:
    'Professional business email and workspace administration setup so your business looks legitimate from day one.',
  path: '/services/workspace-setup',
  image: serviceImage,
  serviceType: 'IT Setup',
});

const detailBlocks = [
  {
    title: 'Look like a professional business from day one',
    paragraphs: [
      'Nothing kills trust faster than a generic @gmail.com or @yahoo.com email address when dealing with high-paying clients. We set up professional, branded domain email addresses (like you@yourbusiness.com) to instantly build credibility.',
      'Your customers notice. When an estimate comes from a branded email, it signals that the business is established, organized, and worth the investment.',
    ],
    supporting: [
      {
        level: 'h4' as const,
        title: 'Proper DNS and SPF/DKIM Authentication',
        paragraphs: [
          'We do not just set up the inbox. We configure the complex DNS records (SPF, DKIM, and DMARC) behind the scenes so your emails actually land in client inboxes, not their spam folders. This is the #1 deliverability fix most small businesses miss.',
        ],
      },
      {
        level: 'h5' as const,
        title: 'Domain protection included',
        paragraphs: [
          'DMARC policy prevents anyone from spoofing your business email address. That protects your reputation and gives email providers more reason to trust your messages.',
        ],
      },
    ],
  },
  {
    title: 'Centralized document management and security',
    paragraphs: [
      'Stop running your business out of a messy personal Google Drive. We set up Google Workspace so all your business files, client contracts, and essential assets are centrally stored, secure, and easily shareable.',
      'This means client proposals live in one shared place, not scattered across personal devices. If a phone gets lost or a laptop breaks, your business data is safe.',
    ],
    supporting: [
      {
        level: 'h4' as const,
        title: 'Built to scale',
        paragraphs: [
          'When it is time to hire a new employee or subcontractor, you can instantly provision a new secure email address and access permissions with total control over your business data.',
        ],
      },
      {
        level: 'h5' as const,
        title: 'Offboarding protection',
        paragraphs: [
          'When someone leaves, you revoke access in one click. Their work stays in the company Drive, and no client data walks out the door.',
        ],
      },
    ],
  },
  {
    title: 'Google Calendar and scheduling for teams',
    paragraphs: [
      'Google Workspace includes shared calendars that let you coordinate with team members, book client appointments, and share availability without the back-and-forth emails.',
      'We configure calendar sharing, default notification settings, and integrate it with your booking tools so scheduling just works.',
    ],
    supporting: [
      {
        level: 'h4' as const,
        title: 'One system, not five',
        paragraphs: [
          'Email, calendar, documents, video calls, and chat all live in one platform. No more juggling Outlook for email, Dropbox for files, and Zoom for meetings.',
        ],
      },
    ],
  },
  {
    title: 'Migration from your old system — handled',
    paragraphs: [
      'Already have years of email history in a personal Gmail account or old hosting provider? We migrate everything — emails, contacts, calendar events, and Drive files — into your new Google Workspace without losing anything.',
      'You pick a cutover date, and we handle the technical transition behind the scenes. Zero email downtime.',
    ],
    supporting: [
      {
        level: 'h4' as const,
        title: 'No technical knowledge required',
        paragraphs: [
          'You do not need to understand MX records, DNS propagation, or TXT verification. We handle the full backend setup so all you see is a clean, working inbox.',
        ],
      },
    ],
  },
];

const pricingSection = {
  title: 'Simple setup pricing',
  intro: 'One-time setup fee covers everything. Google Workspace subscription is paid separately to Google.',
  cards: [
    {
      label: 'Single User Setup',
      amount: '$149',
      description: 'Perfect for solo operators who need professional email and basic document storage.',
      features: [
        'Branded business email',
        'SPF, DKIM, DMARC configuration',
        'Google Drive setup',
        'Calendar configuration',
        'Email migration (if needed)',
      ],
    },
    {
      label: 'Team Setup',
      amount: '$299',
      badge: 'Best value',
      description: 'For businesses with 2–10 team members who need shared access, permissions, and centralized data.',
      features: [
        'Everything in Single User',
        'Multiple user provisioning',
        'Shared Drive and folder structure',
        'Team calendar configuration',
        'Access permissions and security',
        'Admin console walkthrough',
      ],
      recommended: true,
    },
  ],
};

const faqEntries = [
  {
    question: 'Do I have to pay Google separately?',
    answer:
      'Yes, Google Workspace is a paid subscription service provided directly by Google (starting around $7/user/month). We handle the complete technical setup, DNS configuration, and migration so you do not have to touch any of the complicated backend.',
  },
  {
    question: 'Can I keep my old emails?',
    answer:
      'Absolutely. We can migrate your old emails, contacts, and calendar events from your current personal or legacy business inbox directly into your new Google Workspace environment seamlessly. No email history is lost.',
  },
  {
    question: 'How long does the setup take?',
    answer:
      'Most single-user setups are completed within 1 to 2 business days. Team setups with multiple users and migrations typically take 3 to 5 business days depending on the volume of data being transferred.',
  },
  {
    question: 'Will my emails go to spam after the switch?',
    answer:
      'No. We configure SPF, DKIM, and DMARC authentication records specifically to prevent this. These are the industry-standard protocols that tell email providers your messages are legitimate. Most small businesses skip this step and wonder why their invoices end up in spam.',
  },
];

const relatedAreas = [
  {
    title: 'Web Design in Rome, NY',
    href: '/service-areas/rome',
    description: 'See how professional infrastructure supports a local service business that values trust and reliability.',
    tag: 'Rome',
  },
  {
    title: 'Web Design in Utica, NY',
    href: '/service-areas/utica',
    description: 'Look at how a branded email setup strengthens credibility in a price-sensitive local market.',
    tag: 'Utica',
  },
  {
    title: 'Web Design in Houston, TX',
    href: '/service-areas/houston',
    description: 'Explore why centralized business tools matter when scaling in a large metro area.',
    tag: 'Houston',
  },
];

const relatedArticles = [
  {
    title: '5 Things Wrong With Most Contractor Websites',
    href: '/blog/contractor-website-mistakes',
    description: 'See why a professional email address is just the start of a strong trust signal stack.',
    tag: 'Trust',
  },
  {
    title: 'Why Astro Is the Best Tech Stack for a Small Business Website',
    href: '/blog/astro-tech-stack',
    description: 'Understand why the right technical foundation matters for every aspect of your online presence.',
    tag: 'Tech Stack',
  },
  {
    title: 'How Site Speed Impacts Revenue',
    href: '/blog/site-speed-conversion',
    description: 'Learn why a lean, professional infrastructure protects your business beyond just the website.',
    tag: 'Performance',
  },
];

---

<ServiceDetailPage
  title="Google Workspace Setup & Admin | Designed by Anthony"
  description="Google Workspace and branded email setup: domains, secure storage, migration, SPF/DKIM, and deliverability basics."
  breadcrumbLabel="Workspace Setup"
  schema={serviceSchema}
  serviceNumber="07"
  heroTitle="Look Legitimate From Day One"
  heroDescription="We build out your professional Google Workspace, giving you branded email, secure cloud storage, and rock-solid email deliverability."
  pricingNote="Single user setup from $149. Team setup from $299. Google subscription paid separately."
  heroPills={['Branded business email', 'SPF/DKIM deliverability setup', 'Secure file management']}
  image={serviceImage}
  imageAlt="Desk with large monitor and laptop showing modern UI design work"
  imageWidth={819}
  imageHeight={1024}
  sectionTitle="Stop risking your business data on personal accounts"
  sectionIntro="A proper Google Workspace setup protects your client data, ensures your invoices don't go to spam, and makes your business look established."
  detailBlocks={detailBlocks}
  pricingSection={pricingSection}
  faqEntries={faqEntries}
  relatedAreas={relatedAreas}
  relatedArticles={relatedArticles}
  ctaTitle="Ready to upgrade your business infrastructure?"
  ctaDescription="Let's get your professional workspace set up correctly the first time. Start with the free audit and we'll assess the full picture."
/>
