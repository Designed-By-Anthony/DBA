  }

  .post-content p {
    font-size: 1.25rem;
    color: var(--text-gray);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .post-content strong {
    color: var(--text-white);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2.5rem;
    }
  }
</style>
