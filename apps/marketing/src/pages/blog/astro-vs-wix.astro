  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .post-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-white);
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .post-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content h4 {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.25rem;
    margin-bottom: 0.85rem;
  }

  .post-content h5 {
    font-size: 1.1rem;
    font-weight: 600;
