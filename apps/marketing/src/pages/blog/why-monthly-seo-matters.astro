  }

  .post-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content h4 {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.25rem;
    margin-bottom: 0.85rem;
  }

  .post-content p {
