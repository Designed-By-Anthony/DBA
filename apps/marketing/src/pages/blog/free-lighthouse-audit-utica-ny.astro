    margin-bottom: 1rem;
  }

  .post-header h1 {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--text-white);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .post-image {
    width: 100%;
    margin-bottom: 4rem;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-white);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .post-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content h4 {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-white);
    margin-top: 2.25rem;
    margin-bottom: 0.85rem;
  }

  .post-content h5 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent-blue);
    margin-top: 1.75rem;
    margin-bottom: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-content p {
    font-size: 1.25rem;
    color: var(--text-gray);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .post-content a {
    color: var(--accent-blue);
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .post-content a:hover {
    color: var(--text-white);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2.5rem;
    }
  }
</style>
