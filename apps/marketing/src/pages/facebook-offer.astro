---
import { Image } from 'astro:assets';
import AuditForm from '../components/AuditForm.astro';
import AuditProofTabs from '../components/AuditProofTabs.astro';
import {
  FACEBOOK_OFFER_CALENDLY_WITH_UTM,
  FACEBOOK_OFFER_SOCIAL_IMAGE,
  FACEBOOK_PRIVATE_OFFER_COPY,
  FACEBOOK_PRIVATE_WEBSITE_PRICE,
  FOUNDING_PARTNER_BUILD_SLOTS,
  FOUNDING_PARTNER_OFFER_SENTENCE,
  FOUNDING_PARTNER_PATH_CARD_SUMMARY,
  FOUNDING_PARTNER_SEO_LABEL,
  FOUNDING_PARTNER_SEO_MONTHLY,
  FOUNDING_PARTNER_WHY_SENTENCE,
  MONTHLY_LOCAL_SEO_PRICE,
  PRIVATE_FACEBOOK_LABEL,
  PUBLIC_PAYMENT_STRUCTURE_COPY,
  PUBLIC_PRICING_PILL,
  STANDARD_WEBSITE_STARTING_PRICE,
} from '../lib/offers';
import Layout from '../layouts/Layout.astro';
import { businessProfile } from '../lib/seo';
import fullLogo from '../assets/FullLogo.png';

const directEmailHref = `mailto:${businessProfile.email}?subject=${encodeURIComponent('Private Facebook Offer — review request')}`;

const offerPills = [
  `${PRIVATE_FACEBOOK_LABEL} · ${FACEBOOK_PRIVATE_WEBSITE_PRICE} invite rate`,
  `${FOUNDING_PARTNER_BUILD_SLOTS} launch pilot spots · ${FOUNDING_PARTNER_SEO_MONTHLY}/mo ${FOUNDING_PARTNER_SEO_LABEL}`,
  `${PUBLIC_PAYMENT_STRUCTURE_COPY}`,
];

const pathCards = [
  {
    eyebrow: 'Best if you qualify',
    title: 'Founding partner program',
    body: FOUNDING_PARTNER_PATH_CARD_SUMMARY,
    cta: 'Book a 15-minute intro call',
    href: FACEBOOK_OFFER_CALENDLY_WITH_UTM,
    isCalendly: true,
  },
  {
    eyebrow: 'Invite-only Facebook',
    title: `${FACEBOOK_PRIVATE_WEBSITE_PRICE} private build`,
    body: `${FACEBOOK_PRIVATE_OFFER_COPY} First 3 months of local SEO included, then ${MONTHLY_LOCAL_SEO_PRICE}/month if you want ongoing visibility.`,
    cta: 'Get a private review',
    href: '#claim-offer',
    isCalendly: false,
  },
];

const deliverables = [
  {
    tag: '01',
    title: 'A site that feels as serious as the business',
    copy:
      'Custom structure and copy—not a template skin—so the first click after Facebook feels intentional.',
  },
  {
    tag: '02',
    title: 'Performance you can feel on mobile',
    copy:
      'Lean Astro build, strong Lighthouse scores, and a calmer technical base than typical builder stacks.',
  },
  {
    tag: '03',
    title: 'Local SEO runway from day one',
    copy:
      'The first three months of local SEO are included so launch does not mean flat visibility.',
  },
  {
    tag: '04',
    title: 'Direct founder communication',
    copy:
      'You get a straight read on fit—whether this is a full build, a smaller cleanup, or a founder spot.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Send what people see today',
    copy: 'Facebook page, website, or both—whatever prospects land on after the ad.',
  },
  {
    n: '02',
    title: 'Get a clear read within 24 hours',
    copy: 'Anthony reviews and replies with the honest next step—no generic funnel.',
  },
  {
    n: '03',
    title: 'Move into build or call if it fits',
    copy: 'If a rebuild or founder spot makes sense, you get a direct path—book a short call when you are ready.',
  },
];

const facebookFooterCta = {
  eyebrow: 'Next step',
  title: 'See where your site stands in 60 seconds.',
  description:
    'Run the free Lighthouse audit, then book a founder review or strategy call when you are ready.',
  primaryHref: '/free-seo-audit',
  primaryLabel: 'Run the Free Audit',
  secondaryHref: FACEBOOK_OFFER_CALENDLY_WITH_UTM,
  secondaryLabel: 'Book a 15-minute intro call',
  note: 'Same engineering standard as every site we ship.',
};
---

<Layout
  title="Facebook Offer | Designed by Anthony"
  description={`Invite-only Facebook offer: founding partner builds, private ${FACEBOOK_PRIVATE_WEBSITE_PRICE} rate, or standard custom sites. Get a direct review of your current destination.`}
  image={FACEBOOK_OFFER_SOCIAL_IMAGE}
  hideBreadcrumbs={true}
  bodyClass="facebook-offer-page"
  noindex={true}
  footerCta={facebookFooterCta}
>
  <section class="page-hero page-hero--offer">
    <div class="page-hero-inner">
      <a href="/" class="facebook-offer-brand" aria-label="Designed by Anthony home">
        <Image
          src={fullLogo}
          alt="Designed by Anthony Logo"
          widths={[152, 304]}
          sizes="(max-width: 720px) 104px, 132px"
          width={152}
          class="facebook-offer-brand-image"
        />
      </a>

      <div class="hero-copy">
        <p class="page-eyebrow page-eyebrow--rule">{PRIVATE_FACEBOOK_LABEL}</p>
        <h1>
          Turn Facebook traffic into a <span class="text-blue">credible home</span>—not a rented first impression.
        </h1>
        <p class="lead-copy founding-partner-lead">
          <span class="founding-partner-lead-block">{FOUNDING_PARTNER_OFFER_SENTENCE}</span>
          <span class="founding-partner-lead-block">{FOUNDING_PARTNER_WHY_SENTENCE}</span>
          Prefer a private invite-only build? {FACEBOOK_PRIVATE_OFFER_COPY} Standard custom work starts at{' '}
          {STANDARD_WEBSITE_STARTING_PRICE} after launch allocations fill.
        </p>

        <div class="hero-actions">
          <a href="/free-seo-audit" class="btn btn-primary-audit" data-facebook-offer-cta="hero-audit">Run the Free Audit</a>
          <a
            href={FACEBOOK_OFFER_CALENDLY_WITH_UTM}
            class="btn btn-primary-book"
            data-calendar-link
            data-facebook-offer-cta="hero-calendly"
          >
            Book a 15-minute intro call
          </a>
        </div>

        <div class="hero-meta-row facebook-offer-pills">
          {offerPills.map((pill) => (
            <span class="mini-pill">{pill}</span>
          ))}
        </div>

        <div class="hero-trust-strip reveal-up">
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Founder-led replies</span>
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3c-3.87 0-7 3.13-7 7s3.13 7 7 7 7-3.13 7-7-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>24-hour review turnaround</span>
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2l1.5 4.5H16l-3.7 2.7 1.4 4.3L10 11l-3.7 2.5 1.4-4.3L4 6.5h4.5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            <span>{PUBLIC_PRICING_PILL}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--proof facebook-offer-stats-shell">
    <div class="section-container">
      <div class="facebook-offer-stat-row reveal-up">
        <article class="surface-card surface-card--proof facebook-offer-stat-card">
          <p class="facebook-offer-stat-label">Private invite</p>
          <p class="facebook-offer-stat-value">{FACEBOOK_PRIVATE_WEBSITE_PRICE}</p>
          <p class="facebook-offer-stat-meta">Flat website build on this offer</p>
        </article>
        <article class="surface-card surface-card--proof facebook-offer-stat-card">
          <p class="facebook-offer-stat-label">Founding partners</p>
          <p class="facebook-offer-stat-value">{FOUNDING_PARTNER_BUILD_SLOTS}</p>
          <p class="facebook-offer-stat-meta">Complimentary builds + {FOUNDING_PARTNER_SEO_LABEL}</p>
        </article>
        <article class="surface-card surface-card--proof facebook-offer-stat-card">
          <p class="facebook-offer-stat-label">Standard</p>
          <p class="facebook-offer-stat-value">{STANDARD_WEBSITE_STARTING_PRICE}</p>
          <p class="facebook-offer-stat-meta">Custom builds after launch</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--technical">
    <div class="section-container">
      <div class="section-header centered">
        <p class="section-eyebrow section-eyebrow--pulse">How to enter</p>
        <h2>Two paths. One standard of work.</h2>
        <p>
          This page is for people who found us through Facebook—whether you want the limited founding partner allocation or the private invite-only build rate.
        </p>
      </div>

      <div class="facebook-offer-path-grid">
        {pathCards.map((card) => (
          <article class="surface-card surface-card--technical facebook-offer-path-card reveal-up">
            <p class="section-eyebrow">{card.eyebrow}</p>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
            <div class="hero-actions facebook-offer-path-actions">
              {card.isCalendly ? (
                <a href={card.href} class="btn btn-primary-book" data-calendar-link data-facebook-offer-cta="path-calendly">
                  {card.cta}
                </a>
              ) : (
                <a href={card.href} class="btn btn-primary-audit" data-facebook-offer-cta="path-review">
                  {card.cta}
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--editorial section-shell--wash">
    <div class="section-container facebook-offer-split">
      <div class="facebook-offer-split-copy reveal-up">
        <p class="section-eyebrow">Private review</p>
        <h2>A direct read on what customers see after the click.</h2>
        <p>
          Send the Facebook page or the site people land on today. I will tell you whether the fit is a full rebuild, the founder program, the private invite rate, or a smaller cleanup.
        </p>
        <ul class="trust-list">
          <li>No website yet is fine—send the Facebook URL if that is the main destination.</li>
          <li>About 60 seconds of your time. No phone call required to start.</li>
          <li>Reply within 24 hours from Anthony, not a sequence.</li>
        </ul>
        <div class="hero-actions">
          <a href={FACEBOOK_OFFER_CALENDLY_WITH_UTM} class="btn btn-primary-book" data-calendar-link data-facebook-offer-cta="split-calendly">
            Prefer a call first?
          </a>
          <a href={directEmailHref} class="btn btn-outline" data-facebook-offer-cta="split-email">
            Email {businessProfile.email}
          </a>
        </div>
      </div>

      <aside class="surface-card surface-card--editorial facebook-offer-form-card reveal-up" id="claim-offer">
        <div class="facebook-offer-form-top">
          <span class="card-tag">Request</span>
          <span class="facebook-offer-form-note">Private review</span>
        </div>
        <h2>Get a private review of your current destination.</h2>
        <p class="facebook-offer-form-lede">
          Share the Facebook page or website people see now. You will get a direct recommendation on next steps.
        </p>

        <AuditForm
          ctaSource="facebook-offer-page"
          pageContext="facebook_offer_landing"
          pageTitle="Facebook Offer | Designed by Anthony"
          offerType="facebook_growth_offer"
          subjectLine="Facebook Offer Request | Designed by Anthony"
          submitLabel="Submit for private review"
          successTag="Private Review Requested"
          successTitle="Request received"
          successMessage="Anthony will review your link and reply within 24 hours with the clearest next step."
          successPoints={[
            'I review the Facebook page or site and the trust it creates.',
            'I confirm fit for founder program, private invite rate, or a smaller fix.',
            'You hear directly from Anthony—no generic sequence.',
          ]}
          successLinkHref="/portfolio"
          successLinkLabel="View portfolio"
          metaMessage="No spam. A founder reply within 24 hours."
          websiteLabel="Facebook page or website URL"
          websitePlaceholder="facebook.com/yourbusiness or yourwebsite.com"
          issueLabel="What should the next version do better?"
          issuePlaceholder="Feel more established, load faster, match the quality of the work..."
          issueRequired={false}
          showPhoneField={false}
        />

        <div class="facebook-offer-direct-email">
          <span class="card-tag">Email instead</span>
          <p>
            Send the link to
            <a href={directEmailHref} data-facebook-offer-cta="form-email">{businessProfile.email}</a>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell section-shell--technical">
    <div class="section-container">
      <div class="section-header centered">
        <p class="section-eyebrow">What you get</p>
        <h2>Built for businesses that already earn attention.</h2>
        <p>Enough substance to change how the business is perceived online—without a bloated agency package.</p>
      </div>

      <div class="facebook-offer-value-grid">
        {deliverables.map((d) => (
          <article class="surface-card surface-card--technical facebook-offer-value-card reveal-up">
            <span class="card-tag">{d.tag}</span>
            <h3>{d.title}</h3>
            <p>{d.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--proof">
    <div class="section-container">
      <div class="section-header centered">
        <p class="section-eyebrow section-eyebrow--pulse">How it works</p>
        <h2>Simple process. Direct communication.</h2>
      </div>
      <div class="facebook-offer-steps">
        {steps.map((s) => (
          <article class="surface-card surface-card--proof facebook-offer-step reveal-up">
            <span class="facebook-offer-step-n">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <AuditProofTabs
    variant="premium"
    eyebrow="Proof"
    title="The technical gap we close when the destination is heavier than it needs to be."
    description="Both examples are mobile Lighthouse runs captured in Chrome private mode on the same machine."
    beforeBadge="Typical baseline"
    beforeHeading="More moving parts. Less confidence."
    beforeDescription="Common builder-heavy sites: slower loading, weaker accessibility, and more technical drag than most owners realize."
    afterBadge="Cleaner benchmark"
    afterHeading="Leaner system. Stronger first impression."
    afterDescription="A faster, more deliberate site that supports trust and conversion—not just a score."
  />

  <section class="section-shell section-shell--editorial facebook-offer-final">
    <div class="section-container">
      <div class="surface-card surface-card--editorial facebook-offer-final-card reveal-up">
        <p class="section-eyebrow section-eyebrow--pulse">Ready</p>
        <h2>If Facebook is the first touch, the next step should feel intentional.</h2>
        <p>
          Submit a link for review, run the free audit, or book a short call—same standard of work either way.
        </p>
        <div class="hero-actions">
          <a href="/free-seo-audit" class="btn btn-primary-audit" data-facebook-offer-cta="final-audit">Run the Free Audit</a>
          <a
            href={FACEBOOK_OFFER_CALENDLY_WITH_UTM}
            class="btn btn-primary-book"
            data-calendar-link
            data-facebook-offer-cta="final-calendly"
          >
            Book a 15-minute intro call
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  body.facebook-offer-page main {
    padding-top: 0;
  }

  body.facebook-offer-page .audit-proof-shell {
    padding-top: clamp(2rem, 4vw, 3rem);
  }
</style>

<style>
  .page-hero--offer {
    padding-top: clamp(5.5rem, 8vw, 6.5rem);
  }

  .page-hero--offer .page-hero-inner {
    max-width: min(var(--content-max), 100%);
  }

  .facebook-offer-brand {
    display: inline-flex;
    margin-bottom: 1.25rem;
  }

  .facebook-offer-brand-image {
    width: clamp(112px, 15vw, 132px);
    height: auto;
  }

  .founding-partner-lead .founding-partner-lead-block {
    display: block;
    margin-bottom: 0.85rem;
  }

  .facebook-offer-pills {
    margin-top: 1.35rem;
  }

  .facebook-offer-stats-shell {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .facebook-offer-stat-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .facebook-offer-stat-card {
    padding: 1.35rem 1.25rem;
    text-align: center;
  }

  .facebook-offer-stat-label {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.95);
  }

  .facebook-offer-stat-value {
    margin: 0.5rem 0 0.45rem;
    font-family: var(--font-display);
    font-size: clamp(1.95rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text-cream);
    line-height: 1;
  }

  .facebook-offer-stat-meta {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-gray);
    line-height: 1.45;
  }

  .facebook-offer-path-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .facebook-offer-path-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .facebook-offer-path-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .facebook-offer-path-card p {
    color: var(--text-gray);
    line-height: 1.72;
    margin: 0;
    flex-grow: 1;
  }

  .facebook-offer-path-actions {
    margin-top: 0.5rem;
  }

  .facebook-offer-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
  }

  .facebook-offer-split-copy h2 {
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3.5vw, 2.75rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin: 0.5rem 0 0.85rem;
  }

  .facebook-offer-split-copy > p {
    color: var(--text-gray);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .facebook-offer-form-card {
    padding: 1.75rem;
    scroll-margin-top: 1.25rem;
  }

  .facebook-offer-form-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .facebook-offer-form-note {
    color: var(--text-muted);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .facebook-offer-form-card h2 {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.8vw, 2.2rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 0.65rem;
  }

  .facebook-offer-form-lede {
    color: var(--text-gray);
    line-height: 1.72;
    margin-bottom: 1.25rem;
  }

  .facebook-offer-direct-email {
    margin-top: 1.25rem;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: grid;
    gap: 0.5rem;
  }

  .facebook-offer-direct-email p {
    margin: 0;
    color: var(--text-gray);
    font-size: 0.9rem;
  }

  .facebook-offer-direct-email a {
    color: #bfdbfe;
    font-weight: 700;
  }

  .facebook-offer-value-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .facebook-offer-value-card {
    padding: 1.5rem;
  }

  .facebook-offer-value-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 0.45rem;
  }

  .facebook-offer-value-card p {
    color: var(--text-gray);
    margin: 0;
    line-height: 1.7;
  }

  .facebook-offer-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .facebook-offer-step {
    padding: 1.35rem;
  }

  .facebook-offer-step-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.28);
    color: #86efac;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .facebook-offer-step h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin: 0.85rem 0 0.45rem;
    letter-spacing: -0.03em;
  }

  .facebook-offer-step p {
    color: var(--text-gray);
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .facebook-offer-final {
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  .facebook-offer-final-card {
    padding: clamp(1.75rem, 3vw, 2.35rem);
    text-align: center;
  }

  .facebook-offer-final-card h2 {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    letter-spacing: -0.04em;
    margin: 0.5rem auto 0.85rem;
    max-width: 22ch;
  }

  .facebook-offer-final-card > p {
    color: var(--text-gray);
    max-width: 52ch;
    margin: 0 auto 1.25rem;
    line-height: 1.72;
  }

  .facebook-offer-final-card .hero-actions {
    justify-content: center;
  }

  @media (min-width: 981px) {
    .facebook-offer-form-card {
      position: sticky;
      top: 1.2rem;
    }
  }

  @media (max-width: 900px) {
    .facebook-offer-stat-row,
    .facebook-offer-path-grid,
    .facebook-offer-split,
    .facebook-offer-value-grid,
    .facebook-offer-steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .facebook-offer-final-card .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .facebook-offer-final-card .hero-actions .btn {
      width: 100%;
    }
  }
</style>
