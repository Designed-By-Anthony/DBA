---
import Layout from '../layouts/Layout.astro';
import FeedSubscribeCluster from '../components/FeedSubscribeCluster.astro';
import { buildItemListSchema } from '../lib/seo';
import { blogPosts } from '../data/blogPosts';

const sortedBlogPosts = [...blogPosts].sort(
  (a, b) => new Date(b.publishedTime).getTime() - new Date(a.publishedTime).getTime(),
);

const blogSchema = buildItemListSchema({
  name: 'The Main Street Blog',
  description: 'Insights, updates, and technical deep-dives on web design for Main Street America.',
  path: '/blog',
  items: sortedBlogPosts.map((post) => ({
    name: post.title,
    url: post.url,
    description: post.excerpt,
    image: post.image,
  })),
});

const blogFooterCta = {
  eyebrow: 'See How Your Site Stacks Up',
  title: 'Run our free Lighthouse audit and see your scores instantly.',
  description:
    'Enter any URL into our in-house scanner and get instant performance, accessibility, best practices, and SEO scores. No signup. No waiting.',
  primaryHref: '/free-seo-audit',
  primaryLabel: 'Run the Free Audit',
  secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
  secondaryLabel: 'Book a 15-minute intro call',
  note: 'Instant results and direct guidance when you want a second opinion.',
};
---

<Layout
  title="Web Design & Local SEO Blog | Designed by Anthony"
  description="Practical web design, local SEO, Google Map Pack, and site speed advice for small service businesses that want their website to actually bring in calls."
  pageType="CollectionPage"
  image={sortedBlogPosts[0].image}
  schema={blogSchema}
  footerCta={blogFooterCta}
>
  <section class="page-header">
    <div class="header-content">
      <h1>The Main Street Blog</h1>
      <p>Web design, web development, local SEO, and Google Map Pack advice built for small service businesses that want their website to bring in more calls.</p>
      <FeedSubscribeCluster
        eyebrow="Subscribe"
        title="Follow new articles and launches without relying on social algorithms."
        description="Subscribe to the blog feed for new SEO and web design articles, or follow the releases feed if you want to track new client launches and public work."
        primaryHref="/rss.xml"
        primaryLabel="Open Blog Feed (XML)"
        secondaryHref="/releases.xml"
        secondaryLabel="Open Releases Feed (XML)"
      />
    </div>
  </section>

  <section class="blog-section">
    <div class="blog-container">
      {sortedBlogPosts.map(post => (
        <article class="blog-card reveal-up">
          <div class="blog-image">
            <img
              src={post.image}
              alt={post.imageAlt || post.title}
              width={post.imageWidth}
              height={post.imageHeight}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="blog-content">
            <div class="blog-meta">
              <span>{post.displayDate}</span>
              <span class="dot">|</span>
              <span>{post.readTime}</span>
            </div>
            <h2><a href={post.url} data-blog-post-link>{post.title}</a></h2>
            <p>{post.excerpt}</p>
            <a href={post.url} class="read-more" data-blog-post-link>Read Full Article</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    position: relative;
    overflow: hidden;
    padding: clamp(7rem, 10vw, 8.25rem) var(--container-gutter) clamp(4.75rem, 7vw, 6rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(91, 156, 248, 0.12), transparent 32%),
      radial-gradient(circle at 82% 12%, rgba(201, 168, 108, 0.06), transparent 28%),
      linear-gradient(180deg, rgba(5, 7, 12, 0.97) 0%, rgba(10, 13, 20, 0.95) 100%);
  }

  .header-content {
    position: relative;
    z-index: 1;
    width: min(var(--content-max), 100%);
    max-width: 860px;
    margin: 0 auto;
  }

  .header-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-bottom: 1rem;
    color: var(--text-cream);
  }

  .header-content p {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--text-gray);
    line-height: 1.78;
    max-width: 64ch;
    margin-left: auto;
    margin-right: auto;
  }

  .header-content :global(.feed-subscribe-shell) {
    text-align: left;
    max-width: 760px;
    margin: 2.25rem auto 0;
  }

  .blog-section {
    padding: var(--section-space) var(--container-gutter);
  }

  .blog-container {
    max-width: var(--content-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr));
    gap: 1.25rem;
  }

  .blog-card {
    background:
      linear-gradient(165deg, rgba(14, 18, 28, 0.97) 0%, rgba(18, 24, 36, 0.93) 100%);
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    position: relative;
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-card);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 28px 68px -36px rgba(2, 6, 23, 0.92);
    border-color: rgba(255, 252, 245, 0.1);
  }

  .blog-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #000;
  }

  .blog-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .blog-card:hover .blog-image img {
    transform: scale(1.02);
  }

  .blog-content {
    padding: clamp(1.35rem, 3vw, 1.75rem);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
  }

  .blog-meta span {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .blog-meta span:first-child,
  .blog-meta span:last-child {
    color: rgba(191, 219, 254, 0.82);
  }

  .dot {
    color: var(--text-gray);
    opacity: 0.4;
  }

  .blog-content h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.55rem;
    line-height: 1.2;
  }

  .blog-content h2 a {
    color: var(--text-white);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .blog-content h2 a::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .blog-content h2 a:hover {
    color: var(--accent-blue);
  }

  .blog-content p {
    color: var(--text-gray);
    font-size: 0.98rem;
    line-height: 1.72;
    margin-bottom: 0.9rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-weight: 700;
    color: #bfdbfe;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .read-more:hover {
    color: var(--accent-blue);
  }

  @media (max-width: 768px) {
    .blog-container {
      grid-template-columns: 1fr;
    }
  }
</style>
