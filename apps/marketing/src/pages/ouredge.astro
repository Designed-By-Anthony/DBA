---
import Layout from '../layouts/Layout.astro';
import ConsumerTrustStack from '../components/ConsumerTrustStack.astro';
import SourceList from '../components/SourceList.astro';
import { evidenceLinks } from '../data/evidence';
import { buildItemListSchema } from '../lib/seo';

const comparisonSources = [
  {
    ...evidenceLinks.astroWhy,
    note: 'Astro positions itself as content-driven, server-first, and zero JavaScript by default.',
  },
  {
    ...evidenceLinks.astroPrerender,
    note: 'Astro prerenders static HTML by default when a route does not need server rendering.',
  },
  {
    ...evidenceLinks.googlePageExperience,
    note: 'Google ties strong page experience to mobile usability and Core Web Vitals.',
  },
  {
    ...evidenceLinks.wordpressUpdates,
    note: 'WordPress projects typically involve ongoing plugin and theme update management.',
  },
  {
    ...evidenceLinks.wixThirdPartyCode,
    note: 'Wix documents that third-party code can affect loading time and performance.',
  },
  {
    ...evidenceLinks.dudaCoreWebVitals,
    note: 'Duda notes that some default platform code cannot be removed.',
  },
];

const edgeCards = [
  {
    title: 'Faster load times',
    description: 'Pages are built to feel immediate on mobile, which protects trust before the visitor has even read the offer.',
  },
  {
    title: 'Less to break after launch',
    description: 'No plugin maze, no fragile theme stack, and far less maintenance drag after the site is live.',
  },
  {
    title: 'Built to rank on Google',
    description: 'Cleaner structure, stronger technical foundations, and pages that are easier for Google to understand.',
  },
];

const benchmarkItems = [
  { value: '98+', label: 'Performance' },
  { value: '98+', label: 'Accessibility' },
  { value: '98+', label: 'Best Practices' },
  { value: '98+', label: 'SEO' },
];

const edgePrinciples = [
  {
    tag: '01',
    title: 'The first impression has to feel expensive',
    description:
      'A premium site is not just about color and typography. It is about how quickly the page settles, how clear the message feels, and how confidently the business is presented on the first screen.',
  },
  {
    tag: '02',
    title: 'The technical foundation should stay calm',
    description:
      'Heavy builders usually create too many moving parts. We strip that down so the experience feels cleaner to visitors and easier to manage after launch.',
  },
  {
    tag: '03',
    title: 'The site should support sales, not just aesthetics',
    description:
      'The edge is not design for other designers. The edge is helping the business feel more credible, easier to understand, and easier to contact.',
  },
];

const edgeSystemRows = [
  {
    title: 'Design',
    standard: 'Template-first layouts that can look decent but rarely feel specific to the business.',
    dba: 'Custom presentation shaped around the business, the objections buyers have, and the action you want them to take.',
  },
  {
    title: 'Performance',
    standard: 'Extra scripts, plugin overhead, and more front-end drag than most owners ever see.',
    dba: 'A leaner front end built to load faster, feel steadier on mobile, and stay out of the visitor’s way.',
  },
  {
    title: 'SEO foundation',
    standard: 'Basic settings switched on, but not much thought put into structure, internal linking, or local clarity.',
    dba: 'Pages and site architecture built to support local intent, service clarity, and long-term expansion.',
  },
  {
    title: 'Ownership',
    standard: 'A handoff into a stack of third-party dependencies most business owners never wanted in the first place.',
    dba: 'A founder-led build with direct accountability and a much clearer understanding of what is actually running.',
  },
];

const edgeSchema = buildItemListSchema({
  name: 'Technical Advantages',
  description:
    'The technical advantages Designed by Anthony emphasizes across build quality, performance, security, and SEO structure.',
  path: '/ouredge',
  items: edgeCards.map((card) => ({
    name: card.title,
    url: '/ouredge',
    description: card.description,
  })),
});

const edgeFooterCta = {
  eyebrow: 'Free Website Audit',
  title: 'Want to see whether your current site feels as strong as the business behind it?',
  description:
    'Request the free audit and I will show you what is slowing your site down, what is hurting your Google visibility, and whether the right move is a tune-up or a rebuild.',
  primaryHref: '/contact',
  primaryLabel: 'See How Your Site Compares',
  secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
  secondaryLabel: 'Book a 15-minute intro call',
};
---

<Layout
  title="Our Edge — Web Development Advantage | Designed by Anthony"
  description="See why our web design company uses a performance-first development stack and how those technical choices support better business outcomes."
  pageType="AboutPage"
  schema={edgeSchema}
  footerCta={edgeFooterCta}
>
  <section class="page-hero centered">
    <div class="page-hero-inner edge-hero">
      <p class="page-eyebrow">Our Edge</p>
      <h1>Why our websites load faster, rank higher, and get more people to call.</h1>
      <p>
        We approach web design and development differently than most companies, and the difference shows up in how the business feels online: cleaner, sharper, and easier to trust from the first touch.
      </p>
      <div class="hero-actions edge-hero-actions">
        <a href="/portfolio" class="btn btn-primary">See the Difference in our Portfolio</a>
      </div>
      <div class="hero-meta-row edge-meta-row">
        <span class="mini-pill">Founder-led builds</span>
        <span class="mini-pill">98+ Lighthouse targets</span>
        <span class="mini-pill">Built for service businesses</span>
      </div>
    </div>
  </section>

  <ConsumerTrustStack variant="compact" />

  <section class="section-shell">
    <div class="section-container">
      <div class="feature-grid edge-grid">
        {edgeCards.map((card) => (
          <div class="surface-card feature-card reveal-up">
            <div class="card-tag">Technical Advantage</div>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell edge-principles-shell">
    <div class="section-container">
      <div class="section-header centered edge-header">
        <p class="section-eyebrow">What That Means</p>
        <h2>The advantage is not one trick. It is a stack of better decisions.</h2>
        <p>
          When the design, the code, and the structure all support the same goal, the site feels more premium without relying on gimmicks.
        </p>
      </div>
      <div class="feature-grid edge-grid">
        {edgePrinciples.map((item) => (
          <article class="surface-card feature-card reveal-up edge-principle-card">
            <div class="card-tag">{item.tag}</div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
      <div class="hero-actions edge-section-actions">
        <a href="/contact" class="btn btn-outline">Ready to upgrade your web presence? Let's talk.</a>
      </div>
    </div>
  </section>

  <section class="section-shell edge-benchmark-shell">
    <div class="section-container">
      <div class="proof-band">
        <div class="section-header centered edge-header">
          <p class="section-eyebrow">Google Lighthouse Scores</p>
          <h2>98+ across the core Lighthouse categories.</h2>
          <p>Google Lighthouse measures how fast, accessible, and well-built your site is. Most websites score in the 40s and 50s. Ours are built to land at 98+ across the board.</p>
        </div>
        <div class="proof-grid">
          {benchmarkItems.map((item) => (
            <div class="proof-item reveal-up">
              <span class="proof-value">{item.value}</span>
              <span class="proof-label">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell edge-system-shell">
    <div class="section-container">
      <div class="section-header centered edge-header">
        <p class="section-eyebrow">Why It Feels Different</p>
        <h2>Where the usual website stack drifts, and where we keep it tighter.</h2>
        <p>
          Most of the gap comes from avoiding the usual technical clutter and being more deliberate about the experience from the beginning.
        </p>
      </div>

      <div class="surface-card edge-system-card reveal-up">
        {edgeSystemRows.map((row) => (
          <article class="edge-system-row">
            <div class="edge-system-label">
              <span class="card-tag">Focus</span>
              <h3>{row.title}</h3>
            </div>
            <div class="edge-system-copy">
              <div class="edge-system-column">
                <p class="edge-system-kicker">Typical approach</p>
                <p>{row.standard}</p>
              </div>
              <div class="edge-system-column edge-system-column-accent">
                <p class="edge-system-kicker">Designed by Anthony</p>
                <p>{row.dba}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="section-container">
      <SourceList
        title="Documentation Sources"
        intro="Here is the documentation behind the claims on this page."
        items={comparisonSources}
      />
    </div>
  </section>

</Layout>

<style>
  .edge-hero {
    max-width: 860px;
  }

  .edge-hero-actions {
    margin-top: 2rem;
    justify-content: center;
  }

  .edge-section-actions {
    margin-top: clamp(2.5rem, 4vw, 4rem);
    justify-content: center;
  }

  .edge-meta-row {
    justify-content: center;
  }

  .edge-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .edge-principles-shell,
  .edge-benchmark-shell {
    padding-top: 0;
  }

  .edge-principle-card,
  .edge-system-card {
    padding: 2rem;
  }

  .edge-header {
    margin-bottom: 2rem;
  }

  .edge-system-shell {
    padding-top: 0;
  }

  .edge-system-card {
    display: grid;
    gap: 1.15rem;
  }

  .edge-system-row {
    display: grid;
    grid-template-columns: minmax(160px, 0.34fr) minmax(0, 1fr);
    gap: 1.25rem;
    padding-top: 1.15rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .edge-system-row:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .edge-system-label {
    display: grid;
    align-content: start;
    gap: 0.6rem;
  }

  .edge-system-label h3 {
    margin: 0;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
  }

  .edge-system-copy {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .edge-system-column {
    padding: 1rem 1.05rem;
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .edge-system-column-accent {
    background:
      radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 34%),
      rgba(8, 15, 28, 0.72);
    border-color: rgba(96, 165, 250, 0.16);
  }

  .edge-system-kicker {
    margin-bottom: 0.45rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #93c5fd;
  }

  .edge-system-column p:last-child {
    margin: 0;
    color: var(--text-gray);
    line-height: 1.75;
  }

  @media (max-width: 900px) {
    .edge-grid {
      grid-template-columns: 1fr;
    }

    .edge-system-row,
    .edge-system-copy {
      grid-template-columns: 1fr;
    }
  }
</style>
