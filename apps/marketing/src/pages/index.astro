---
import Layout from '../layouts/Layout.astro';
import AuditForm from '../components/AuditForm.astro';
import FoundingPartnerSection from '../components/FoundingPartnerSection.astro';
import PremiumPitchStrip from '../components/PremiumPitchStrip.astro';
import { Image } from 'astro:assets';
import { showcaseFeaturedItems } from '../data/showcase';
import { buildItemListSchema, buildLighthouseSoftwareApplicationSchema } from '../lib/seo';
import {
  FOUNDING_PARTNER_BUILD_SLOTS,
  FOUNDING_PARTNER_SEO_LABEL,
  FOUNDING_PARTNER_SEO_MONTHLY,
  PUBLIC_PAYMENT_STRUCTURE_COPY,
  STANDARD_WEBSITE_STARTING_PRICE,
} from '../lib/offers';

const homeServiceSchema = buildItemListSchema({
  name: 'Core Services',
  description:
    'Designed by Anthony provides custom websites, local SEO, managed hosting, and website rescue for service businesses, including a limited 10-client launch pilot.',
  path: '/',
  items: [
    {
      name: 'Custom Web Design',
      url: '/services/custom-web-design',
      description: 'Custom websites built for trust, clarity, speed, and conversion.',
    },
    {
      name: 'Local SEO and Search Visibility',
      url: '/services/local-seo',
      description: 'Technical and on-page SEO that helps service businesses show up more clearly in local search.',
    },
    {
      name: 'Managed Hosting and VIP Support',
      url: '/services/managed-hosting',
      description: 'Managed hosting and support that keeps your site fast, current, and easy to trust.',
    },
    {
      name: 'Website Rescues and Mobile Optimization',
      url: '/services/website-rescue',
      description: 'Website rebuilds for older sites that need better mobile usability and stronger conversion flow.',
    },
    {
      name: 'Google Workspace Setup',
      url: '/services/workspace-setup',
      description: 'Professional business email and workspace administration setup.',
    },
    {
      name: 'Custom Google AI Chatbots & Forms',
      url: '/services/ai-automation',
      description: 'Automated chatbots and smart forms for hands-free lead capture.',
    },
  ],
});
const homeFeaturedWorkItems = showcaseFeaturedItems.slice(0, 3);

const processSteps = [
  {
    title: 'Run the free audit on your site',
    description: 'Enter your URL into our in-house Lighthouse scanner. You get performance, accessibility, best practices, and SEO scores in under 60 seconds — no signup, no waiting.',
  },
  {
    title: 'Anthony reviews and follows up',
    description: 'If you want a deeper read, Anthony reviews the results and sends a practical summary of the clearest fixes and the likely gains. If a rebuild makes sense, the quote is based on what was actually found.',
  },
  {
    title: 'You see the site before it goes live',
    description: `Nothing launches until you approve it. ${PUBLIC_PAYMENT_STRUCTURE_COPY} Standard custom builds start at ${STANDARD_WEBSITE_STARTING_PRICE}, or ask about a founding partner spot while any remain (${FOUNDING_PARTNER_SEO_MONTHLY}/mo ${FOUNDING_PARTNER_SEO_LABEL}).`,
  },
];

const homeFooterCta = {
  eyebrow: 'Free Instant Audit',
  title: 'See what your website needs to fix — in 60 seconds.',
  description:
    'Run our in-house Lighthouse scanner against your URL and get instant performance, accessibility, best practices, and SEO scores. No signup. No waiting. Ten launch pilot builds are currently available.',
  primaryHref: '/free-seo-audit',
  primaryLabel: 'Run the Free Audit',
  secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
  secondaryLabel: 'Book a 15-minute intro call',
  note: 'Instant results and direct follow-up when you want guidance.',
};

---

<Layout
  title="Web Design & Development Company — Mohawk Valley, Syracuse, CNY | Designed by Anthony"
  description="Web design and development company based in the Mohawk Valley, serving Syracuse, North Country, and Central New York. Custom websites, local SEO, and managed hosting for service businesses."
  hideBreadcrumbs={true}
  schema={[homeServiceSchema, buildLighthouseSoftwareApplicationSchema()]}
  footerCta={homeFooterCta}
>
  <section class="page-hero page-hero--home">
    <div class="hero-rain" aria-hidden="true">
      <span class="hero-rain__layer hero-rain__layer--back"></span>
      <span class="hero-rain__layer hero-rain__layer--front"></span>
    </div>
    <div class="page-hero-inner">
      <div class="hero-copy">
        <p class="page-eyebrow page-eyebrow--rule">Web Design That Works For Your Business</p>
        <div class="hero-launch-pill" role="status">
          <span class="hero-launch-dot" aria-hidden="true"></span>
          <span><strong>{FOUNDING_PARTNER_BUILD_SLOTS} launch pilot spots</strong> · complimentary build + {FOUNDING_PARTNER_SEO_MONTHLY}/mo growth plan</span>
        </div>
        <h1>Your website should reflect the quality of your business and help the right customers choose you.</h1>
        <p>
          We are a web design and development company based in the Mohawk Valley, currently onboarding ten founding partners across Syracuse, the North Country, and greater Central New York. The build is complimentary with the {FOUNDING_PARTNER_SEO_MONTHLY}/mo growth plan while this launch allocation is open. Standard custom website builds start at {STANDARD_WEBSITE_STARTING_PRICE}. Start with the free audit to see what matters most for your business.
        </p>
        <div class="hero-actions">
          <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" class="btn btn-primary-book hero-cta-glow" id="hero-founder-btn" data-calendar-link>
            <span class="hero-cta-glow-halo" aria-hidden="true"></span>
            Book a 15-minute intro call
          </a>
          <a href="/free-seo-audit" class="btn btn-primary-audit" id="hero-run-audit-btn">Run your free audit</a>
        </div>
        <div class="hero-trust-strip reveal-up">
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>US-Based &amp; Direct</span>
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2l1.5 4.5H16l-3.7 2.7 1.4 4.3L10 11l-3.7 2.5 1.4-4.3L4 6.5h4.5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            <span>98+ Lighthouse Scores</span>
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-badge">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3c-3.87 0-7 3.13-7 7s3.13 7 7 7 7-3.13 7-7-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>60-Second Audit</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--premium-pitch">
    <PremiumPitchStrip variant="home" />
  </section>

  <section class="section-shell section-shell--proof command-shell">
    <div class="section-container command-strip reveal-up" aria-label="Design and performance command center">
      <div class="command-strip__item command-strip__item--brand">
        <p class="command-strip__label">Studio Signal</p>
        <p class="command-strip__value">Boutique Build System</p>
        <p class="command-strip__meta">Custom IA, conversion copy, and performance engineering under one roof.</p>
      </div>
      <div class="command-strip__item">
        <p class="command-strip__label">Delivery Cadence</p>
        <p class="command-strip__value">Audit → Plan → Build</p>
        <p class="command-strip__meta">Fastest path from weak trust score to booked calls.</p>
      </div>
      <div class="command-strip__item">
        <p class="command-strip__label">Conversion Priority</p>
        <p class="command-strip__value">Booked Calls First</p>
        <p class="command-strip__meta">Every section supports one action: clear next steps and better lead quality.</p>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--wash home-proof-shell" aria-labelledby="home-proof-heading">
    <div class="section-container">
      <div class="section-header centered">
        <p class="section-eyebrow">Proof so far</p>
        <h2 id="home-proof-heading">Early traction, clearly documented.</h2>
        <p>
          We are still in the first 10-client launch pilot. Here is exactly what we can verify today.
        </p>
      </div>
      <div class="home-proof-grid">
        <article class="surface-card home-proof-card reveal-up">
          <span class="card-tag">Verified technical baseline</span>
          <h3>Lighthouse performance and quality scores are consistently strong.</h3>
          <p>
            The site showcases real Lighthouse results and the same engineering standards used in client builds:
            fast loading, clean accessibility, and solid technical SEO structure.
          </p>
        </article>
        <article class="surface-card home-proof-card reveal-up">
          <span class="card-tag">Current client outcome</span>
          <h3>The Long Beach Handyman is live; lead generation is still in progress.</h3>
          <p>
            The first client paid $250 for the build and the site is deployed. Paid advertising has not produced a
            customer yet, so we are treating this as an early-stage baseline and continuing to test positioning and traffic.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--wash home-quick-lead" aria-labelledby="home-quick-heading">
    <div class="section-container">
      <div class="home-quick-lead__card surface-card reveal-up">
        <h2 id="home-quick-heading" class="home-quick-lead__title">Quick question?</h2>
        <p class="home-quick-lead__sub">
          Same secure lead path as the <a href="/contact">contact page</a> — compact so the hero stays clean.
        </p>
        <AuditForm
          ctaSource="home_quick"
          pageContext="homepage"
          offerType="home_page_contact"
          subjectLine="Homepage quick contact — Designed by Anthony"
          successTitle="Got it"
          successMessage="Anthony will follow up within 24 hours — same workflow as the full contact form."
          successPoints={[
            'We will reply with a clear next step.',
            'Book a call anytime from the site header if you prefer.',
          ]}
          successTag="Message received"
          submitLabel="Send"
          metaMessage="Turnstile-protected. No spam."
          websiteRequired={false}
          issueRequired={false}
          issueLabel="Message (optional)"
          issuePlaceholder="What should we know?"
          issueRows={2}
          showPhoneField={false}
        />
      </div>
    </div>
  </section>

  <FoundingPartnerSection />

  <section class="section-shell section-shell--technical process-shell">
    <div class="section-container">
      <div class="section-flow-marker reveal-up" aria-hidden="true"></div>
      <div class="section-header centered">
        <p class="section-eyebrow section-eyebrow--pulse">How It Works</p>
        <h2>From free audit to live website, with a clear development process at every step.</h2>
        <p>No long sales calls. No commitment until you are ready. Here is the full process from first click to launch.</p>
      </div>

      <div class="process-grid process-grid--asymmetric">
        {processSteps.map((step, index) => (
          <div class="surface-card surface-card--technical process-card reveal-up">
            <span class="process-number">0{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>

      <div class="process-action">
        <a href="/free-seo-audit" class="btn btn-primary-audit">Run the Free Audit</a>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--editorial section-shell--wash">
    <div class="section-container">
      <div class="section-flow-marker reveal-up" aria-hidden="true"></div>
      <div class="section-header centered">
        <p class="section-eyebrow">Selected Examples</p>
        <h2>A quick look at the web design quality behind the work.</h2>
        <p>Finished examples show the design standard, structure, and conversion thinking behind the websites we develop. <a href="/ouredge" class="inline-link">See our technical edge →</a></p>
      </div>

      <div class="featured-work-grid featured-work-grid--stagger" data-home-featured-work>
        {homeFeaturedWorkItems.map((item, i) => {
          const href = item.caseStudySlug ? `/portfolio/${item.caseStudySlug}` : item.href;
          const isExternal = !item.caseStudySlug;
          const ctaLabel = item.caseStudySlug
            ? 'View Case Study'
            : `Open ${item.name} example`;

          return (
            <article class="surface-card surface-card--editorial featured-work-card reveal-up">
              <a
                href={href}
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
                class="featured-work-media"
              >
                <div class="featured-image-wrap">
                  <Image
                    src={item.displayImage}
                    alt={item.imageAlt}
                    class="featured-image"
                    widths={[360, 480, 560, 640, 768, 960]}
                    sizes="(max-width: 900px) min(100vw, 1160px), min(33vw, 480px)"
                    format="webp"
                    quality={68}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    fetchpriority={i === 0 ? 'high' : undefined}
                  />
                </div>
              </a>
              <div class="featured-copy">
                <div class="featured-meta">
                  <span class="card-tag">{item.statusLabel}</span>
                  <span class="featured-industry">{item.industry}</span>
                </div>
                <h3>{item.name}</h3>
                <p>{item.description}</p>
                <a
                  href={href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                  class="featured-link"
                >
                  {ctaLabel}
                  {isExternal && <span class="sr-only">(opens in new window)</span>}
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <div class="portfolio-link-wrap">
        <a href="/portfolio" class="btn btn-secondary-proof">View Full Portfolio</a>
      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  (() => {
    const hero = document.querySelector('.page-hero--home');
    if (!hero) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;

    if (!prefersReducedMotion && hasFinePointer) {
      hero.addEventListener(
        'pointermove',
        (event) => {
          const rect = hero.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          hero.style.setProperty('--hero-spot-x', `${x.toFixed(2)}%`);
          hero.style.setProperty('--hero-spot-y', `${y.toFixed(2)}%`);
        },
        { passive: true },
      );

      hero.addEventListener('pointerleave', () => {
        hero.style.setProperty('--hero-spot-x', '50%');
        hero.style.setProperty('--hero-spot-y', '22%');
      });
    }

    const actionButtons = hero.querySelectorAll('.hero-actions .btn');
    if (prefersReducedMotion || !hasFinePointer || actionButtons.length === 0) return;

    const MAX_SHIFT = 8;
    actionButtons.forEach((button) => {
      button.addEventListener(
        'pointermove',
        (event) => {
          const rect = button.getBoundingClientRect();
          const dx = event.clientX - (rect.left + rect.width / 2);
          const dy = event.clientY - (rect.top + rect.height / 2);
          const xShift = (dx / (rect.width / 2)) * MAX_SHIFT;
          const yShift = (dy / (rect.height / 2)) * MAX_SHIFT;

          button.style.setProperty('--btn-shift-x', `${xShift.toFixed(2)}px`);
          button.style.setProperty('--btn-shift-y', `${yShift.toFixed(2)}px`);
        },
        { passive: true },
      );

      button.addEventListener('pointerleave', () => {
        button.style.setProperty('--btn-shift-x', '0px');
        button.style.setProperty('--btn-shift-y', '0px');
      });
    });
  })();
</script>

<style>
  .page-hero--home {
    --hero-spot-x: 50%;
    --hero-spot-y: 22%;
  }

  .page-hero--home::before {
    background:
      radial-gradient(560px 300px at var(--hero-spot-x) var(--hero-spot-y), rgba(125, 181, 255, 0.22), transparent 62%),
      radial-gradient(circle at 18% 22%, rgba(91, 156, 248, 0.12), transparent 32%),
      radial-gradient(circle at 82% 12%, rgba(201, 168, 108, 0.06), transparent 28%),
      linear-gradient(180deg, rgba(5, 7, 12, 0.97) 0%, rgba(10, 13, 20, 0.95) 100%);
  }

  .hero-actions .btn {
    --btn-shift-x: 0px;
    --btn-shift-y: 0px;
    transform: translate3d(var(--btn-shift-x), var(--btn-shift-y), 0);
    transition:
      transform 140ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce), (pointer: coarse) {
    .hero-actions .btn {
      transform: none;
      transition: box-shadow 220ms ease, border-color 220ms ease;
    }
  }

  /* Compact homepage lead (same API as /contact) */
  .home-quick-lead {
    padding-block: 1.25rem 1.5rem;
  }

  .home-quick-lead__card {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1.35rem 1.5rem 1.5rem;
  }

  .home-quick-lead__title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .home-quick-lead__sub {
    margin: 0 0 1rem;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-gray);
  }

  .home-quick-lead__sub a {
    color: #bfdbfe;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .home-quick-lead .audit-form textarea {
    min-height: 4.25rem;
  }

  .home-quick-lead .audit-form-meta,
  .home-quick-lead .audit-form-privacy {
    font-size: 0.78rem;
  }

  /* Hero launch ribbon */
  .hero-launch-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
    max-width: 36rem;
    margin-bottom: 1.15rem;
    padding: 0.55rem 1rem 0.55rem 0.65rem;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255, 252, 245, 0.88);
    background: linear-gradient(135deg, rgba(91, 156, 248, 0.14), rgba(201, 168, 108, 0.1));
    border: 1px solid rgba(255, 252, 245, 0.1);
    box-shadow: 0 12px 40px -28px rgba(91, 156, 248, 0.5);
    animation: hero-pill-enter 0.85s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: 0.12s;
  }

  .hero-launch-pill strong {
    color: var(--text-cream);
    font-weight: 800;
  }

  .hero-launch-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #fef9c3, #5b9cf8);
    box-shadow: 0 0 0 3px rgba(91, 156, 248, 0.25);
    flex-shrink: 0;
    animation: hero-dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-pill-enter {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes hero-dot-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.85;
      transform: scale(1.12);
    }
  }

  .hero-cta-glow {
    position: relative;
    z-index: 0;
    isolation: isolate;
    overflow: visible;
  }

  .hero-cta-glow-halo {
    position: absolute;
    inset: -4px;
    z-index: -1;
    border-radius: inherit;
    pointer-events: none;
    box-shadow:
      0 22px 40px -22px rgba(37, 99, 235, 0.95),
      0 0 26px 2px rgba(147, 197, 253, 0.2);
    opacity: 0.55;
    animation: hero-cta-glow-ring 4s ease-in-out infinite;
  }

  @keyframes hero-cta-glow-ring {
    0%,
    100% {
      opacity: 0.42;
    }
    50% {
      opacity: 0.85;
    }
  }

  .process-card,
  .featured-work-card {
    --card-stagger-offset: 0px;
    transform: translateY(var(--card-stagger-offset));
  }

  .featured-work-card:hover,
  .process-card:hover {
    transform: translateY(calc(var(--card-stagger-offset) - 3px));
    border-color: rgba(96, 165, 250, 0.22);
    box-shadow: 0 26px 56px -34px rgba(2, 6, 23, 0.85);
  }

  .service-arrow,
  .featured-link {
    color: #bfdbfe;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .process-shell {
    background: rgba(8, 15, 28, 0.34);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .command-shell {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .home-proof-shell {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .home-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .home-proof-card {
    padding: clamp(1.2rem, 2.4vw, 1.6rem);
  }

  .home-proof-card h3 {
    margin: 0.75rem 0 0.6rem;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    letter-spacing: -0.02em;
    line-height: 1.28;
  }

  .home-proof-card p {
    margin: 0;
    color: var(--text-gray);
    line-height: 1.68;
  }

  .section-flow-marker {
    width: min(100%, 11rem);
    height: 2px;
    margin: 0 auto clamp(1.25rem, 2vw, 1.8rem);
    border-radius: 999px;
    background:
      linear-gradient(90deg, transparent, rgba(201, 168, 108, 0.8), rgba(91, 156, 248, 0.8), transparent);
    box-shadow: 0 0 18px rgba(91, 156, 248, 0.26);
  }

  .command-strip {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 0.95rem;
    padding: clamp(1rem, 2vw, 1.25rem);
    border-radius: 1.1rem;
    border: 1px solid rgba(147, 197, 253, 0.24);
    background:
      linear-gradient(145deg, rgba(11, 18, 31, 0.92) 0%, rgba(9, 14, 24, 0.92) 100%);
    box-shadow: 0 20px 50px -32px rgba(2, 6, 23, 0.95);
  }

  .command-strip__item {
    padding: 0.95rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: rgba(15, 23, 42, 0.55);
  }

  .command-strip__item--brand {
    border-color: rgba(201, 168, 108, 0.32);
    background:
      radial-gradient(circle at top right, rgba(201, 168, 108, 0.1), transparent 55%),
      rgba(15, 23, 42, 0.55);
  }

  .command-strip__label {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.96);
    font-weight: 700;
  }

  .command-strip__value {
    margin: 0.35rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.2rem);
    letter-spacing: -0.02em;
    color: var(--text-cream);
    font-weight: 700;
    line-height: 1.2;
  }

  .command-strip__meta {
    margin: 0.45rem 0 0;
    color: var(--text-gray);
    font-size: 0.82rem;
    line-height: 1.52;
  }

  .process-grid {
    display: grid;
