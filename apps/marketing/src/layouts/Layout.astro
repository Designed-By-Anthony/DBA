    <script is:inline>
      (function() {
        /** Must match `TURNSTILE_SITE_KEY_TEST_ALWAYS_PASS` in `src/lib/turnstile.ts`. */
        var TURNSTILE_TEST_SITEKEY = '1x00000000000000000000AA';

        window.__dbaTurnstileError = function () {
          document.querySelectorAll('.cf-turnstile').forEach(function (w) {
            var lhRoot = w.closest('[data-lh-audit]');
            if (lhRoot) {
