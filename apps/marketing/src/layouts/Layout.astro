---
import { Image } from 'astro:assets';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import FooterCTA from '../components/FooterCTA.astro';
import SiteFooter from '../components/SiteFooter.astro';
import iconLogo from '../assets/IconLogo.png';
import interLatinNormalWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

import '@fontsource-variable/outfit/wght.css';
import outfitLatinWoff2 from '@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url';
import '@fontsource-variable/fraunces';
import '@fontsource/abril-fatface/latin-400.css';
import abrilFatfaceLatinWoff2 from '@fontsource/abril-fatface/files/abril-fatface-latin-400-normal.woff2?url';
import '@dba/theme/dba-global.css';
import { MONTHLY_LOCAL_SEO_PRICE } from '../lib/offers';
import {
  DEFAULT_SOCIAL_IMAGE,
  GA_MEASUREMENT_ID,
  ORGANIZATION_ID,
  WEBSITE_ID,
  buildBaseOrganizationSchema,
  buildFounderPersonSchema,
  buildBaseWebsiteSchema,
  buildBreadcrumbSchema,
  buildBreadcrumbs,
  buildImageObject,
  businessProfile,
  normalizePath,
  stripSiteSuffix,
  toAbsoluteUrl,
  type SchemaValue,
} from '../lib/seo';

export interface Props {
  title: string;
  description: string;
  image?: string;
  socialImage?: string;
  ogType?: 'website' | 'article';
  pageType?: string;
  breadcrumbLabel?: string;
  hideBreadcrumbs?: boolean;
  minimalChrome?: boolean;
  noindex?: boolean;
  schema?: SchemaValue | SchemaValue[];
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  bodyClass?: string;
  priorityAnalytics?: boolean;
  hidePreFooterCTA?: boolean;
  footerCta?: {
    eyebrow: string;
    title: string;
    description: string;
    primaryHref: string;
    primaryLabel: string;
    secondaryHref?: string;
    secondaryLabel?: string;
    note?: string;
  };
}

const {
  title,
  description,
  image,
  socialImage: customSocialImage,
  ogType = 'website',
  pageType = 'WebPage',
  breadcrumbLabel,
  hideBreadcrumbs = false,
  minimalChrome = false,
  noindex = false,
  schema,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags = [],
  bodyClass,
  priorityAnalytics = false,
  hidePreFooterCTA = false,
  footerCta,
} = Astro.props;

const pathname = normalizePath(Astro.url.pathname);
const canonicalUrl = toAbsoluteUrl(pathname);
const pageTitle = breadcrumbLabel ?? stripSiteSuffix(title);
const socialImage = toAbsoluteUrl(customSocialImage ?? image ?? DEFAULT_SOCIAL_IMAGE);
// Hash of bundled script — stable across builds when `site.js` is unchanged (deterministic HTML).
const siteScriptVersion = createHash('sha256')
  .update(readFileSync(join(process.cwd(), 'public/scripts/site.js')))
  .digest('hex')
  .slice(0, 12);
const mailtoContactHref = `mailto:${businessProfile.email}?subject=${encodeURIComponent('Website inquiry — Designed by Anthony')}`;

const robotsContent = noindex
  ? 'noindex, nofollow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const breadcrumbItems = hideBreadcrumbs ? [] : buildBreadcrumbs(pathname, pageTitle);
const breadcrumbSchema = hideBreadcrumbs ? null : buildBreadcrumbSchema(pathname, breadcrumbItems);
const webPageSchema: SchemaValue = {
  '@context': 'https://schema.org',
  '@type': pageType,
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: pageTitle,
  description,
  isPartOf: {
    '@id': WEBSITE_ID,
  },
  about: {
    '@id': ORGANIZATION_ID,
  },
  primaryImageOfPage: buildImageObject(socialImage),
  breadcrumb: breadcrumbSchema
    ? {
        '@id': `${canonicalUrl}#breadcrumb`,
      }
    : undefined,
  inLanguage: 'en-US',
};
const extraSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const resolvedFooterCta =
  footerCta ??
  (ogType === 'article'
    ? {
        eyebrow: 'Apply This to Your Site',
        title: 'Want a direct read on whether this applies to your website?',
        description:
          'Run the free Lighthouse audit to see your performance, accessibility, and SEO scores. If you want a second pair of eyes on what it means, I will reply with a practical next step.',
        primaryHref: '/free-seo-audit',
        primaryLabel: 'Run the Free Audit',
        secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
        secondaryLabel: 'Book a 15-minute intro call',
        note: 'Instant scores. A human reply within a business day if you ask for one.',
      }
    : undefined);
const structuredData = [
  buildBaseOrganizationSchema(),
  buildFounderPersonSchema(),
  buildBaseWebsiteSchema(),
  webPageSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...extraSchemas,
];

/** Preconnect when DSN is set (falls back to production default used by CSP helpers). */
const DEFAULT_SENTRY_DSN =
  'https://0d490516ab9f385b16ea4210a1f9622e@o4511201601912832.ingest.us.sentry.io/4511201603158016';
const sentryDsnForOrigin = import.meta.env.PUBLIC_SENTRY_DSN ?? DEFAULT_SENTRY_DSN;
let sentryIngestOrigin: string | undefined;
try {
  sentryIngestOrigin = new URL(sentryDsnForOrigin).origin;
} catch {
  sentryIngestOrigin = undefined;
}
---
<!DOCTYPE html>
<html lang="en" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Trusted Types: permissive default policy; must be first script so CSP require-trusted-types-for does not break GTM/Astro/third parties. Tighten createHTML/createScript later. -->
    <script is:inline>
      (function () {
        if (!window.trustedTypes || !window.trustedTypes.createPolicy) return;
        try {
          window.trustedTypes.createPolicy('default', {
            createHTML: function (s) {
              return s;
            },
            createScript: function (s) {
              return s;
            },
            createScriptURL: function (s) {
              return s;
            },
          });
        } catch (_) {}
      })();
    </script>
    {sentryIngestOrigin && <link rel="preconnect" href={sentryIngestOrigin} crossorigin />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.png" />
    <link rel="icon" type="image/png" href="/site-icon-48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-180.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#22d3ee" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- LCP (home hero) uses Abril first; body/UI use Inter + Outfit. -->
    <link rel="preload" href={abrilFatfaceLatinWoff2} as="font" type="font/woff2" crossorigin fetchpriority="high" />
    <link rel="preload" href={interLatinNormalWoff2} as="font" type="font/woff2" crossorigin fetchpriority="high" />
    <link rel="preload" href={outfitLatinWoff2} as="font" type="font/woff2" crossorigin />
    <!-- DNS prefetch for deferred third-party origins -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en-US" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="license" href="https://designedbyanthony.com/image-license" />
    <link rel="alternate" type="application/rss+xml" title="Designed by Anthony Blog" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Designed by Anthony Releases" href="/releases.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="author" content={businessProfile.name} />
    <meta name="publisher" content={businessProfile.name} />
    <meta name="application-name" content={businessProfile.name} />
    <meta name="apple-mobile-web-app-title" content={businessProfile.name} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-TileColor" content="#0f1218" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="theme-color" content="#0f1218" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={businessProfile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content={`${pageTitle} | ${businessProfile.name}`} />
    {ogType === 'article' && (
      <>
        <meta property="article:publisher" content={businessProfile.url} />
        <meta property="article:author" content={toAbsoluteUrl('/about')} />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={`${pageTitle} | ${businessProfile.name}`} />
    <!-- Google Analytics 4 (loaded only after in-house cookie consent; see cookie-consent-root) -->
    <script is:inline define:vars={{ gaMeasurementId: GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () {
        window.dataLayer.push(arguments);
      };
      window.__dbaAnalyticsEnabled = false;
      window.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
      var analyticsLoaded = false;
      var analyticsConfigured = false;
      window.__dbaCookieConsentKey = 'dba_cookie_consent';

      function configureAnalytics() {
        if (analyticsConfigured) return;
        analyticsConfigured = true;
        window.gtag('js', new Date());
        window.gtag('config', gaMeasurementId, {
          anonymize_ip: true,
          allow_google_signals: false,
          allow_ad_personalization_signals: false,
          send_page_view: true,
        });
      }

      window.__dbaLoadAnalytics = function () {
        if (analyticsLoaded) {
          configureAnalytics();
          return;
        }

        analyticsLoaded = true;

        if (document.getElementById('dba-ga4-loader')) {
          configureAnalytics();
          return;
        }

        var script = document.createElement('script');
        script.id = 'dba-ga4-loader';
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
        script.onload = configureAnalytics;
        document.head.appendChild(script);
      };

      window.__dbaGrantAnalyticsConsent = function () {
        window.__dbaAnalyticsEnabled = true;
        window.gtag('consent', 'update', {
          analytics_storage: 'granted',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
      };
      window.__dbaRevokeAnalyticsConsent = function () {
        window.__dbaAnalyticsEnabled = false;
        window.gtag('consent', 'update', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
      };
    </script>
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    {articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    {
      structuredData.map((entry) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
    <slot name="head" />
    <Analytics />
    <SpeedInsights />
  </head>
  <body
    class:list={[bodyClass]}
    data-priority-analytics={priorityAnalytics ? 'true' : undefined}
    data-reach-out-sticky={!minimalChrome ? 'true' : undefined}
  >
    {!minimalChrome && <div id="reading-progress-bar" aria-hidden="true"></div>}

    {
      !minimalChrome && (
        <>
          <div class="site-banner">
            <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" class="site-banner-link" data-calendar-link>
              <span class="site-banner-dot" aria-hidden="true"></span>
              <span><strong>Launch pilot: 10 client spots</strong> — complimentary custom build + {MONTHLY_LOCAL_SEO_PRICE}/mo growth plan while the program is open →</span>
            </a>
          </div>
          <header class="header">
            <div class="header-container">
              <a href="/" class="brand-lockup" data-astro-prefetch>
                <Image
                  src={iconLogo}
                  alt="Designed by Anthony"
                  widths={[36, 72]}
                  sizes="36px"
                  width={36}
                  height={27}
                  class="nav-icon"
                  loading="eager"
                  fetchpriority="high"
                />
              </a>
              <nav class="nav nav-desktop">
                <a href="/ouredge" data-astro-prefetch>Our Edge</a>
                <a href="/services" data-astro-prefetch>Services</a>
                <a href="/service-areas" data-astro-prefetch>Service Areas</a>
                <a href="/portfolio" data-astro-prefetch>Portfolio</a>
                <a href="/about" data-astro-prefetch>About</a>
                <a href="/faq" data-astro-prefetch>FAQ</a>
                <a href="/blog" data-astro-prefetch>Blog</a>
                <a href="/contact" class="nav-contact-link" data-astro-prefetch>Contact</a>
                <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" class="btn btn-primary btn-sm nav-book-btn" id="nav-book-call-btn" data-calendar-link>
                  Book a Free Call
                </a>
              </nav>
              <button
                class="hamburger"
                id="hamburger-btn"
                type="button"
                aria-label="Open navigation menu"
                aria-controls="mobile-nav"
                aria-expanded="false"
              >
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
              </button>
            </div>
          </header>

          <div class="mobile-nav-overlay" id="mobile-nav">
            <nav class="mobile-nav-links">
              <a href="/ouredge" data-astro-prefetch>Our Edge</a>
              <a href="/services" data-astro-prefetch>Services</a>
              <a href="/service-areas" data-astro-prefetch>Service Areas</a>
              <a href="/portfolio" data-astro-prefetch>Portfolio</a>
              <a href="/about" data-astro-prefetch>About</a>
              <a href="/faq" data-astro-prefetch>FAQ</a>
              <a href="/blog" data-astro-prefetch>Blog</a>
              <a href="/contact" data-astro-prefetch>Contact</a>
              <a href="/contact" class="mobile-nav-cta" data-astro-prefetch>
                Contact Us
              </a>
            </nav>
          </div>
        </>
      )
    }

    {
      !minimalChrome && breadcrumbItems.length > 0 && (
        <nav class="breadcrumb-nav" aria-label="Breadcrumb">
          <div class="breadcrumb-container">
            <ol class="breadcrumbs">
              {breadcrumbItems.map((item, index) => {
                const isLast = index === breadcrumbItems.length - 1;

                return (
                  <li class="breadcrumb-item">
                    {isLast ? (
                      <span aria-current="page">{item.name}</span>
                    ) : (
                      <a href={item.path} data-astro-prefetch>
                        {item.name}
                      </a>
                    )}
                  </li>
                );
              })}
            </ol>
          </div>
        </nav>
      )
    }

    <main id="main-content">
      <slot />
    </main>

    {!minimalChrome && !hidePreFooterCTA && resolvedFooterCta && <FooterCTA {...resolvedFooterCta} />}

    { !minimalChrome && <SiteFooter /> }

    {
      !minimalChrome && (
        <>
          <div class="reach-out-sticky" id="reachOutSticky">
            <button
              type="button"
              class="reach-out-sticky-btn"
              id="reachOutOpenBtn"
              aria-haspopup="dialog"
              aria-controls="reachOutModal"
              aria-expanded="false"
            >
              <span class="reach-out-sticky-label">Get in touch</span>
              <svg class="reach-out-sticky-chevron" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>

          <dialog id="reachOutModal" class="reach-out-dialog" aria-labelledby="reachOutModalTitle" aria-modal="true">
            <div class="reach-out-dialog-panel splash-shell splash-shell--reach-out">
              <div class="reach-out-dialog-header">
                <Image
                  src={iconLogo}
                  alt="Designed by Anthony"
                  widths={[40, 80]}
                  sizes="40px"
                  width={40}
                  class="reach-out-dialog-logo"
                  loading="eager"
                  decoding="async"
                />
                <button type="button" class="reach-out-dialog-close splash-close" id="reachOutCloseBtn" data-reach-out-close aria-label="Close">
                  <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </button>
              </div>
              <h2 id="reachOutModalTitle" class="reach-out-dialog-title">Say hello</h2>
              <p class="reach-out-dialog-lede">
                Pick what feels easiest — email the form, call, or grab a time on the calendar.
              </p>
              <a href="/contact" class="reach-out-dialog-primary" data-reach-out-close data-astro-prefetch>
                Contact us
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
              <div class="reach-out-dialog-actions" role="group" aria-label="Other ways to reach us">
                <a href={businessProfile.telephoneHref} class="reach-out-action" data-reach-out-close>
                  <span class="reach-out-action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <span class="reach-out-action-text">
                    <span class="reach-out-action-label">Call</span>
                    <span class="reach-out-action-detail">{businessProfile.telephone.replace('+1-', '')}</span>
                  </span>
                </a>
                <a href={mailtoContactHref} class="reach-out-action" data-reach-out-close>
                  <span class="reach-out-action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                      <polyline points="22,6 12,13 2,6" />
                    </svg>
                  </span>
                  <span class="reach-out-action-text">
                    <span class="reach-out-action-label">Email</span>
                    <span class="reach-out-action-detail">{businessProfile.email}</span>
                  </span>
                </a>
                <button
                  type="button"
                  class="reach-out-action reach-out-action--calendly"
                  id="reachOutCalendlyBtn"
                  aria-label="Book a call — opens calendar in this window"
                >
                  <span class="reach-out-action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                  </span>
                  <span class="reach-out-action-text">
                    <span class="reach-out-action-label">Book a call</span>
                    <span class="reach-out-action-detail">Calendly</span>
                  </span>
                </button>
              </div>
            </div>
          </dialog>

          <div
            class="layout-calendly-modal"
            id="layoutCalendlyModal"
            hidden
            role="dialog"
            aria-modal="true"
            aria-labelledby="layoutCalendlyModalTitle"
          >
            <div class="layout-calendly-modal__content splash-shell splash-shell--calendly">
              <h2 id="layoutCalendlyModalTitle" class="sr-only">
                Schedule a web design consultation
              </h2>
              <button type="button" class="layout-calendly-modal__close splash-close" id="layoutCalendlyCloseBtn" aria-label="Close calendar">
                &times;
              </button>
              <div class="layout-calendly-modal__body" id="layoutCalendlyModalBody">
                <div class="calendly-embed-loading" data-calendly-loading>
                  <div class="calendly-embed-loading__spinner" aria-hidden="true" />
                  <p class="calendly-embed-loading__text">Loading calendar…</p>
                </div>
              </div>
            </div>
          </div>
        </>
      )
    }

    <div
      id="cookie-consent-root"
      class="cookie-consent"
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="cookie-consent-title"
      aria-describedby="cookie-consent-desc"
    >
      <div class="cookie-consent__inner">
        <p id="cookie-consent-title" class="cookie-consent__title">
          Cookies and analytics
        </p>
        <p id="cookie-consent-desc" class="cookie-consent__text">
          We use essential tools to keep forms secure and the site running. If you are OK with it, we also load Google Analytics 4
          to see how traffic moves. Read the{' '}
          <a href="/cookie" data-astro-prefetch>Cookie Policy</a> and <a href="/privacy" data-astro-prefetch>Privacy Policy</a>.
        </p>
        <div class="cookie-consent__actions">
          <button type="button" class="btn btn-primary btn-sm" id="cookie-consent-accept">
            Accept
          </button>
          <button type="button" class="btn btn-outline btn-sm" id="cookie-consent-reject">
            Decline
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        if (window.__dbaCookieConsentBootstrapped) return;
        window.__dbaCookieConsentBootstrapped = true;
        var key = window.__dbaCookieConsentKey || 'dba_cookie_consent';
        var root = document.getElementById('cookie-consent-root');
        var accept = document.getElementById('cookie-consent-accept');
        var reject = document.getElementById('cookie-consent-reject');
        function hide() {
