---
import Layout from '../layouts/Layout.astro';
import type { SchemaValue } from '../lib/seo';

export interface Props {
  title: string;
  description: string;
  lastUpdated: string;
  pageType?: string;
  schema?: SchemaValue | SchemaValue[];
}

const {
  title,
  description,
  lastUpdated,
  pageType = 'WebPage',
  schema,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  pageType={pageType}
  schema={schema}
>
  <div class="page-wrapper">
    <section class="legal-hero">
      <div class="hero-container">
        <h1>{title.replace(' | Designed by Anthony', '')}</h1>
        <p class="last-updated">Last Updated: {lastUpdated}</p>
      </div>
    </section>

    <section class="legal-content-wrapper">
      <div class="legal-content">
        <slot />
        <div class="legal-return">
          <p>Have a question about your project or our services?</p>
          <a href="/contact" data-astro-prefetch>Contact us</a>
          <span class="legal-return-sep">,</span>{' '}
          <a href="/services" data-astro-prefetch>view services</a>
          <span class="legal-return-sep">, or</span>{' '}
          <a href="/" data-astro-prefetch>return to the homepage</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-wrapper {
    background-color: var(--bg-dark, #111827);
    color: var(--text-white, #f9fafb);
    min-height: 100vh;
  }

  .legal-hero {
    padding: clamp(7rem, 10vw, 8.25rem) var(--container-gutter) clamp(3rem, 5vw, 4rem);
    background:
      radial-gradient(circle at 18% 22%, rgba(91, 156, 248, 0.12), transparent 32%),
      radial-gradient(circle at 82% 12%, rgba(201, 168, 108, 0.06), transparent 28%),
      linear-gradient(180deg, rgba(5, 7, 12, 0.97) 0%, rgba(10, 13, 20, 0.95) 100%);
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-container {
    width: min(var(--content-max), 100%);
    margin: 0 auto;
  }

  .hero-container h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--text-cream);
  }

  .last-updated {
    font-size: 1.1rem;
    color: var(--text-gray, #9ca3af);
    font-weight: 500;
  }

  .legal-content-wrapper {
    padding: var(--section-space) var(--container-gutter);
  }

  .legal-content {
    max-width: 800px;
    margin: 0 auto;
    color: var(--text-gray, #d1d5db);
  }

  .legal-content h2 {
    font-size: 2rem;
    color: var(--text-white, #ffffff);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .legal-content h2:first-of-type {
    margin-top: 0;
  }

  .legal-content h3 {
    font-size: 1.5rem;
    color: var(--accent-blue, #2563eb);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .legal-content p {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .legal-content ul {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .legal-content li {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 0.75rem;
    position: relative;
  }

  .legal-content li::marker {
    color: var(--accent-blue, #2563eb);
  }

  .legal-content a {
    color: var(--accent-blue, #2563eb);
    transition: color 0.2s ease;
  }

  .legal-content a:hover {
    color: #93c5fd;
  }

  .legal-content strong {
    color: var(--text-white, #ffffff);
    font-weight: 600;
  }

  .legal-return {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-gray, #9ca3af);
    font-size: 1.05rem;
  }

  .legal-return a {
    color: var(--accent-blue, #2563eb);
    font-weight: 600;
  }

  .legal-return-sep {
    margin: 0 0.25rem;
    color: var(--text-gray, #6b7280);
  }

  @media (max-width: 768px) {
    .legal-hero {
      padding: 6.75rem var(--container-gutter) clamp(2.5rem, 6vw, 3rem);
    }

    .legal-content-wrapper {
      padding: clamp(3rem, 8vw, 4rem) var(--container-gutter);
    }

    .legal-content h2 {
      font-size: 1.75rem;
      margin-top: 2.5rem;
      margin-bottom: 1.25rem;
    }

    .legal-content p,
    .legal-content li {
      font-size: 1.05rem;
    }
  }
</style>
