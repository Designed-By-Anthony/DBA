---
export interface LinkClusterItem {
  title: string;
  href: string;
  description: string;
  tag?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  items: LinkClusterItem[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow,
  title,
  intro,
  items,
  ctaHref,
  ctaLabel,
} = Astro.props;
---

{
  items.length > 0 && (
    <section class="section-shell link-cluster-shell">
      <div class="section-container">
        <div class="section-header centered link-cluster-header">
          <p class="section-eyebrow">{eyebrow}</p>
          <h2>{title}</h2>
          {intro && <p>{intro}</p>}
        </div>

        <div class="link-cluster-grid">
          {items.map((item) => (
            <a href={item.href} class="surface-card link-cluster-card">
              {item.tag && <span class="card-tag">{item.tag}</span>}
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <span class="link-cluster-arrow">Explore page</span>
            </a>
          ))}
        </div>

        {
          ctaHref && ctaLabel && (
            <div class="link-cluster-cta">
              <a href={ctaHref} class="btn btn-outline">{ctaLabel}</a>
            </div>
          )
        }
      </div>
    </section>
  )
}

<style>
  .link-cluster-shell {
    padding-top: 0;
  }

  .link-cluster-header {
    max-width: 820px;
    margin-bottom: 2rem;
  }

  .link-cluster-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .link-cluster-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.6rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .link-cluster-card:hover {
    transform: translateY(-4px);
    border-color: rgba(96, 165, 250, 0.28);
  }

  .link-cluster-card h3 {
    font-size: 1.2rem;
    line-height: 1.3;
    letter-spacing: -0.03em;
    color: var(--text-white);
    margin: 0;
  }

  .link-cluster-card p {
    margin: 0;
    color: var(--text-gray);
    line-height: 1.65;
    flex: 1;
  }

  .link-cluster-arrow {
    color: #bfdbfe;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .link-cluster-cta {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  @media (max-width: 960px) {
    .link-cluster-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
