---
import {
  FOUNDING_PARTNER_BUILD_SLOTS,
  FOUNDING_PARTNER_SHORT_COPY,
  FOUNDING_PARTNER_SEO_LABEL,
  FOUNDING_PARTNER_SEO_MONTHLY,
} from '../lib/offers';
---

<section class="section-shell founding-partner-shell" aria-labelledby="founding-partner-heading">
  <div class="section-container">
    <div class="section-header centered founding-partner-header">
      <p class="section-eyebrow">Founding partner program</p>
      <h2 id="founding-partner-heading">
        {FOUNDING_PARTNER_BUILD_SLOTS} complimentary custom builds for early client partners.
      </h2>
      <p>{FOUNDING_PARTNER_SHORT_COPY}</p>
    </div>

    <div class="founding-pillars">
      <article class="founding-pillar">
        <div class="founding-pillar-accent" aria-hidden="true"></div>
        <p class="founding-pillar-eyebrow">Launch allocation</p>
        <h3 class="founding-pillar-title">
          <span class="founding-pillar-stat" data-founding-stat>{FOUNDING_PARTNER_BUILD_SLOTS}</span>
          complimentary launch builds
        </h3>
        <p class="founding-pillar-lede">
          Full custom website—strategy, design, and hand-built performance—not a page builder skin.
          Reserved for businesses that are the right fit and ready for a higher-trust digital presence.
        </p>
        <ul class="founding-pillar-list">
          <li>Built for trust, calls, and local search—not vanity slides</li>
          <li>Mobile-first engineering with strong Lighthouse scores</li>
          <li>You approve everything before anything goes live</li>
        </ul>
      </article>

      <article class="founding-pillar founding-pillar--growth">
        <div class="founding-pillar-accent founding-pillar-accent--growth" aria-hidden="true"></div>
        <p class="founding-pillar-eyebrow">After launch</p>
        <h3 class="founding-pillar-title">
          <span class="founding-pillar-price">{FOUNDING_PARTNER_SEO_MONTHLY}</span>
          /mo {FOUNDING_PARTNER_SEO_LABEL}
        </h3>
        <p class="founding-pillar-lede">
          Ongoing visibility and care: Google Cloud hosting, security, and SEO—plus Google Business
          Profile attention, review support, and one meaningful growth asset each month.
        </p>
        <ul class="founding-pillar-list">
          <li>Hosting on a fast global CDN—included in the plan</li>
          <li>Local SEO structure maintained as Google and your market shift</li>
          <li>Direct line to Anthony—no tickets, no offshore handoffs</li>
        </ul>
      </article>
    </div>

    <div class="founding-partner-actions">
      <a
        href="https://calendly.com/anthony-designedbyanthony/web-design-consult"
        class="btn btn-primary"
        data-calendar-link
        >Book a 15-minute intro call</a
      >
      <a href="/free-seo-audit" class="btn btn-outline">Run the Free Audit</a>
    </div>

    <p class="founding-partner-note">
      Limited to {FOUNDING_PARTNER_BUILD_SLOTS} approved partners. Fit and scope confirmed on a short
      call. Complimentary build applies when you enroll in the {FOUNDING_PARTNER_SEO_MONTHLY}/month
      {FOUNDING_PARTNER_SEO_LABEL}; terms reviewed before any commitment.
    </p>
  </div>
</section>

<style>
  .founding-partner-shell {
    padding-top: clamp(3.5rem, 6vw, 5rem);
    padding-bottom: clamp(4.25rem, 7vw, 6rem);
    position: relative;
  }

  .founding-partner-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(59, 130, 246, 0.07), transparent 55%);
    pointer-events: none;
    animation: founding-ambient 12s ease-in-out infinite;
  }

  @keyframes founding-ambient {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.72;
    }
  }

  .founding-partner-shell .section-container {
    position: relative;
    z-index: 1;
  }

  .founding-partner-header {
    max-width: 40rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.75rem);
    gap: 1.15rem;
  }

  .founding-partner-header h2 {
    font-size: clamp(1.85rem, 3.8vw, 2.85rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.12;
    margin-bottom: 0.15rem;
  }

  .founding-partner-header p {
    max-width: 38rem;
    line-height: 1.78;
    color: var(--text-gray);
  }

  .founding-pillars {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
    max-width: 920px;
    margin: 0 auto;
  }

  .founding-pillar {
    position: relative;
    padding: clamp(1.85rem, 3.5vw, 2.35rem);
    border-radius: var(--radius-card);
    background: linear-gradient(165deg, rgba(11, 17, 30, 0.92) 0%, rgba(15, 23, 42, 0.88) 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 28px 64px -40px rgba(2, 6, 18, 0.9);
    transition:
      border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .founding-pillar:hover {
    border-color: rgba(96, 165, 250, 0.22);
    box-shadow: 0 32px 72px -36px rgba(2, 6, 18, 0.95);
    transform: translateY(-2px);
  }

  .founding-pillar-accent {
    position: absolute;
    top: 0;
    left: 1.85rem;
    right: 1.85rem;
    height: 2px;
    border-radius: 2px;
    overflow: hidden;
    opacity: 0.85;
    pointer-events: none;
  }

  .founding-pillar-accent::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 200%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(147, 197, 253, 0.55), transparent);
    animation: founding-shimmer 5s ease-in-out infinite;
    will-change: transform;
  }

  .founding-pillar-accent--growth::after {
    background: linear-gradient(90deg, transparent, rgba(134, 239, 172, 0.45), transparent);
    animation: founding-shimmer 5.5s ease-in-out infinite reverse;
  }

  @keyframes founding-shimmer {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(-50%);
    }
  }

  .founding-pillar-eyebrow {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(147, 197, 253, 0.85);
    margin: 0.65rem 0 1rem;
  }

  .founding-pillar--growth .founding-pillar-eyebrow {
    color: rgba(167, 243, 208, 0.88);
  }

  .founding-pillar-title {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1.2;
    color: var(--text-white);
    margin: 0 0 1rem;
  }

  .founding-pillar-stat,
  .founding-pillar-price {
    display: block;
    font-size: clamp(2.35rem, 5vw, 3.1rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1;
    margin-bottom: 0.35rem;
    color: #f1f5f9;
  }

  .founding-pillar-stat[data-founding-stat] {
    display: inline-block;
    animation: founding-stat-pop 6s ease-in-out infinite;
  }

  @keyframes founding-stat-pop {
    0%,
    88%,
    100% {
      transform: scale(1);
    }
    90% {
      transform: scale(1.04);
    }
    94% {
      transform: scale(1);
    }
  }

  .founding-pillar--growth .founding-pillar-price {
    color: #bbf7d0;
  }

  .founding-pillar-lede {
    font-size: 0.98rem;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0 0 1.15rem;
  }

  .founding-pillar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .founding-pillar-list li {
    position: relative;
    padding-left: 1.15rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
  }

  .founding-pillar-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.52rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(147, 197, 253, 0.9);
  }

  .founding-pillar--growth .founding-pillar-list li::before {
    background: rgba(134, 239, 172, 0.85);
  }

  .founding-partner-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: clamp(2.25rem, 4vw, 3rem);
  }

  .founding-partner-note {
    max-width: 36rem;
    margin: 1.5rem auto 0;
    text-align: center;
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .founding-pillars {
      grid-template-columns: 1fr;
    }

    .founding-partner-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .founding-partner-actions .btn {
      width: 100%;
    }
  }
</style>
