---
import { getTurnstileSiteKey } from '../lib/turnstile';
import { normalizePath } from '../lib/seo';

const turnstileSiteKey = getTurnstileSiteKey();

/**
 * Augusta Global Ingest Protocol — public leads POST to the versioned CRM
 * route `POST /api/v1/ingest`. `PUBLIC_INGEST_URL` is the new primary env;
 * `PUBLIC_CRM_LEAD_URL` is kept for backward compatibility with older
 * deploys that still point at `/api/lead`.
 */
const defaultFormEndpoint =
  import.meta.env.PUBLIC_INGEST_URL ||
  import.meta.env.PUBLIC_CRM_LEAD_URL ||
  'https://admin.designedbyanthony.com/api/v1/ingest';

/** Clerk org id (tenant) for this marketing build — threaded through the `X-Tenant-Id` header. */
const tenantId = import.meta.env.PUBLIC_TENANT_ID || '';

export interface Props {
  ctaSource: string;
  pageContext: string;
  pageTitle?: string;
  formEndpoint?: string;
  /** Stable key for backend/CRM; every form should set this so leads are traceable. */
  offerType?: string;
  subjectLine?: string;
  successLinkHref?: string;
  successLinkLabel?: string;
  successMode?: 'inline' | 'redirect';
  successRedirect?: string;
  successTag?: string;
  successTitle?: string;
  successMessage?: string;
  successPoints?: string[];
  submitLabel?: string;
  metaMessage?: string;
  websiteLabel?: string;
  websitePlaceholder?: string;
  websiteRequired?: boolean;
  issueLabel?: string;
  issuePlaceholder?: string;
  issueRequired?: boolean;
  showPhoneField?: boolean;
  /** Textarea height; use 2–3 for compact inline forms. */
  issueRows?: number;
}

const {
  ctaSource,
  pageContext,
  pageTitle = 'Designed by Anthony',
  formEndpoint = defaultFormEndpoint,
  offerType = 'free_website_audit',
  subjectLine = `Free Website Audit Request - ${pageTitle}`,
  successLinkHref = '/portfolio',
  successLinkLabel = 'See Example Builds',
  successMode = 'inline',
  successRedirect = '/thank-you?offer=audit',
  successTag = 'Audit Requested',
  successTitle = 'Audit request received',
  successMessage = 'Anthony will review your submission and reach out within 24 hours with the clearest next step.',
  successPoints = [
    'I run the BuiltWith stack scan and Lighthouse test.',
    'I compile the clearest issues and likely gains into one report.',
    'You will hear from Anthony within 24 hours with a practical next step.',
  ],
  submitLabel = 'Send My Audit Request',
  metaMessage = 'No spam. Just a BuiltWith scan, a Lighthouse test, and a direct follow-up within 24 hours.',
  websiteLabel = 'Website URL',
  websitePlaceholder = 'yourwebsite.com',
  websiteRequired = true,
  issueLabel = 'What feels off right now?',
  issuePlaceholder = 'Low-quality leads, not enough calls, weak local rankings, dated design, slow mobile experience...',
  issueRequired = true,
  showPhoneField = true,
  issueRows = 5,
} = Astro.props;

const sourcePath = normalizePath(Astro.url.pathname);

/** Human-readable origin for emails/CRM; posted as `lead_source` alongside `offer_type`. */
const LEAD_SOURCE_LABELS: Record<string, string> = {
  home_page_contact: 'Home page contact',
  contact_page: 'Contact page',
  facebook_growth_offer: 'Facebook growth offer',
  free_website_audit: 'Free website audit',
  general_inquiry: 'Contact page',
  quick_contact_home: 'Home page contact',
};

function leadSourceLabelForOfferType(ot: string): string {
  return LEAD_SOURCE_LABELS[ot] ?? ot.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

const leadSourceLabel = leadSourceLabelForOfferType(offerType);
---

<form
  class="audit-form"
  action={formEndpoint}
  method="POST"
  data-audit-form
  data-success-mode={successMode}
  data-success-redirect={successRedirect}
  data-tenant-id={tenantId}
>
  <input type="hidden" name="_subject" value={subjectLine} />
  <input type="hidden" name="source_page" value={sourcePath} />
  <input type="hidden" name="page_url" value="" />
  <input type="hidden" name="referrer_url" value="" />
  <input type="hidden" name="page_title" value={pageTitle} />
  <input type="hidden" name="ga_client_id" value="" />
  <input type="hidden" name="cta_source" value={ctaSource} />
  <input type="hidden" name="offer_type" value={offerType} />
  <input type="hidden" name="lead_source" value={leadSourceLabel} />
  <input type="hidden" name="page_context" value={pageContext} />
  <!-- Honeypot for CRM /api/lead — must stay empty -->
  <input
    type="text"
    name="_hp"
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
    class="audit-form-honeypot"
  />

  <div class="audit-form-grid" data-form-shell>
    <div class="audit-form-field">
      <label for={`${ctaSource}-first-name`}>First name</label>
      <input id={`${ctaSource}-first-name`} name="first_name" type="text" autocomplete="given-name" required />
      <span class="audit-field-error" data-field-error="first_name"></span>
    </div>

    <div class="audit-form-field">
      <label for={`${ctaSource}-email`}>Email</label>
      <input id={`${ctaSource}-email`} name="email" type="email" autocomplete="email" required />
      <span class="audit-field-error" data-field-error="email"></span>
    </div>

    <div class="audit-form-field audit-form-field-full">
      <label for={`${ctaSource}-website`}>
        <span>{websiteLabel}</span>
        {!websiteRequired && <span class="audit-label-optional">Optional</span>}
      </label>
      <input
        id={`${ctaSource}-website`}
        name="website"
        type="text"
        inputmode="url"
        placeholder={websitePlaceholder}
        autocomplete="url"
        required={websiteRequired}
      />
      <span class="audit-field-error" data-field-error="website"></span>
    </div>

    <div class="audit-form-field audit-form-field-full">
      <label for={`${ctaSource}-biggest-issue`}>
        <span>{issueLabel}</span>
        {!issueRequired && <span class="audit-label-optional">Optional</span>}
      </label>
      <textarea
        id={`${ctaSource}-biggest-issue`}
        name="biggest_issue"
        rows={issueRows}
        placeholder={issuePlaceholder}
        required={issueRequired}
      ></textarea>
      <span class="audit-field-error" data-field-error="biggest_issue"></span>
    </div>

    {
      showPhoneField && (
        <div class="audit-form-field audit-form-field-full">
          <label for={`${ctaSource}-phone`}>
            <span>Phone</span>
            <span class="audit-label-optional">Optional</span>
          </label>
          <input id={`${ctaSource}-phone`} name="phone" type="tel" autocomplete="tel" />
          <span class="audit-field-error" data-field-error="phone"></span>
        </div>
      )
    }

  </div>

  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-theme="dark"
    data-size="invisible"
    data-appearance="interaction-only"
    data-callback="__dbaAuditFormTurnstileSuccess"
    data-error-callback="__dbaAuditFormTurnstileFailure"></div>

  <p class="audit-form-status" data-form-error hidden></p>

  <div class="audit-form-actions" data-form-actions>
    <button type="submit" class="btn btn-primary audit-submit" data-form-submit>
      {submitLabel}
    </button>
    <p class="audit-form-meta">{metaMessage}</p>
    <p class="audit-form-privacy">
      Protected by Turnstile. By submitting, you agree to the <a href="/privacy">Privacy Policy</a> and <a href="/cookie">Cookie Policy</a>.
    </p>
  </div>

  <div class="audit-success-panel" data-form-success hidden>
    <div class="card-tag">{successTag}</div>
    <h3>{successTitle}</h3>
    <p>{successMessage}</p>
    <ul class="trust-list audit-success-list">
      {successPoints.map((item) => <li>{item}</li>)}
    </ul>
    <div class="audit-success-actions">
      <a href={successLinkHref} class="btn btn-outline">{successLinkLabel}</a>
    </div>
  </div>
</form>

<style is:global>
  .audit-form {
    display: grid;
    gap: 1.1rem;
    position: relative;
  }

  .audit-form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  /* Invisible Turnstile — takes no vertical space in the form.
     Cloudflare still shows the challenge popup when a visitor is
     flagged as suspicious; the container just has no resting layout. */
  .audit-form .cf-turnstile {
    margin: 0;
    padding: 0;
    display: block;
  }
  .audit-form .cf-turnstile:empty {
    display: none;
  }

  .audit-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .audit-form-field {
    display: grid;
    gap: 0.45rem;
  }

  .audit-form-field-full {
    grid-column: 1 / -1;
  }

  .audit-form label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.86);
    letter-spacing: 0.01em;
  }

  .audit-label-optional {
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .audit-form input,
  .audit-form textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(226, 232, 240, 0.52);
    background: rgba(8, 15, 28, 0.78);
    color: var(--text-white);
    font: inherit;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  .audit-form input::placeholder,
  .audit-form textarea::placeholder {
    color: rgba(255, 255, 255, 0.34);
  }

  .audit-form input:focus,
  .audit-form textarea:focus {
    outline: none;
    border-color: rgba(96, 165, 250, 0.8);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3), 0 0 12px rgba(59, 130, 246, 0.2);
    transform: translateY(-1px);
  }

  .audit-form textarea {
    resize: vertical;
    min-height: 140px;
  }

  .audit-field-error,
  .audit-form-status {
    min-height: 1.2rem;
    font-size: 0.84rem;
    color: #fca5a5;
  }

  .audit-form-status {
    margin-top: -0.15rem;
  }

  .audit-form-actions {
    display: grid;
    gap: 0.8rem;
  }

  .audit-submit[disabled] {
    opacity: 0.72;
    cursor: wait;
  }

  .audit-submit-success {
    background: #16a34a !important;
    opacity: 1 !important;
    cursor: default !important;
    border-color: #22c55e !important;
  }

  .audit-form-meta {
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .audit-form-privacy {
    color: rgba(255, 255, 255, 0.46);
    font-size: 0.8rem;
    line-height: 1.55;
    margin: 0;
  }

  .audit-form-privacy a {
    color: #bfdbfe;
  }

  .audit-success-panel {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(147, 197, 253, 0.44);
    background:
      radial-gradient(circle at top left, rgba(59, 130, 246, 0.14), transparent 34%),
      linear-gradient(180deg, rgba(10, 16, 28, 0.98) 0%, rgba(12, 19, 32, 0.95) 100%);
  }

  .audit-success-panel h3 {
    font-size: 1.65rem;
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .audit-success-panel p {
    color: var(--text-gray);
  }

  .audit-success-list {
    margin-top: 0.2rem;
  }

  .audit-success-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .audit-form [hidden] {
    display: none !important;
  }


  .audit-form [aria-invalid='true'] {
    border-color: rgba(248, 113, 113, 0.8);
    box-shadow: 0 0 0 4px rgba(248, 113, 113, 0.14);
  }

  @media (max-width: 720px) {
    .audit-form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
