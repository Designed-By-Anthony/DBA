---
export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  note?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  note,
} = Astro.props;

const primaryIsCalendly = primaryHref.includes('calendly.com');
const secondaryIsExternal = Boolean(secondaryHref?.startsWith('http'));
const secondaryIsCalendly = Boolean(secondaryHref?.includes('calendly.com'));
const primaryPrefetch = primaryHref.startsWith('/') ? true : undefined;
const secondaryPrefetch =
  secondaryHref && secondaryHref.startsWith('/') ? true : undefined;
---

<section class="section-shell section-shell--proof footer-cta-shell">
  <div class="section-container">
    <div class="footer-cta-card reveal-up">
      <div class="footer-cta-copy">
        <p class="section-eyebrow section-eyebrow--pulse">{eyebrow}</p>
        <h2>{title}</h2>
        <p>{description}</p>
        {note && <p class="footer-cta-note">{note}</p>}
      </div>

      <div class="hero-actions footer-cta-actions">
        <a
          href={primaryHref}
          class="btn btn-primary-audit"
          data-calendar-link={primaryIsCalendly ? true : undefined}
          data-astro-prefetch={primaryPrefetch}
        >
          {primaryLabel}
        </a>
        {secondaryHref && secondaryLabel && (
          <a
            href={secondaryHref}
            class="btn btn-primary-book"
            target={secondaryIsExternal && !secondaryIsCalendly ? '_blank' : undefined}
            rel={secondaryIsExternal && !secondaryIsCalendly ? 'noopener noreferrer' : undefined}
            data-calendar-link={secondaryIsCalendly ? true : undefined}
            data-astro-prefetch={secondaryPrefetch}
          >
            {secondaryLabel}
            {secondaryIsExternal && !secondaryIsCalendly && <span class="sr-only"> (opens in new window)</span>}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .footer-cta-shell {
    padding-top: 0;
  }

  .footer-cta-card {
    padding: clamp(2rem, 4vw, 2.8rem);
    border-radius: 1.7rem;
    text-align: left;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr);
    gap: clamp(1.2rem, 2.6vw, 2rem);
    align-items: center;
    background:
      radial-gradient(circle at top right, rgba(96, 165, 250, 0.16), transparent 34%),
      linear-gradient(140deg, rgba(8, 17, 31, 0.98) 0%, rgba(13, 24, 43, 0.98) 55%, rgba(19, 34, 58, 0.98) 100%);
    border: 1px solid rgba(96, 165, 250, 0.18);
    box-shadow: 0 34px 90px -54px rgba(8, 15, 28, 0.96);
  }

  .footer-cta-copy {
    max-width: 760px;
  }

  .footer-cta-card h2 {
    font-size: clamp(1.95rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.06;
    color: var(--text-white);
    margin-bottom: 0.95rem;
  }

  .footer-cta-card p {
    color: var(--text-gray);
    font-size: clamp(1rem, 1.7vw, 1.08rem);
    line-height: 1.72;
    margin: 0;
    max-width: none;
  }

  .footer-cta-note {
    margin-top: 0.9rem !important;
    color: rgba(255, 255, 255, 0.72) !important;
    font-size: 0.95rem !important;
  }

  .footer-cta-actions {
    justify-content: flex-end;
    gap: 0.85rem;
    margin-top: 0;
    align-items: stretch;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .footer-cta-card {
      padding: 1.8rem 1.25rem;
      border-radius: 1.35rem;
      text-align: center;
      grid-template-columns: 1fr;
    }

    .footer-cta-actions {
      flex-direction: column;
      align-items: stretch;
      margin-top: 1.35rem;
    }

    .footer-cta-actions .btn {
      width: 100%;
    }

    .footer-cta-card p {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
