---
/**
 * Reinforces positioning: fast delivery, custom craft, SEO strength, transparent pricing.
 */
import { STANDARD_WEBSITE_STARTING_PRICE, FOUNDING_PARTNER_SEO_MONTHLY, FOUNDING_PARTNER_BUILD_SLOTS } from '../lib/offers';

interface Props {
  variant?: 'home' | 'services';
}

const { variant = 'home' } = Astro.props;

const items =
  variant === 'home'
    ? [
        {
          label: 'Fast',
          title: 'Built to load on a phone',
          body: 'Lean builds that open quickly on a phone, a free audit you can run yourself, and timelines measured in weeks — not quarters lost to meetings.',
        },
        {
          label: 'Stylish',
          title: 'Yours, not a template',
          body: 'Layout and type tuned so you look like a real shop someone would call — not a theme someone picked in ten minutes.',
        },
        {
          label: 'High-ranking',
          title: 'SEO that does not feel bolted on',
          body: 'Clean structure, fast pages, and the behind-the-scenes tags Google actually reads — so your service area and offers are clear from day one.',
        },
        {
          label: 'Fair price',
          title: 'Numbers before the invoice',
          body: `Founding spots (${FOUNDING_PARTNER_BUILD_SLOTS} total) pair a complimentary build with ${FOUNDING_PARTNER_SEO_MONTHLY}/mo growth while the launch program is open. After that, projects start at ${STANDARD_WEBSITE_STARTING_PRICE}, scoped to what the audit shows.`,
        },
      ]
    : [
        {
          label: 'Fast',
          title: 'Momentum, not meetings',
          body: 'Lean stack and direct communication — fewer calls, faster iterations, and a site that earns phone calls sooner.',
        },
        {
          label: 'Stylish',
          title: 'Built to earn trust fast',
          body: 'Hierarchy, proof, and mobile polish so people believe you before they read every line.',
        },
        {
          label: 'High-ranking',
          title: 'Local + technical SEO',
          body: 'Structure and tags Google reads, plus page speed that matches how people really search for trades and service businesses.',
        },
        {
          label: 'Fair price',
          title: 'No mystery bundles',
          body: `Scope tied to what you need: audit-first recommendations, clear phases, and founder-friendly entry when spots remain (${FOUNDING_PARTNER_BUILD_SLOTS} launch builds + ${FOUNDING_PARTNER_SEO_MONTHLY}/mo SEO tier).`,
        },
      ];
---

<section class="premium-pitch" aria-labelledby={`premium-pitch-heading-${variant}`}>
  <div class="section-container">
    <div class="premium-pitch__header">
      <p class="page-eyebrow" id={`premium-pitch-heading-${variant}`}>What you get here</p>
      <h2 class="premium-pitch__title">Fast, considered, and honest about price.</h2>
      <p class="premium-pitch__lede">
        Boutique delivery for Upstate NY service businesses: one senior builder, modern performance habits, and quotes tied to what we actually find in your audit.
      </p>
    </div>
    <ul class="premium-pitch__grid">
      {
        items.map((item) => (
          <li class="surface-card premium-pitch__card reveal-up">
            <span class="premium-pitch__label">{item.label}</span>
            <h3 class="premium-pitch__card-title">{item.title}</h3>
            <p class="premium-pitch__card-body">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .premium-pitch {
    padding: var(--section-space-tight) 0;
    border-top: 1px solid rgba(255, 252, 245, 0.05);
    border-bottom: 1px solid rgba(255, 252, 245, 0.05);
    background: linear-gradient(180deg, rgba(8, 12, 20, 0.35) 0%, transparent 100%);
  }

  .premium-pitch__header {
    max-width: 52rem;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .premium-pitch__title {
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 3.2vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.2;
    margin: 0.5rem 0 0.75rem;
    color: var(--text-cream);
  }

  .premium-pitch__lede {
    margin: 0;
    color: var(--text-gray);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .premium-pitch__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .premium-pitch__card {
    padding: 1.35rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-height: 100%;
    transition:
      border-color var(--motion-duration-normal, 0.28s) var(--ease-out, ease),
      box-shadow var(--motion-duration-normal, 0.28s) var(--ease-out, ease);
  }

  .premium-pitch__card:focus-within {
    border-color: rgba(96, 165, 250, 0.35);
    box-shadow: 0 12px 40px -24px rgba(37, 99, 235, 0.45);
  }

  .premium-pitch__label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(147, 197, 253, 0.95);
  }

  .premium-pitch__card-title {
    font-size: 1.08rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.25;
  }

  .premium-pitch__card-body {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-gray);
    flex: 1;
  }

  @media (max-width: 1024px) {
    .premium-pitch__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .premium-pitch__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
