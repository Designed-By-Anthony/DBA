---
/*
 * InlineReport.astro
 * Premium 8-section Local Digital Presence Audit Report.
 * Populated by client-side Javascript via the <inline-report> custom element.
 */
---
<inline-report class="isolate" hidden>
  <div class="lh-results">

    <!-- Report Toolbar (sticky, no-print) -->
    <div class="report-toolbar no-print" data-report-toolbar>
      <button class="toolbar-btn" data-action="print"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg> Print</button>
      <button class="toolbar-btn" data-action="download-pdf" title="Use 'Save as PDF' in your browser's print dialog"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg> Download PDF</button>
      <button class="toolbar-btn" data-action="copy-link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg> Copy Link</button>
      <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" class="toolbar-btn toolbar-btn--primary" data-calendar-link><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> Book 15-min call</a>
    </div>

    <!-- ═══════ SECTION 1: COVER PAGE ═══════ -->
    <div class="report-section report-cover">
      <div class="health-badge" data-health-badge hidden>
        <span class="health-badge__icon" data-health-icon></span>
        <span class="health-badge__label" data-health-label></span>
      </div>

      <div class="receipt-header">
        <div class="receipt-eyebrow">Local Digital Presence Audit</div>
        <h2 class="lh-results-title">Analysis Complete</h2>
        <div class="trust-score-hero" data-trust-score-container hidden>
          <div class="trust-score-value"><span data-trust-score>0</span><span class="trust-score-max">/100</span></div>
          <span class="trust-score-label">Local Trust Score</span>
        </div>
        <div class="receipt-meta">
          <span class="meta-item"><span class="meta-label">ID:</span> <span data-report-id></span></span>
          <span class="meta-item"><span class="meta-label">Target:</span> <a data-report-url target="_blank" rel="noreferrer" hidden></a></span>
          <span class="meta-item"><span class="meta-label">Run Date:</span> <span data-report-date></span></span>
        </div>
        <p class="report-prepared">Prepared by <strong>Designed by Anthony</strong></p>
      </div>
    </div>

    <div class="report-cta-band no-print">
      <div class="report-cta-band__inner">
        <p class="report-cta-band__copy">
          <strong>Turn this audit into a prioritized plan.</strong>
          Book a free 15-minute call — we translate these scores into what to fix first for leads and revenue, not vanity metrics.
        </p>
        <a
          href="https://calendly.com/anthony-designedbyanthony/web-design-consult"
          class="btn btn-primary report-cta-band__btn"
          data-calendar-link
        >
          Book a 15-minute intro call
        </a>
      </div>
    </div>

    <!-- ═══════ SECTION 2: EXECUTIVE SUMMARY ═══════ -->
    <div class="report-section" data-section-summary hidden>
      <div class="section-title-bar"><h3>Executive Summary</h3></div>
      <div class="surface-card ai-insight-card">
        <div class="ai-insight-content" data-insight-content></div>
      </div>
      <div class="strengths-weaknesses">
        <div class="sw-column sw-strengths surface-card">
          <h4>Key Strengths</h4>
          <ul data-strengths-list></ul>
        </div>
        <div class="sw-column sw-weaknesses surface-card">
          <h4>Key Weaknesses</h4>
          <ul data-weaknesses-list></ul>
        </div>
      </div>
    </div>

    <!-- ═══════ SECTION 3: TECHNICAL PERFORMANCE ═══════ -->
    <div class="report-section" data-section-technical>
      <div class="section-title-bar"><h3>Technical Performance</h3></div>

      <div class="lh-score-grid">
        <div class="lh-score-item" data-score-type="performance">
          <div class="lh-ring-wrap">
            <svg class="lh-ring-svg" viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-bg" />
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-progress" stroke-linecap="round" data-ring />
            </svg>
            <span class="lh-ring-value" data-ring-value>0</span>
          </div>
          <span class="lh-score-label">Performance</span>
        </div>
        <div class="lh-score-item" data-score-type="accessibility">
          <div class="lh-ring-wrap">
            <svg class="lh-ring-svg" viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-bg" />
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-progress" stroke-linecap="round" data-ring />
            </svg>
            <span class="lh-ring-value" data-ring-value>0</span>
          </div>
          <span class="lh-score-label">Accessibility</span>
        </div>
        <div class="lh-score-item" data-score-type="bestPractices">
          <div class="lh-ring-wrap">
            <svg class="lh-ring-svg" viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-bg" />
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-progress" stroke-linecap="round" data-ring />
            </svg>
            <span class="lh-ring-value" data-ring-value>0</span>
          </div>
          <span class="lh-score-label">Best Practices</span>
        </div>
        <div class="lh-score-item" data-score-type="seo">
          <div class="lh-ring-wrap">
            <svg class="lh-ring-svg" viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-bg" />
              <circle cx="40" cy="40" r="36" stroke-width="6" fill="transparent" class="lh-ring-progress" stroke-linecap="round" data-ring />
            </svg>
            <span class="lh-ring-value" data-ring-value>0</span>
          </div>
          <span class="lh-score-label">SEO</span>
        </div>
      </div>

      <div class="metrics-grid surface-card">
        <div class="metric"><span class="metric-label">First Contentful Paint</span><span class="metric-value" data-metric="fcp">–</span></div>
        <div class="metric"><span class="metric-label">Largest Contentful Paint</span><span class="metric-value" data-metric="lcp">–</span></div>
        <div class="metric"><span class="metric-label">Total Blocking Time</span><span class="metric-value" data-metric="tbt">–</span></div>
        <div class="metric"><span class="metric-label">Cumulative Layout Shift</span><span class="metric-value" data-metric="cls">–</span></div>
      </div>

      <div class="diagnostic-callout" data-diagnostic-callout hidden>
        <div class="callout-icon" data-callout-icon>⚠️</div>
        <div class="callout-text">
          <strong data-callout-title></strong>
          <p data-callout-body></p>
        </div>
      </div>
    </div>

    <!-- ═══════ SECTION 4: SEO & DISCOVERABILITY ═══════ -->
    <div class="report-section" data-section-seo hidden>
      <div class="section-title-bar"><h3>SEO &amp; Discoverability</h3></div>
      <div class="seo-audit-grid">
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-title-icon>–</span>
          <div class="seo-item-detail">
            <strong>Page Title</strong>
            <p class="seo-preview" data-seo-title-text>–</p>
          </div>
        </div>
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-desc-icon>–</span>
          <div class="seo-item-detail">
            <strong>Meta Description</strong>
            <p class="seo-preview" data-seo-desc-text>–</p>
          </div>
        </div>
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-h1-icon>–</span>
          <div class="seo-item-detail">
            <strong>H1 Heading Tag</strong>
            <p class="seo-preview" data-seo-h1-text>–</p>
          </div>
        </div>
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-schema-icon>–</span>
          <div class="seo-item-detail">
            <strong>LocalBusiness Schema</strong>
            <p class="seo-preview" data-seo-schema-text>Structured data for local search</p>
          </div>
        </div>
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-img-icon>–</span>
          <div class="seo-item-detail">
            <strong>Image Alt Attributes</strong>
            <p class="seo-preview" data-seo-img-text>–</p>
          </div>
        </div>
        <div class="seo-item surface-card">
          <span class="seo-check-icon" data-seo-https-icon>–</span>
          <div class="seo-item-detail">
            <strong>HTTPS Security</strong>
            <p class="seo-preview" data-seo-https-text>–</p>
          </div>
        </div>
      </div>
      <div class="seo-gsc-note surface-card">
        <h4 class="seo-gsc-note__title">Indexing &amp; backlinks (Google)</h4>
        <p class="seo-gsc-note__p">
          <strong>Indexed page count:</strong> Lighthouse cannot read Google’s index. Confirm live numbers in
          <a href="https://search.google.com/search-console" target="_blank" rel="noopener noreferrer">Google Search Console</a>
          → <em>Pages</em> (or legacy Coverage). If you see ~419 indexed, that’s the source of truth—not this scan.
        </p>
        <p class="seo-gsc-note__p">
          <strong>Backlinks:</strong> Spammy or toxic links can hurt rankings. Use Search Console → <em>Links</em> to review;
          use Google’s disavow only for clear, sustained toxic patterns—not routine outreach links.
        </p>
      </div>
    </div>

    <!-- ═══════ SECTION 5: ONLINE REPUTATION ═══════ -->
    <div class="report-section" data-section-reputation hidden>
      <div class="section-title-bar"><h3>Online Reputation</h3></div>
      <div class="lh-row-panels">
        <div class="rep-panel surface-card" data-rep-panel>
          <div class="rep-header"><h4>Your Google Profile</h4></div>
          <div class="rep-stats">
            <div class="rep-stat"><span class="rep-value-big" data-rep-rating>–</span><span class="rep-label-sub">Average Rating</span></div>
            <div class="rep-stat"><span class="rep-value-big" data-rep-count>–</span><span class="rep-label-sub">Total Reviews</span></div>
          </div>
        </div>
      </div>
      <!-- Competitor Comparison Table -->
      <div class="competitor-table-wrap surface-card" data-competitor-table hidden>
        <h4>Local Competitor Comparison</h4>
        <table class="competitor-table">
          <caption class="sr-only">Local competitor comparison showing business names, ratings, and review counts</caption>
          <thead><tr><th scope="col">Business</th><th scope="col">Rating</th><th scope="col">Reviews</th></tr></thead>
          <tbody data-competitor-tbody>
            <tr class="competitor-you"><th scope="row" data-comp-you-name>Your Business</th><td data-comp-you-rating>–</td><td data-comp-you-reviews>–</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══════ SECTION 6: CONVERSION READINESS ═══════ -->
    <div class="report-section" data-section-conversion hidden>
      <div class="section-title-bar"><h3>Conversion Readiness</h3></div>
      <div class="conv-checklist-grid">
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-tel>❌</span><span class="conv-text">Click-to-Call Phone Number</span></div>
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-forms>❌</span><span class="conv-text">Contact Form Present</span></div>
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-https>❌</span><span class="conv-text">HTTPS Enabled</span></div>
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-social>❌</span><span class="conv-text">Social Media Links</span></div>
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-schema>❌</span><span class="conv-text">LocalBusiness Schema</span></div>
        <div class="conv-check surface-card"><span class="conv-icon" data-conv-ctas>❌</span><span class="conv-text">Action-Oriented CTAs: <strong data-conv-cta-count>0</strong></span></div>
      </div>
      <div class="conv-grade-row surface-card">
        <div class="conv-grade-left">
          <span class="conv-grade-label">AI Copywriting Grade</span>
          <span class="conv-grade-score"><span data-conv-score>–</span><span class="conv-grade-max">/100</span></span>
        </div>
        <div class="conv-grade-right" data-copywriting-analysis></div>
      </div>
    </div>

    <!-- ═══════ SECTION 7: ACTION PLAN ═══════ -->
    <div class="report-section" data-section-actions hidden>
      <div class="section-title-bar"><h3>Prioritized Action Plan</h3></div>
      <div class="action-plan-list" data-action-plan></div>
    </div>

    <div class="report-cta-band report-cta-band--closing no-print">
      <div class="report-cta-band__inner">
        <p class="report-cta-band__copy">
          <strong>Ready to turn this report into booked work?</strong>
          We will prioritize the top 2-3 fixes with the highest revenue impact and give you a practical implementation sequence.
        </p>
        <a
          href="https://calendly.com/anthony-designedbyanthony/web-design-consult"
          class="btn btn-primary-book report-cta-band__btn"
          data-calendar-link
        >
          Book your 15-min strategy review
        </a>
      </div>
      <p class="report-cta-band__proof">Average post-launch Lighthouse outcomes: <strong>97+ across core categories</strong>.</p>
    </div>

    <!-- ═══════ SECTION 8: FOOTER / CTA ═══════ -->
    <div id="action-status" class="action-status-msg no-print" hidden></div>

    <div class="receipt-footer">
      <p>Report ID: <span data-report-id-footer></span> &bull; Extracted via Google APIs &bull; Built by Designed by Anthony</p>
    </div>
  </div>

  <!-- Exit Intent Modal -->
  <div class="exit-modal-overlay" data-exit-modal hidden>
    <div class="exit-modal-content surface-card">
      <button class="exit-close-btn" data-close-exit>&times;</button>
      <h3>Wait &mdash; let's fix that weakest score.</h3>
      <p>I can walk you through exactly what's failing on your site and how it's costing you leads right now. It takes 15 minutes, no sales pitch.</p>
      <div class="exit-actions">
        <a href="https://calendly.com/anthony-designedbyanthony/web-design-consult" class="btn btn-primary" data-calendar-link>Grab a free consult</a>
        <button class="btn btn-outline" data-close-exit>No thanks</button>
      </div>
    </div>
  </div>
</inline-report>

<script>
  interface CompetitorRow {
    name: string;
    rating?: number;
    reviewCount?: number;
  }

  interface PrioritizedAction {
    priority: number;
    action: string;
    impact: string;
    effort: string;
  }

  interface HtmlSignals {
    metaTitle?: string;
    metaDescription?: string;
    h1Count?: number;
    h1Text?: string;
    hasLocalBusinessSchema?: boolean;
    imgsMissingAlt?: number;
    imgCount?: number;
    hasHttps?: boolean;
    hasTelLink?: boolean;
    hasForms?: boolean;
    hasSocialLinks?: boolean;
    ctaCount?: number;
  }

  interface AiInsight {
    executiveSummary?: string;
    strengths?: string[];
    weaknesses?: string[];
    prioritizedActions?: PrioritizedAction[];
    copywritingAnalysis?: string;
    conversionScore?: number;
  }

  interface InlineReportPayload {
    reportId: string;
    url?: string;
    company?: string;
    createdAt?: { _seconds: number };
    scores?: Record<string, string | number>;
    trustScore?: number;
    conversion?: number;
    metrics?: Record<string, string>;
    diagnostics?: { failedAuditCount?: number; criticalIssue?: string };
    aiInsight?: AiInsight;
    htmlSignals?: HtmlSignals;
    places?: { found?: boolean; rating?: string; userRatingCount?: string };
    competitors?: CompetitorRow[];
  }

  class InlineReport extends HTMLElement {
    hasSetup = false;
    circ = 2 * Math.PI * 36;
    reportId: string | null = null;

    constructor() {
      super();
    }

    setReportData(data: InlineReportPayload) {
      this.removeAttribute('hidden');
      this.reportId = data.reportId;

      // Cover page meta
      this.setText('[data-report-id]', data.reportId);
      this.setText('[data-report-id-footer]', data.reportId);
      const dateStr = data.createdAt ? new Date(data.createdAt._seconds * 1000).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : new Date().toLocaleString();
      this.setText('[data-report-date]', dateStr);

      const urlEl = this.querySelector('[data-report-url]') as HTMLAnchorElement | null;
      if (urlEl) {
        const resolvedUrl = (data.url && !data.url.startsWith('http')) ? `https://${data.url}` : data.url;
        if (resolvedUrl) {
          const displayUrl = data.url || resolvedUrl;
          urlEl.textContent = displayUrl;
          urlEl.href = resolvedUrl;
          urlEl.setAttribute('aria-label', displayUrl);
          urlEl.removeAttribute('hidden');
        } else {
          urlEl.textContent = '';
          urlEl.removeAttribute('href');
          urlEl.removeAttribute('aria-label');
          urlEl.setAttribute('hidden', '');
        }
      }

      const scores = (data.scores || data) as Record<string, string | number>;
      const p = parseInt(String(scores.performance ?? ''), 10);
      const a = parseInt(String(scores.accessibility ?? ''), 10);
      const bp = parseInt(String(scores.bestPractices ?? ''), 10);
      const s = parseInt(String(scores.seo ?? ''), 10);

      this.renderRing('performance', p);
      this.renderRing('accessibility', a);
      this.renderRing('bestPractices', bp);
      this.renderRing('seo', s);

      // ── Health badge ──
      const failedCount = data.diagnostics?.failedAuditCount || 0;
      const lowScores = [p, a, bp, s].filter(v => v < 90).length;
      const criticalLow = [p, a, bp, s].filter(v => v < 50).length;

      let grade, gradeLabel, gradeClass;
      if (lowScores === 0 && failedCount === 0) {
        grade = 'green'; gradeLabel = 'All systems go — your site is technically solid.'; gradeClass = 'health-badge--green';
      } else if (criticalLow > 0 || failedCount >= 5) {
        grade = 'red';
        const parts = [];
        if (failedCount > 0) parts.push(`${failedCount} failed audits`);
        if (criticalLow > 0) parts.push(`${criticalLow} categor${criticalLow === 1 ? 'y' : 'ies'} scoring below 50`);
        gradeLabel = `Critical issues detected — ${parts.join(' and ')}.`; gradeClass = 'health-badge--red';
      } else {
        grade = 'yellow';
        gradeLabel = `${lowScores} categor${lowScores === 1 ? 'y' : 'ies'} below 90${failedCount > 0 ? ', ' + failedCount + ' background issues flagged' : ''} — room for improvement.`;
        gradeClass = 'health-badge--yellow';
      }

      const badgeEl = this.querySelector('[data-health-badge]');
      if (badgeEl) {
        badgeEl.removeAttribute('hidden');
        badgeEl.className = `health-badge ${gradeClass}`;
        this.setText('[data-health-icon]', grade === 'green' ? '✅' : grade === 'red' ? '🔴' : '🟡');
        this.setText('[data-health-label]', gradeLabel);
      }

      // ── Trust Score ──
      if (data.trustScore != null) {
        this.querySelector('[data-trust-score-container]')?.removeAttribute('hidden');
        this.setText('[data-trust-score]', data.trustScore);
      }

      // ── Metrics ──
      const metrics = data.metrics || {};
      ['fcp', 'lcp', 'tbt', 'cls'].forEach(k => {
        this.setText(`[data-metric="${k}"]`, metrics[k] || '–');
      });

      // ── Section 2: Executive Summary (AI) ──
      const ai = data.aiInsight || {};
      if (ai.executiveSummary) {
        const summarySection = this.querySelector('[data-section-summary]');
        if (summarySection) {
          summarySection.removeAttribute('hidden');
          const contentEl = this.querySelector('[data-insight-content]');
          if (contentEl) contentEl.innerHTML = ai.executiveSummary;
        }

        // Strengths list
        if (ai.strengths && ai.strengths.length > 0) {
          const sList = this.querySelector('[data-strengths-list]');
          if (sList) sList.innerHTML = ai.strengths.map((s: string) => `<li>${s}</li>`).join('');
        }

        // Weaknesses list
        if (ai.weaknesses && ai.weaknesses.length > 0) {
          const wList = this.querySelector('[data-weaknesses-list]');
          if (wList) wList.innerHTML = ai.weaknesses.map((w: string) => `<li>${w}</li>`).join('');
        }
      }

      // ── Diagnostic callout ──
      if (failedCount > 0 && grade !== 'green') {
        const callout = this.querySelector('[data-diagnostic-callout]');
        if (callout) {
          callout.removeAttribute('hidden');
          const critIssue = data.diagnostics?.criticalIssue;
          const calloutIcon = this.querySelector('[data-callout-icon]');
          if (grade === 'red') {
            this.setText('[data-callout-title]', `⚠️ Your site failed ${failedCount} Lighthouse audits.`);
            if (calloutIcon) calloutIcon.textContent = '🔴';
          } else {
            this.setText('[data-callout-title]', `${failedCount} technical issues flagged behind the scenes.`);
            if (calloutIcon) calloutIcon.textContent = '🟡';
          }
          if (critIssue && critIssue.trim()) {
            this.setText('[data-callout-body]', `The most impactful issue detected was: ${critIssue}. These are the kind of things that quietly cost you calls and local traffic.`);
          } else {
            this.setText('[data-callout-body]', `These are mostly rendering and optimization issues that slow your page down or confuse search engines.`);
          }
        }
      }

      // ── Section 4: SEO & Discoverability ──
      const hs = data.htmlSignals || {};
      if (hs.metaTitle !== undefined || hs.h1Count !== undefined) {
        this.querySelector('[data-section-seo]')?.removeAttribute('hidden');

        // Title
        const hasTitle = hs.metaTitle && hs.metaTitle.trim().length > 0;
        this.setText('[data-seo-title-icon]', hasTitle ? '✅' : '❌');
        this.setText('[data-seo-title-text]', hasTitle ? `"${hs.metaTitle}"` : 'No page title found');

        // Description
        const hasDesc = hs.metaDescription && hs.metaDescription.trim().length > 0;
        this.setText('[data-seo-desc-icon]', hasDesc ? '✅' : '❌');
        this.setText('[data-seo-desc-text]', hasDesc ? `"${hs.metaDescription}"` : 'No meta description found');

        // H1
        const goodH1 = hs.h1Count === 1;
        this.setText('[data-seo-h1-icon]', goodH1 ? '✅' : hs.h1Count === 0 ? '❌' : '🟡');
        this.setText('[data-seo-h1-text]', hs.h1Count === 0 ? 'No H1 tag found' : hs.h1Count === 1 ? `"${hs.h1Text}"` : `${hs.h1Count} H1 tags found (should be 1)`);

        // Schema
        this.setText('[data-seo-schema-icon]', hs.hasLocalBusinessSchema ? '✅' : '❌');
        this.setText('[data-seo-schema-text]', hs.hasLocalBusinessSchema ? 'LocalBusiness schema detected' : 'Not found — missing from local search results');

        // Images
        const imgGood = hs.imgsMissingAlt === 0;
        this.setText('[data-seo-img-icon]', imgGood ? '✅' : '🟡');
        this.setText(
          '[data-seo-img-text]',
          (hs.imgCount ?? 0) > 0
            ? `${hs.imgsMissingAlt ?? 0} of ${hs.imgCount} images missing alt text`
            : 'No images detected',
        );

        // HTTPS
        this.setText('[data-seo-https-icon]', hs.hasHttps ? '✅' : '❌');
        this.setText('[data-seo-https-text]', hs.hasHttps ? 'Site loads over HTTPS' : 'Not using HTTPS — browsers flag this as insecure');
      }

      // ── Section 5: Reputation & Competitors ──
      if (data.places && data.places.found) {
        this.querySelector('[data-section-reputation]')?.removeAttribute('hidden');
        this.setText('[data-rep-rating]', data.places.rating || 'N/A');
        this.setText('[data-rep-count]', data.places.userRatingCount || '0');

        // Competitor table
        if (data.competitors && data.competitors.length > 0) {
          const tableWrap = this.querySelector('[data-competitor-table]');
          if (tableWrap) {
            tableWrap.removeAttribute('hidden');
            this.setText('[data-comp-you-name]', data.company || 'Your Business');
            this.setText('[data-comp-you-rating]', data.places.rating ? `⭐ ${data.places.rating}` : 'N/A');
            this.setText('[data-comp-you-reviews]', data.places.userRatingCount || '0');

            const tbody = this.querySelector('[data-competitor-tbody]');
            if (tbody) {
              data.competitors.forEach((comp: CompetitorRow) => {
                const row = document.createElement('tr');
                row.innerHTML = `<th scope="row">${comp.name}</th><td>${comp.rating ? '⭐ ' + comp.rating : 'N/A'}</td><td>${comp.reviewCount || 0}</td>`;
                tbody.appendChild(row);
              });
            }
          }
        }
      }

      // ── Section 6: Conversion Readiness ──
      if (hs.hasTelLink !== undefined || ai.conversionScore !== undefined) {
        this.querySelector('[data-section-conversion]')?.removeAttribute('hidden');
        const setIcon = (sel: string, truthy: boolean | undefined) =>
          this.setText(sel, truthy ? '✅' : '❌');
        setIcon('[data-conv-tel]', !!hs.hasTelLink);
        setIcon('[data-conv-forms]', !!hs.hasForms);
        setIcon('[data-conv-https]', !!hs.hasHttps);
        setIcon('[data-conv-social]', !!hs.hasSocialLinks);
        setIcon('[data-conv-schema]', !!hs.hasLocalBusinessSchema);
        setIcon('[data-conv-ctas]', (hs.ctaCount || 0) > 0);
        this.setText('[data-conv-cta-count]', hs.ctaCount || '0');
        this.setText('[data-conv-score]', ai.conversionScore ?? data.conversion ?? '–');

        // Copywriting analysis
        if (ai.copywritingAnalysis) {
          const caEl = this.querySelector('[data-copywriting-analysis]');
          if (caEl) caEl.innerHTML = ai.copywritingAnalysis;
        }
      }

      // ── Section 7: Action Plan ──
      if (ai.prioritizedActions && ai.prioritizedActions.length > 0) {
        this.querySelector('[data-section-actions]')?.removeAttribute('hidden');
        const planEl = this.querySelector('[data-action-plan]');
        if (planEl) {
          planEl.innerHTML = ai.prioritizedActions.map((a: PrioritizedAction) => `
            <div class="action-item surface-card">
              <div class="action-priority">#${a.priority}</div>
              <div class="action-body">
                <p class="action-text">${a.action}</p>
                <div class="action-tags">
                  <span class="action-tag impact-${a.impact}">Impact: ${a.impact}</span>
                  <span class="action-tag effort-${a.effort}">Effort: ${a.effort}</span>
                </div>
              </div>
            </div>
          `).join('');
        }
      }

      // Calendar links
      const calLinks = this.querySelectorAll<HTMLAnchorElement>('[data-calendar-link]');
      calLinks.forEach((link) => {
        const base = 'https://calendly.com/anthony-designedbyanthony/web-design-consult';
        const url = new URL(base);
        url.searchParams.set('utm_source', 'dba_audit_report');
        url.searchParams.set('utm_medium', 'site');
        url.searchParams.set('utm_campaign', 'report_strategy_call');
        if (this.reportId) {
          url.searchParams.set('a1', this.reportId);
        }
        link.href = url.toString();
      });

      if (!this.hasSetup) {
        this.setupEventListeners();
        this.hasSetup = true;
      }
    }

    setText(selector: string, text: string | number | undefined) {
      const el = this.querySelector(selector);
      if (el) el.textContent = text === undefined || text === null ? '' : String(text);
    }

    scoreColor(score: number) {
      if (score >= 90) return '#22c55e';
      if (score >= 50) return '#f59e0b';
      return '#ef4444';
    }

    renderRing(key: string, score: string | number) {
      const item = this.querySelector(`[data-score-type="${key}"]`);
      if (!item) return;
      const ring = item.querySelector('[data-ring]') as SVGCircleElement | null;
      const value = item.querySelector('[data-ring-value]') as HTMLElement | null;
      if (!ring || !value) return;
      const scoreNum = parseInt(String(score), 10);
      const color = this.scoreColor(Number.isFinite(scoreNum) ? scoreNum : 0);
      const offset = this.circ - (scoreNum / 100) * this.circ;
      ring.style.stroke = color;
      ring.style.strokeDasharray = String(this.circ);
      setTimeout(() => {
        ring.style.strokeDashoffset = String(offset);
      }, 100);
      value.textContent = String(scoreNum);
      value.style.color = color;
    }

    setupEventListeners() {
      const reportUrlLink = this.querySelector<HTMLAnchorElement>('[data-report-url]');
      if (reportUrlLink && !reportUrlLink.dataset.labelSyncBound) {
        reportUrlLink.dataset.labelSyncBound = 'true';
        const syncLabel = () => {
          const text = (reportUrlLink.textContent || '').replace(/\s+/g, ' ').trim();
          if (text) reportUrlLink.setAttribute('aria-label', text);
        };
        syncLabel();
        const observer = new MutationObserver(syncLabel);
        observer.observe(reportUrlLink, { childList: true, characterData: true, subtree: true });
      }

      const copyBtn = this.querySelector('[data-action="copy-link"]');
      const statusEl = this.querySelector('#action-status') as HTMLElement | null;
      const showStatus = (msg: string, type = 'info') => {
        if (statusEl) {
          statusEl.textContent = msg;
          statusEl.className = `action-status-msg action-status--${type}`;
          statusEl.hidden = false;
          setTimeout(() => {
            statusEl.hidden = true;
          }, 5000);
        }
      };

      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          if (!this.reportId) return;
          const reportUrl = `${window.location.origin}/report/${this.reportId}`;
          try {
            await navigator.clipboard.writeText(reportUrl);
            copyBtn.textContent = '✓ Copied!';
            showStatus(`Link copied: ${reportUrl}`, 'success');
            setTimeout(() => { copyBtn.textContent = '🔗 Copy Report Link'; }, 3000);
          } catch {
            copyBtn.textContent = '✓ Copied!';
            showStatus(`Link copied: ${reportUrl}`, 'success');
            setTimeout(() => { copyBtn.textContent = '🔗 Copy Report Link'; }, 3000);
          }
        });
      }

      // Print
      const pdfBtn = this.querySelector('[data-action="download-pdf"]');
      if (pdfBtn) {
        pdfBtn.addEventListener('click', () => window.print());
      }

      // Exit Intent
      let exitTriggered = false;
      const overlay = this.querySelector('[data-exit-modal]');
      const closeBtns = this.querySelectorAll('[data-close-exit]');

      document.addEventListener('mouseleave', (e) => {
        if (e.clientY < 0 && !exitTriggered && this.reportId) {
          exitTriggered = true;
          if (overlay) overlay.removeAttribute('hidden');
        }
      });

      closeBtns.forEach(b => {
        b.addEventListener('click', () => {
          if (overlay) overlay.setAttribute('hidden', '');
        });
      });

      // Close on backdrop click (outside the modal content)
      if (overlay) {
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) overlay.setAttribute('hidden', '');
        });
      }
    }
  }

  if (!customElements.get('inline-report')) {
    customElements.define('inline-report', InlineReport);
  }
</script>

