---
const fallbackHref = "/blog";
---

<div class="blog-back-wrap">
  <a href={fallbackHref} class="blog-back-button" data-blog-back-button>
    <svg viewBox="0 0 24 24" aria-hidden="true" class="blog-back-icon">
      <path d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    <span>Back to Blog</span>
  </a>
</div>

<style>
  .blog-back-wrap {
    margin-bottom: 2rem;
  }

  .blog-back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--text-white);
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    backdrop-filter: blur(14px);
    box-shadow: 0 18px 35px -24px rgba(0, 0, 0, 0.8);
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
  }

  .blog-back-button:hover {
    transform: translateY(-2px);
    border-color: rgba(37, 99, 235, 0.45);
    background: rgba(37, 99, 235, 0.08);
    box-shadow: 0 24px 45px -28px rgba(37, 99, 235, 0.45);
  }

  .blog-back-icon {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    stroke-width: 2.25;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 768px) {
    .blog-back-wrap {
      margin-bottom: 1.5rem;
    }

    .blog-back-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
