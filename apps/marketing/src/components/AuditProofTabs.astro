---
export interface Props {
	eyebrow?: string;
	title?: string;
	description?: string;
	variant?: "default" | "premium";
	beforeBadge?: string;
	beforeHeading?: string;
	beforeDescription?: string;
	afterBadge?: string;
	afterHeading?: string;
	afterDescription?: string;
}

const {
	eyebrow = "Before and After",
	title = "A cleaner look at the kind of technical gap we fix.",
	description = "Flip between a redacted sample audit and the benchmark from this site. Both examples shown here are mobile Lighthouse runs captured in Chrome private mode on the same MacBook setup.",
	variant = "default",
	beforeBadge = "Redacted sample",
	beforeHeading = "Heavier stack. More friction.",
	beforeDescription = "This is the kind of drag we usually find in template-heavy builds: slower loading, weaker accessibility, and more moving parts than most owners realize.",
	afterBadge = "Our benchmark",
	afterHeading = "Leaner stack. Cleaner result.",
	afterDescription = "The goal is not vanity scores. The goal is a cleaner site that loads faster, feels more trustworthy, and gives you a stronger base for search and conversion.",
} = Astro.props;

const beforeImageVersion = "20260402-redacted";

const panels = [
	{
		id: "before",
		tabId: "audit-proof-tab-before",
		panelId: "audit-proof-panel-before",
		title: "Before",
		badge: beforeBadge,
		heading: beforeHeading,
		description: beforeDescription,
		image: `/images/audit-before-report.png?v=${beforeImageVersion}`,
		imageAlt:
			"Redacted sample Lighthouse audit showing lower scores before technical cleanup.",
	},
	{
		id: "after",
		tabId: "audit-proof-tab-after",
		panelId: "audit-proof-panel-after",
		title: "After",
		badge: afterBadge,
		heading: afterHeading,
		description: afterDescription,
		image: "/images/audit-after-report.png",
		imageAlt:
			"Designed by Anthony Lighthouse report showing strong after-cleanup scores.",
	},
];

const comparisonStats = [
	{
		label: "Performance",
		before: "73",
		after: "100",
	},
	{
		label: "LCP",
		before: "6.3s",
		after: "1.3s",
	},
	{
		label: "Accessibility",
		before: "75",
		after: "100",
	},
];
---

<section class:list={['section-shell', 'audit-proof-shell', variant === 'premium' && 'audit-proof-shell-premium']}>
  <div class="section-container">
    <div class:list={['section-header', 'centered', 'audit-proof-header', variant === 'premium' && 'audit-proof-header-premium']}>
      <p class="section-eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class:list={['surface-card', 'audit-proof-card', 'reveal-up', variant === 'premium' && 'audit-proof-card-premium']} data-tabbed-proof>
      <div class="audit-proof-tabs" role="tablist" aria-label="Audit proof examples">
        {panels.map((panel, index) => (
          <button
            type="button"
            class="audit-proof-tab"
            id={panel.tabId}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls={panel.panelId}
            tabindex={index === 0 ? '0' : '-1'}
            data-tab-trigger
            data-tab-target={panel.id}
          >
            {panel.title}
          </button>
        ))}
      </div>

      {panels.map((panel, index) => (
        <section
          class="audit-proof-panel"
          id={panel.panelId}
          role="tabpanel"
          aria-labelledby={panel.tabId}
          data-tab-panel={panel.id}
          hidden={index === 0 ? undefined : true}
        >
          <div class="audit-proof-panel-copy">
            <span class="card-tag">{panel.badge}</span>
            <h3>{panel.heading}</h3>
            <p>{panel.description}</p>
            <details class="audit-proof-details">
              <summary class="audit-proof-toggle">View full report ▸</summary>
              <div class="audit-proof-image-frame">
                <img
                  src={panel.image}
                  alt={panel.imageAlt}
                  width="1224"
                  height="1584"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </details>
          </div>
        </section>
      ))}

      <div class="audit-proof-stats">
        {comparisonStats.map((item) => (
          <article class="audit-proof-stat">
            <p class="audit-proof-stat-label">{item.label}</p>
            <h3>
              <span class="audit-proof-before">{item.before}</span>
              <span class="audit-proof-arrow" aria-hidden="true">to</span>
              <span class="audit-proof-after">{item.after}</span>
            </h3>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .audit-proof-shell {
    padding-top: 2.75rem;
  }

  .audit-proof-header {
    max-width: 720px;
  }

  .audit-proof-shell-premium {
    padding-top: 1.25rem;
  }

  .audit-proof-header-premium {
    max-width: 780px;
    margin-bottom: 1.85rem;
  }

  .audit-proof-card {
    padding: 1.15rem;
  }

  .audit-proof-card-premium {
    padding: 1.2rem;
    border-radius: 1.65rem;
    border-color: rgba(96, 165, 250, 0.16);
    background:
      radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 30%),
      radial-gradient(circle at 84% 12%, rgba(37, 99, 235, 0.08), transparent 22%),
      linear-gradient(180deg, rgba(8, 14, 24, 0.98) 0%, rgba(11, 18, 32, 0.98) 52%, rgba(13, 21, 36, 0.94) 100%);
    box-shadow: var(--shadow-card);
  }

  .audit-proof-tabs {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1rem;
    padding: 0.3rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .audit-proof-tab {
    appearance: none;
    border: 0;
    border-radius: 999px;
    padding: 0.68rem 1rem;
    background: transparent;
    color: var(--text-gray);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .audit-proof-tab[aria-selected='true'] {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.95), rgba(59, 130, 246, 0.88));
    color: #eff6ff;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
  }

  .audit-proof-card-premium .audit-proof-tabs {
    background: rgba(7, 12, 21, 0.54);
    border-color: rgba(96, 165, 250, 0.12);
  }

  .audit-proof-tab:hover {
    color: var(--text-white);
  }

  .audit-proof-tab:active {
    transform: scale(0.96);
  }

  .audit-proof-panel {
    display: block;
  }

  .audit-proof-panel[hidden] {
    display: none;
  }

  .audit-proof-panel-copy {
    padding: 0.45rem 0.15rem 0.25rem;
  }

  .audit-proof-panel-copy h3 {
    font-size: clamp(1.55rem, 2.5vw, 2.2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0.9rem 0 0.7rem;
  }

  .audit-proof-panel-copy p {
    color: var(--text-gray);
    margin: 0;
    max-width: 52ch;
    line-height: 1.72;
  }

  .audit-proof-details {
    margin-top: 1rem;
  }

  .audit-proof-toggle {
    cursor: pointer;
    color: var(--accent-blue);
    font-weight: 700;
    font-size: 0.92rem;
    list-style: none;
    user-select: none;
  }

  .audit-proof-toggle::-webkit-details-marker {
    display: none;
  }

  .audit-proof-details[open] .audit-proof-toggle {
    margin-bottom: 1rem;
  }

  .audit-proof-details[open] .audit-proof-toggle::after {
    content: ' ▾';
  }

  .audit-proof-details:not([open]) .audit-proof-toggle::after {
    content: '';
  }

  .audit-proof-card-premium .audit-proof-panel-copy h3 {
    font-size: clamp(1.75rem, 2.7vw, 2.45rem);
  }

  .audit-proof-card-premium .audit-proof-panel-copy p {
    max-width: 38ch;
    line-height: 1.8;
  }

  .audit-proof-image-frame {
    width: 100%;
    max-width: 600px;
    border-radius: 1.3rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 18px 42px rgba(2, 6, 23, 0.24);
  }

  .audit-proof-card-premium .audit-proof-image-frame {
    border-radius: 1.45rem;
    border-color: rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      rgba(8, 15, 28, 0.4);
    box-shadow:
      0 24px 50px rgba(2, 6, 23, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .audit-proof-image-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .audit-proof-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .audit-proof-stat {
    padding: 0.85rem 0.95rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .audit-proof-card-premium .audit-proof-stat {
    background: rgba(8, 15, 28, 0.5);
    border-color: rgba(96, 165, 250, 0.12);
  }

  .audit-proof-stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.55rem;
  }

  .audit-proof-stat h3 {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    margin: 0;
    font-size: 1.3rem;
    line-height: 1;
  }

  .audit-proof-before {
    color: rgba(248, 113, 113, 0.98);
  }

  .audit-proof-after {
    color: #86efac;
  }

  .audit-proof-arrow {
    color: #bfdbfe;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 980px) {
    .audit-proof-panel {
      grid-template-columns: 1fr;
    }

    .audit-proof-panel-copy {
      padding: 0.35rem 0.15rem 0;
    }

    .audit-proof-image-frame {
      max-width: none;
      justify-self: stretch;
    }
  }

  @media (max-width: 720px) {
    .audit-proof-tabs {
      width: 100%;
      justify-content: space-between;
    }

    .audit-proof-tab {
      flex: 1 1 0;
      text-align: center;
    }

    .audit-proof-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
