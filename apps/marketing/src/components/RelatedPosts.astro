---
export interface RelatedPost {
	title: string;
	href: string;
	description: string;
	image?: string;
	imageAlt?: string;
	tag?: string;
}

interface Props {
	posts: RelatedPost[];
	heading?: string;
}

const { posts, heading = "Keep Reading" } = Astro.props;
---

<section class="related-posts-section">
  <div class="related-posts-inner">
    <div class="related-header">
      <p class="section-eyebrow">Related Articles</p>
      <h2 class="related-heading">{heading}</h2>
    </div>
    <div class="related-grid">
      {posts.map((post) => (
        <a href={post.href} class="related-card surface-card">
          {post.image && (
            <div class="related-image-wrap">
              <img
                src={post.image}
                alt={post.imageAlt ?? post.title}
                width="480"
                height="270"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
          <div class="related-copy">
            {post.tag && <span class="card-tag">{post.tag}</span>}
            <h3>{post.title}</h3>
            <p>{post.description}</p>
            <span class="related-arrow">Read article</span>
          </div>
        </a>
      ))}
    </div>

    <div class="related-blog-link">
      <a href="/blog" class="btn btn-outline">View All Articles</a>
    </div>
  </div>
</section>

<style>
  .related-posts-section {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin-top: 4rem;
    padding-top: 3.5rem;
    padding-bottom: 3rem;
  }

  .related-posts-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .related-header {
    margin-bottom: 2rem;
  }

  .related-heading {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-top: 0.4rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: rgba(96, 165, 250, 0.28);
  }

  .related-image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
  }

  .related-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.35s ease;
  }

  .related-card:hover .related-image-wrap img {
    transform: scale(1.04);
  }

  .related-copy {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .related-copy h3 {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text-white);
    margin: 0;
  }

  .related-copy p {
    font-size: 0.875rem;
    color: var(--text-gray);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .related-arrow {
    font-size: 0.82rem;
    font-weight: 700;
    color: #bfdbfe;
    margin-top: 0.25rem;
  }

  .related-blog-link {
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }

</style>
