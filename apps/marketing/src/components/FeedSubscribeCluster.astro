---
export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
  note?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  note = 'Heads up: RSS links open raw XML in a new tab (best used with a feed reader).',
} = Astro.props;

const isRawXmlLink = (href: string): boolean => /\.xml(?:$|[?#])/.test(href);
const primaryIsRawXml = isRawXmlLink(primaryHref);
const secondaryIsRawXml = isRawXmlLink(secondaryHref);
---

<div class="feed-subscribe-shell">
  <div class="feed-subscribe-card">
    <p class="feed-subscribe-eyebrow">{eyebrow}</p>
    <div class="feed-subscribe-copy">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="feed-subscribe-actions">
      <a
        href={primaryHref}
        class="btn btn-white"
        target={primaryIsRawXml ? '_blank' : undefined}
        rel={primaryIsRawXml ? 'noopener noreferrer' : undefined}
      >
        {primaryLabel}
        {primaryIsRawXml && <span class="sr-only"> (opens raw XML in new tab)</span>}
      </a>
      <a
        href={secondaryHref}
        class="btn btn-outline"
        target={secondaryIsRawXml ? '_blank' : undefined}
        rel={secondaryIsRawXml ? 'noopener noreferrer' : undefined}
      >
        {secondaryLabel}
        {secondaryIsRawXml && <span class="sr-only"> (opens raw XML in new tab)</span>}
      </a>
    </div>

    <p class="feed-subscribe-note">{note}</p>
  </div>
</div>

<style>
  .feed-subscribe-shell {
    margin-top: 1.6rem;
  }

  .feed-subscribe-eyebrow {
    margin: 0 0 0.45rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(191, 219, 254, 0.82);
  }

  .feed-subscribe-card {
    padding: 1.05rem 1.1rem 1rem;
    border-radius: 1.45rem;
    background:
      radial-gradient(circle at top right, rgba(96, 165, 250, 0.16), transparent 34%),
      linear-gradient(145deg, rgba(9, 15, 28, 0.92) 0%, rgba(14, 24, 42, 0.9) 100%);
    border: 1px solid rgba(96, 165, 250, 0.16);
    box-shadow:
      0 28px 70px -46px rgba(15, 23, 42, 0.96),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
  }

  .feed-subscribe-copy h2 {
    margin: 0;
    font-size: clamp(1rem, 1.8vw, 1.22rem);
    line-height: 1.18;
    letter-spacing: -0.04em;
    color: var(--text-white);
  }

  .feed-subscribe-copy p {
    margin: 0.55rem 0 0;
    max-width: 54rem;
    color: rgba(226, 232, 240, 0.82);
    line-height: 1.62;
    font-size: 0.94rem;
  }

  .feed-subscribe-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.95rem;
  }

  .feed-subscribe-note {
    margin: 0.7rem 0 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: rgba(226, 232, 240, 0.62);
  }

  @media (max-width: 768px) {
    .feed-subscribe-card {
      padding: 1rem;
      border-radius: 1.2rem;
    }

    .feed-subscribe-actions {
      flex-direction: column;
    }

    .feed-subscribe-actions .btn {
      width: 100%;
    }
  }
</style>
