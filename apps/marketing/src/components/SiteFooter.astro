---
import { Image } from 'astro:assets';
import iconLogo from '../assets/IconLogo.png';
---

<footer class="footer" id="contact">
  <div class="footer-container">
    <a href="/" class="footer-logo-link" aria-label="Designed by Anthony home" data-astro-prefetch>
      <Image
        src={iconLogo}
        alt="Designed by Anthony Logo"
        widths={[48, 96]}
        sizes="36px"
        width={48}
        class="footer-logo"
      />
    </a>

    <div class="footer-link-column">
      <p class="footer-heading">Explore</p>
      <div class="footer-link-list">
        <a href="/services" data-astro-prefetch>Services</a>
        <a href="/pricing" data-astro-prefetch>Pricing</a>
        <a href="/service-areas" data-astro-prefetch>Areas</a>
        <a href="/portfolio" data-astro-prefetch>Portfolio</a>
        <a href="/blog" data-astro-prefetch>Blog</a>
      </div>
    </div>

    <div class="footer-link-column">
      <p class="footer-heading">Reach Out</p>
      <div class="footer-link-list">
        <a href="/contact" data-astro-prefetch>Contact</a>
        <a href="tel:+13159225592">(315) 922-5592</a>
        <a href="/about" data-astro-prefetch>About</a>
      </div>
    </div>

    <div class="footer-link-column">
      <p class="footer-heading">Connect</p>
      <div class="footer-social-links">
        <a href="https://share.google/c4NOQf9hkRWAN32rO" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Google Business Profile (opens in new window)</span>
          <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
          </svg>
          Google
        </a>
        <a href="https://www.yelp.com/biz/designed-by-anthony-rome-2" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Yelp Profile (opens in new window)</span>
          <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12.51 10.66c-.49-.78-.07-1.55 1.25-2.2l5.44-2.68c1.24-.61 2.22-.05 2.19 1.25l-.12 6.06c-.03 1.3-.99 2.02-2.14 1.6l-5.69-2.05c-1.15-.42-1.42-1.21-.93-1.98zm-1.04-1.28c-.68.61-1.35.61-1.91.01l-4.14-4.47C4.85 4.3 5.09 3.25 6.42 2.89l5.88-1.59c1.33-.36 2.07.28 1.63 1.41l-2.46 5.56zm-1.1-1.63z" fill="#D32323"></path>
            <path d="M6.3 16.59c.73-1.07 1.58-.93 2.45.39l3.35 5.06c1.07 1.61.35 2.41-.99 2.17l-5.68-.99C4.09 23 3.48 21.94 4 20.8l2.3-4.21zM20.89 17.5l-5.63-2.03c-1.14-.41-1.95-.08-2.31 1.01l-1.89 5.76c-.45 1.37.1 2.41 1.22 2.3l6.04-.62c1.12-.11 1.83-1.14 1.57-2.3z" fill="#D32323"></path>
          </svg>
          Yelp
        </a>
        <a href="https://www.facebook.com/profile.php?id=61574388797744" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Facebook Profile (opens in new window)</span>
          <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.03 4.39 11.03 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.03 1.79-4.71 4.53-4.71 1.31 0 2.68.24 2.68.24v2.98h-1.51c-1.49 0-1.95.93-1.95 1.88v2.26h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z" fill="#1877F2"></path>
          </svg>
          Facebook
        </a>
        <a href="https://www.instagram.com/dbastudio315/" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Instagram Profile (opens in new window)</span>
          <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill="#E4405F" d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5z"></path>
            <path fill="#E4405F" d="M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4z"></path>
            <circle cx="17.4" cy="6.6" r="1.2" fill="#E4405F"></circle>
          </svg>
          Instagram
        </a>
      </div>
    </div>

    <a href="https://locallyownedandoperated.org/" target="_blank" rel="nofollow noopener noreferrer" class="footer-badge-link" aria-label="Locally Owned and Operated (opens in new window)">
      <img src="/images/local-owned-badge.png" width="88" height="100" alt="" loading="lazy" />
      <span>Locally Owned</span>
    </a>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Designed by Anthony</p>
      <span class="footer-sep">·</span>
      <a href="/privacy" data-astro-prefetch>Privacy</a>
      <a href="/terms" data-astro-prefetch>Terms</a>
      <a href="/cookie" data-astro-prefetch>Cookies</a>
      <a href="/image-license" data-astro-prefetch>Image license</a>
      <span class="footer-sep">·</span>
      <button type="button" class="footer-cookie-settings" data-cookie-settings>
        Cookie settings
      </button>
      <span class="footer-sep">·</span>
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="astro-badge" aria-label="Built with Astro (opens in new window)">
        <img src="/images/built-with-astro.svg" alt="Built with Astro" width="100" height="16" loading="lazy" />
      </a>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background:
      radial-gradient(circle at top center, rgba(37, 99, 235, 0.08), transparent 24%),
      linear-gradient(180deg, #05070d 0%, #020307 100%);
    padding: 4rem var(--container-gutter) 2.2rem;
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-blue), transparent);
  }

  .footer-container {
    max-width: var(--content-max);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2.5rem;
  }

  .footer-logo-link {
    display: inline-flex;
    flex-shrink: 0;
  }

  .footer-logo {
    width: 36px;
    height: auto;
  }

  .footer-link-column {
    flex: 1;
    min-width: 0;
  }

  .footer-social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.88rem;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer-social-links a:hover {
    color: var(--accent-blue);
  }

  .footer-social-links svg {
    flex-shrink: 0;
  }

  .footer-heading {
    margin: 0 0 0.7rem;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(147, 197, 253, 0.88);
  }

  .footer-link-list {
    display: grid;
    gap: 0.5rem;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .footer-link-list a {
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.25s ease;
  }

  .footer-link-list a:hover {
    color: var(--accent-blue);
  }

  .footer-badge-link {
    flex-shrink: 0;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 116px;
    min-height: 116px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 0.3s ease;
  }

  .footer-badge-link:hover {
    opacity: 0.85;
  }

  .footer-badge-link img {
    width: 76px;
    height: 86px;
    display: block;
    object-fit: contain;
  }

  .footer-bottom {
    width: 100%;
    padding-top: 0.6rem;
    margin-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.75rem;
  }

  .footer-bottom p,
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.72rem;
    margin: 0;
    text-decoration: none;
  }

  .footer-bottom a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-bottom .footer-cookie-settings {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.72rem;
    text-decoration: none;
  }

  .footer-bottom .footer-cookie-settings:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-sep {
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.72rem;
  }

  .footer-meta-list span {
    color: rgba(255, 255, 255, 0.58);
  }

  .footer-tech-strip {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tech-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.5);
  }

  .astro-badge {
    opacity: 0.7;
    transition: opacity 0.3s ease;
    display: inline-flex;
    align-items: center;
    min-width: 100px;
    min-height: 16px;
    line-height: 0;
  }

  .astro-badge img {
    display: block;
    width: 100px;
    height: 16px;
  }

  .astro-badge:hover {
    opacity: 1;
  }

  .footer-legal {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }

    .footer-brand,
    .footer-badge-card {
      max-width: none;
    }

    .footer-badge-card {
      justify-items: center;
      text-align: center;
    }

    .footer-link-columns {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
