---
import Layout from '../layouts/Layout.astro';
import LinkClusterSection, { type LinkClusterItem } from './LinkClusterSection.astro';
import SourceList from './SourceList.astro';
import {
  DEFAULT_SOCIAL_IMAGE,
  buildFaqPageSchema,
  buildLighthouseSoftwareApplicationSchema,
  type SchemaValue,
} from '../lib/seo';
import { PUBLIC_PRICING_PILL } from '../lib/offers';

interface SupportingBlock {
  level: 'h4' | 'h5';
  title: string;
  paragraphs: string[];
}

interface DetailBlock {
  title: string;
  paragraphs: string[];
  supporting?: SupportingBlock[];
}

interface SourceItem {
  label: string;
  note?: string;
  url: string;
}

interface PricingCard {
  label: string;
  amount: string;
  period?: string;
  badge?: string;
  description?: string;
  features: string[];
  recommended?: boolean;
}

interface PricingSection {
  title: string;
  intro?: string;
  cards: PricingCard[];
}

interface FaqEntry {
  question: string;
  answer: string;
}

export interface Props {
  title: string;
  description: string;
  breadcrumbLabel: string;
  schema: SchemaValue;
  serviceNumber: string;
  heroTitle: string;
  heroDescription: string;
  pricingNote: string;
  heroPills?: string[];
  image: string;
  socialImage?: string;
  imageAlt: string;
  imageWidth?: number;
  imageHeight?: number;
  sectionTitle: string;
  sectionIntro?: string;
  detailBlocks: DetailBlock[];
  sourcesTitle?: string;
  sourcesIntro?: string;
  sourcesItems?: SourceItem[];
  pricingSection?: PricingSection;
  faqEntries?: FaqEntry[];
  relatedAreas?: LinkClusterItem[];
  relatedArticles?: LinkClusterItem[];
  ctaTitle: string;
  ctaDescription: string;
}

const {
  title,
  description,
  breadcrumbLabel,
  schema,
  serviceNumber,
  heroTitle,
  heroDescription,
  pricingNote,
  heroPills = ['Performance-first builds', 'Built for service businesses', PUBLIC_PRICING_PILL],
  image,
  socialImage = DEFAULT_SOCIAL_IMAGE,
  imageAlt,
  imageWidth = 2070,
  imageHeight = 1380,
  sectionTitle,
  sectionIntro,
  detailBlocks,
  sourcesTitle = 'Why We Say This',
  sourcesIntro,
  sourcesItems = [],
  pricingSection,
  faqEntries = [],
  relatedAreas = [],
  relatedArticles = [],
  ctaTitle,
  ctaDescription,
} = Astro.props;

const faqSchema = faqEntries.length > 0 ? buildFaqPageSchema(faqEntries) : null;
const softwareSchema = buildLighthouseSoftwareApplicationSchema();
const pageSchemas: SchemaValue[] = [
  ...(Array.isArray(schema) ? schema : [schema]),
  ...(faqSchema ? [faqSchema] : []),
  softwareSchema,
];
---

<Layout
  title={title}
  description={description}
  breadcrumbLabel={breadcrumbLabel}
  image={image}
  socialImage={socialImage}
  schema={pageSchemas}
  footerCta={{
    eyebrow: 'Free Website Audit',
    title: ctaTitle,
    description: ctaDescription,
    primaryHref: '/contact',
    primaryLabel: 'Get a Free Website Audit',
    secondaryHref: 'https://calendly.com/anthony-designedbyanthony/web-design-consult',
    secondaryLabel: 'Book a 15-minute intro call',
  }}
>
  <section class="page-hero">
    <div class="page-hero-inner hero-grid service-hero-grid">
      <div class="service-hero-copy">
        <p class="page-eyebrow">Service {serviceNumber}</p>
        <h1>{heroTitle}</h1>
        <p>{heroDescription}</p>
        <div class="pricing-note">
          <strong>{pricingNote}</strong>
        </div>
        <div class="hero-actions">
          <a href="/free-seo-audit" class="btn btn-primary">Run the Free Audit</a>
          <a href="/services" class="btn btn-outline">View All Services</a>
        </div>
        <div class="hero-meta-row">
          {heroPills.map((pill) => <span class="mini-pill">{pill}</span>)}
        </div>
      </div>

      <div class="surface-card service-hero-media reveal-up">
        <img
          src={image}
          alt={imageAlt}
          width={imageWidth}
          height={imageHeight}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section class="section-shell section-shell--technical">
    <div class="section-container">
      <div class="section-header centered service-detail-header">
        <p class="section-eyebrow">What This Includes</p>
        <h2>{sectionTitle}</h2>
        {sectionIntro && <p>{sectionIntro}</p>}
      </div>

      <div class="service-detail-grid">
        {detailBlocks.map((block) => (
          <article class="surface-card surface-card--editorial service-detail-card reveal-up">
            <h3>{block.title}</h3>
            {block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

            {block.supporting?.map((support) => {
              const HeadingTag = support.level;

              return (
                <Fragment>
                  <HeadingTag>{support.title}</HeadingTag>
                  {support.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                </Fragment>
              );
            })}
          </article>
        ))}
      </div>

      {sourcesItems.length > 0 && (
        <SourceList
          title={sourcesTitle}
          intro={sourcesIntro}
          items={sourcesItems}
          compact={true}
        />
      )}
    </div>
  </section>

  <slot name="mid-content" />

  {
    pricingSection && (
      <section class="section-shell section-shell--proof service-pricing-shell">
        <div class="section-container">
          <div class="section-header centered service-detail-header pricing-header">
            <p class="section-eyebrow section-eyebrow--pulse">Pricing</p>
            <h2>{pricingSection.title}</h2>
            {pricingSection.intro && <p>{pricingSection.intro}</p>}
          </div>

          <div class="service-pricing-grid">
            {pricingSection.cards.map((card) => (
              <article class:list={['surface-card', 'surface-card--proof', 'service-pricing-card', card.recommended && 'recommended']}>
                <div class="service-pricing-top">
                  <span class="card-tag">{card.label}</span>
                  {card.badge && <span class="service-pricing-badge">{card.badge}</span>}
                </div>
                <h3>
                  {card.amount}
                  {card.period && <span>{card.period}</span>}
                </h3>
                {card.description && <p>{card.description}</p>}
                <ul class="trust-list service-pricing-list">
                  {card.features.map((feature) => <li>{feature}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    faqEntries.length > 0 && (
      <section class="section-shell section-shell--editorial service-faq-shell">
        <div class="section-container">
          <div class="section-header centered service-detail-header">
            <p class="section-eyebrow section-eyebrow--pulse">Common Questions</p>
            <h2>Questions we hear before a project starts</h2>
            <p>
              Straight answers about fit, pricing, and what this service actually changes for your
              business.
            </p>
          </div>

          <div class="service-faq-list" data-faq-accordion>
            {faqEntries.map((entry) => (
              <div class="faq-item surface-card reveal-up">
                <button class="faq-trigger" aria-expanded="false" type="button">
                  <span class="faq-icon"></span>
                  <span class="faq-title">{entry.question}</span>
                </button>
                <div class="faq-panel">
                  <div class="faq-panel-inner">
                    <div class="faq-content">
                      <p>{entry.answer}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <LinkClusterSection
    eyebrow="Service Areas"
    title="Markets where this service can gain traction"
    intro="These location pages show how the strategy adapts to different levels of competition and buyer intent."
    items={relatedAreas}
    ctaHref="/service-areas"
    ctaLabel="View All Service Areas"
  />

  <LinkClusterSection
    eyebrow="Related Articles"
    title="Supporting articles that deepen the strategy"
    intro="These guides go further into the technical and SEO decisions that make the service work."
    items={relatedArticles}
    ctaHref="/blog"
    ctaLabel="View All Articles"
  />

</Layout>

<style>
  .service-hero-grid {
    align-items: center;
  }

  .service-hero-copy {
    max-width: 620px;
  }

  .service-hero-media {
    overflow: hidden;
    padding: 1rem;
  }

  .service-hero-media img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
    object-fit: cover;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .service-detail-header {
    max-width: 820px;
  }

  .service-detail-grid,
  .service-pricing-grid,
  .service-faq-list {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 1024px) {
    .service-detail-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }

    .service-detail-grid .service-detail-card:nth-child(2n) {
      --card-stagger-offset: 1.25rem;
    }
  }

  .service-detail-card,
  .service-pricing-card {
    padding: 2rem;
  }

  .service-detail-card {
    --card-stagger-offset: 0px;
    transform: translateY(var(--card-stagger-offset));
  }

  .service-detail-card:hover {
    transform: translateY(calc(var(--card-stagger-offset) - 2px));
  }

  .service-detail-card h3,
  .service-pricing-card h3 {
    font-size: 1.45rem;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin-bottom: 0.8rem;
  }

  .service-detail-card h4 {
    font-size: 1.08rem;
    color: var(--text-white);
    margin: 1.4rem 0 0.45rem;
    letter-spacing: -0.02em;
  }

  .service-detail-card h5 {
    font-size: 0.82rem;
    color: #93c5fd;
    margin: 1.2rem 0 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .service-detail-card p,
  .service-pricing-card p {
    color: var(--text-gray);
  }

  .service-pricing-shell {
    padding-top: 0;
  }

  .service-faq-shell {
    padding-top: 0;
  }

  .pricing-header {
    margin-bottom: 2rem;
  }

  .service-pricing-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .service-pricing-card.recommended {
    border-color: rgba(96, 165, 250, 0.28);
  }

  .service-pricing-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .service-pricing-badge {
    color: #93c5fd;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .service-pricing-card h3 {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .service-pricing-card h3 span {
    color: var(--text-gray);
    font-size: 0.94rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .service-pricing-list {
    margin-top: 1rem;
  }

  .service-faq-list {
    max-width: 920px;
    margin: 0 auto;
  }

  .faq-item {
    overflow: hidden;
  }

  .faq-trigger {
    width: 100%;
    padding: 1.7rem 1.8rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }

  .faq-trigger:focus-visible {
    outline: 2px solid rgba(96, 165, 250, 0.4);
    outline-offset: -2px;
  }

  .faq-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background-color: var(--accent-blue);
    border-radius: 2px;
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  .faq-icon::before {
    top: 9px;
    left: 0;
    width: 20px;
    height: 3px;
  }

  .faq-icon::after {
    top: 0;
    left: 9px;
    width: 3px;
    height: 20px;
  }

  .faq-trigger[aria-expanded='true'] .faq-icon::after {
    opacity: 0;
    transform: scaleY(0);
  }

  .faq-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-white);
    line-height: 1.5;
  }

  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  .faq-panel.is-open {
    grid-template-rows: 1fr;
  }

  .faq-panel-inner {
    overflow: hidden;
  }

  .faq-content {
    padding: 0 1.8rem 1.6rem 3.8rem;
  }

  .faq-content p {
    color: var(--text-gray);
    line-height: 1.75;
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .service-pricing-grid {
      grid-template-columns: 1fr;
    }

    .faq-trigger {
      padding: 1.35rem 1.25rem;
    }

    .faq-content {
      padding: 0 1.25rem 1.2rem;
    }

    .faq-title {
      font-size: 1.05rem;
    }
  }
</style>
