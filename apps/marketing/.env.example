# Copy to `.env` for local overrides (not committed).

# Sentry — create projects at https://sentry.io/for/astro (marketing) and set the browser DSN.
# Build uploads (source maps): set SENTRY_AUTH_TOKEN in CI; optional SENTRY_ORG / SENTRY_PROJECT
# override defaults (designed-by-anthony / marketing).
# PUBLIC_SENTRY_DSN=https://...@o....ingest...sentry.io/PROJECT_ID
# Optional: server-only DSN if you split browser vs SSR projects (else PUBLIC_SENTRY_DSN is used).
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=designed-by-anthony
# SENTRY_PROJECT=marketing
# Optional: tag CSP reports with environment in Sentry (defaults omitted if unset).
# SENTRY_CSP_ENVIRONMENT=production

# Playwright: static parity server uses port 5500 (see static-headers.json; avoids :5000 / AirPlay).
# npm run test:e2e:hosting sets this automatically.
# PLAYWRIGHT_USE_STATIC_PARITY_SERVER=1

# IndexNow (build-time URL submission). Key file must be served at
# `https://<your-site>/{INDEXNOW_KEY}.txt` (see `public/{INDEXNOW_KEY}.txt`).
# Bing’s global API (`api.indexnow.org`) often returns 403 UserForbiddedToAccessSite until the
# same hostname + key are verified in Bing Webmaster Tools; Yandex/Seznam fallbacks may still
# accept. To avoid the Bing warning in logs, set primary to a partner endpoint, e.g.:
# INDEXNOW_ENDPOINT=https://yandex.com/indexnow
# INDEXNOW_KEY=a503ff689a18407993ac047df017d9a8
# INDEXNOW_FALLBACK_ENDPOINTS=https://search.seznam.cz/indexnow

# Lead forms — Augusta Global Ingest Protocol.
# Full routing table: apps/vertaflow-crm/docs/CRM_LEAD_ROUTING.md
# Primary: POST JSON to the versioned Global Ingest Engine on the admin subdomain.
# PUBLIC_INGEST_URL=https://admin.vertaflow.io/api/v1/ingest
# Clerk org id (tenant) for this marketing build — threaded via `X-Tenant-Id`.
# PUBLIC_TENANT_ID=org_...
# Fallback (legacy /api/lead endpoint; kept for older deploys).
# PUBLIC_CRM_LEAD_URL=https://admin.vertaflow.io/api/lead
# Lighthouse (audits / reports only — not the public lead API):
# PUBLIC_API_URL=https://lighthouse-audit--lighthouse-492701.us-east4.hosted.app

# Cloudflare Turnstile widget site key. Defaults: test key in `astro dev`, production key in builds.
# Set the site key here (production Turnstile widget should be configured as
# "Invisible" in the Cloudflare dashboard — the UI only pops if the visitor
# is flagged; otherwise the token is obtained silently). API verification
# must use the matching secret (TURNSTILE_SECRET_KEY) on Agency OS + Lighthouse.
# For `astro preview` on localhost, set the always-pass test key so the widget
# matches your API’s test secret:
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# @see https://developers.cloudflare.com/turnstile/get-started/client-side-rendering/#invisibly-render-turnstile
# @see https://developers.cloudflare.com/turnstile/troubleshooting/testing/

# GetStream Chat (live chat on marketing) — https://getstream.io/chat/
# Set PUBLIC_ENABLE_STREAM_CHAT=1 to show the floating widget. Server route issues JWTs; never expose STREAM_CHAT_SECRET to the client.
# PUBLIC_ENABLE_STREAM_CHAT=1
# PUBLIC_STREAM_CHAT_API_KEY=your_stream_app_api_key
# STREAM_CHAT_SECRET=your_stream_app_secret
# Optional: Stream user id for your team inbox (defaults to production inbox user).
# STREAM_CHAT_INBOX_USER_ID=DBAStudio315
# STREAM_CHAT_INBOX_NAME=Designed by Anthony
