{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "designed-by-anthony",
	"main": ".open-next/worker.js",
	"base_dir": ".open-next",
	"compatibility_date": "2026-05-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dba-ledger",
      "database_id": "961ce211-2843-4ed7-a609-9ab224f7eb8a"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "NEXT_CACHE_WORKERS_KV",
      "id": "860a4c60147a484a995ed207af8094de"
    }
  ],
	"routes": [
		{ "pattern": "designedbyanthony.com", "custom_domain": true },
		{ "pattern": "www.designedbyanthony.com", "custom_domain": true }
	]
}
