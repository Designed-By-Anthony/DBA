{
	"name": "@dba/web",
	"version": "0.0.1",
	"private": true,
	"packageManager": "bun@1.3.13",
	"type": "module",
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=24.11.0"
	},
	"browserslist": {
		"production": [
			"last 2 Chrome major versions",
			"last 2 Firefox major versions",
			"last 2 Edge major versions",
			"last 2 Safari major versions",
			"not dead",
			"not ie <= 11",
			"not op_mini all"
		],
		"development": [
			"last 1 Chrome major version",
			"last 1 Firefox major version",
			"last 1 Safari major version"
		]
	},
	"scripts": {
		"generate:gbp-playbook-cover": "bun build/generate-gbp-playbook-cover.mjs",
		"generate:gbp-playbook-hero": "bun build/generate-gbp-playbook-hero.mjs",
		"build:site-script": "mkdir -p public/scripts && esbuild src/scripts/site.ts --bundle --platform=browser --format=esm --target=es2020 --minify --outfile=public/scripts/site.js && bun build/trim-generated-whitespace.mjs public/scripts/site.js",
		"sync:static-headers": "bun build/sync-static-headers.mjs",
		"prepare:next": "bun run build:site-script && bun run sync:static-headers",
		"dev": "bun run build:site-script && next dev",
		"build": "bun build/ensure-workspace-install.mjs && bun run build:pages",
		"build:next": "bun run prepare:next && next build --webpack",
		"build:worker": "opennextjs-cloudflare build -c wrangler.worker.json",
		"build:pages": "bun run build:worker && bun build/prepare-pages-bundle.mjs",
		"preview:worker": "bun run build:worker && opennextjs-cloudflare preview -c wrangler.worker.json",
		"deploy:worker": "bun run build:worker && opennextjs-cloudflare deploy -c wrangler.worker.json",
		"deploy": "bun run deploy:pages",
		"deploy:pages": "bun run build:pages && wrangler pages deploy .vercel/output/static -c wrangler.json --project-name ${CLOUDFLARE_PAGES_PROJECT_NAME:-designed-by-anthony}",
		"start": "next start",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@dba/shared": "file:../../packages/shared",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/outfit": "^5.2.8",
		"@fontsource/abril-fatface": "^5.2.7",
		"framer-motion": "^12.38.0",
		"gsap": "^3.15.0",
		"next": "16.2.4",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"sharp": "^0.34.5",
		"zod": "^4.4.0"
	},
	"devDependencies": {
		"@opennextjs/cloudflare": "^1.19.4",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/node": "^24",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.28.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"wrangler": "^4.86.0"
	}
}
