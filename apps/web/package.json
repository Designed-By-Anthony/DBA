{
	"name": "@dba/web",
	"version": "0.0.1",
	"private": true,
	"packageManager": "bun@1.3.13",
	"type": "module",
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=24.11.0"
	},
	"browserslist": {
		"production": [
			"last 2 Chrome major versions",
			"last 2 Firefox major versions",
			"last 2 Edge major versions",
			"last 2 Safari major versions",
			"not dead",
			"not ie <= 11",
			"not op_mini all"
		],
		"development": [
			"last 1 Chrome major version",
			"last 1 Firefox major version",
			"last 1 Safari major version"
		]
	},
	"scripts": {
		"generate:gbp-playbook-cover": "bun build/generate-gbp-playbook-cover.mjs",
		"generate:gbp-playbook-hero": "bun build/generate-gbp-playbook-hero.mjs",
		"generate:master-wordmark": "bun build/generate-master-wordmark-png.mjs",
		"build:site-script": "mkdir -p public/scripts && esbuild src/scripts/site.ts --bundle --platform=browser --format=esm --target=es2020 --minify --outfile=public/scripts/site.js && bun build/trim-generated-whitespace.mjs public/scripts/site.js",
		"sync:static-headers": "bun build/sync-static-headers.mjs",
		"prepare:next": "bun run generate:master-wordmark && bun run build:site-script && bun run sync:static-headers",
		"dev": "bun run build:site-script && next dev",
		"build": "bun build/ensure-workspace-install.mjs && bun run build:worker",
		"build:next": "NODE_OPTIONS=\"--max-old-space-size=4096\" bun run prepare:next && NODE_OPTIONS=\"--max-old-space-size=4096\" next build --webpack",
		"build:worker": "NODE_OPTIONS=\"--max-old-space-size=4096\" opennextjs-cloudflare build",
		"preview:worker": "bun run build:worker && wrangler dev",
		"deploy:worker": "bun run build && wrangler deploy",
		"deploy": "bun run deploy:worker",
		"start": "next start",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@dba/shared": "file:../../packages/shared",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/outfit": "^5.2.8",
		"@fontsource/abril-fatface": "^5.2.7",
		"@marsidev/react-turnstile": "^1.5.1",
		"drizzle-orm": "^0.45.2",
		"next": "16.2.4",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"sharp": "^0.34.5",
		"zod": "^4.4.0"
	},
	"devDependencies": {
		"@opennextjs/cloudflare": "^1.19.4",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/node": "^24",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.28.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"wrangler": "^4.86.0"
	}
}
