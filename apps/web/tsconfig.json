{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"],
			"@dba/shared/lib/*": ["../../packages/shared/src/lib/*"],
			"@dba/shared/lighthouse/*": ["../../packages/shared/src/lighthouse/*"],
			"@dba/shared/lighthouse/lib/*": [
				"../../packages/shared/src/lighthouse/lib/*"
			],
			"@lh/lib/*": ["../../packages/shared/src/lighthouse/lib/*"],
			"@lh/*": ["./src/lighthouse/*"],
			"@dba/shared/db/*": ["../../packages/shared/src/db/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"../../cypress",
		"../../playwright",
		"scratch",
		"customer-site-embeds"
	]
}
