{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dba-admin",
  "main": ".open-next/worker.js",
  "base_dir": ".open-next",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dba-ledger",
      "database_id": "961ce211-2843-4ed7-a609-9ab224f7eb8a"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "NEXT_CACHE",
      "id": "72f85b0a2e284e7c890815e77bc0982a",
    }
  ],
  "routes": [
    { "pattern": "admin.designedbyanthony.com", "custom_domain": true }
  ]
}
