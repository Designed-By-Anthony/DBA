# Public values inlined into `index.html` at build time (Vite).
# Set these on the VertaFlow marketing Vercel project.

# Cloudflare Turnstile SITE key (public). Required for production `POST /api/lead` on Agency OS.
VITE_PUBLIC_TURNSTILE_SITE_KEY=

# Clerk org id for the **VertaFlow master** tenant (must exist in `tenants.clerk_org_id`).
# When set, early-access submissions from vertaflow.io include `agencyId` so they never land in the wrong inbox.
VITE_CRM_DEFAULT_AGENCY_ID=

# Full URL to public lead ingest (default in code: https://admin.vertaflow.io/api/lead).
# VITE_CRM_LEAD_URL=

# Canonical marketing origin for telemetry / JSON-LD (optional).
# VITE_PUBLIC_DOMAIN=https://vertaflow.io

# Sentry browser DSN for marketing shell (optional).
# VITE_SENTRY_DSN=
