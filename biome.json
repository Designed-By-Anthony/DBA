{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/dist",
			"!**/coverage",
			"!**/playwright-report",
			"!**/test-results",
			"!**/cypress/screenshots",
			"!**/cypress/videos",
			"!**/public/scripts",
			"!static-headers.json",
			"!netlify.toml"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"html": {
		"parser": {
			"interpolation": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/styles/freshworks-chat-widget.css"],
			"linter": {
				"rules": {
					"complexity": {
						"noImportantStyles": "off"
					}
				}
			}
		},
		{
			"includes": ["src/styles/theme.css", "src/styles/layout-shell.css"],
			"linter": {
				"rules": {
					"complexity": {
						"noImportantStyles": "off"
					},
					"style": {
						"noDescendingSpecificity": "off"
					}
				}
			}
		},
		{
			"includes": ["emails/**/*.html"],
			"linter": {
				"rules": {
					"complexity": {
						"noImportantStyles": "off"
					}
				}
			}
		}
	]
}
